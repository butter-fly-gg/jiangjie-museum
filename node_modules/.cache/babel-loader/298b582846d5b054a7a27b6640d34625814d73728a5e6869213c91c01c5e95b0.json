"next\">❯</div>\r\n    </div>\r\n\r\n    <button class=\"enter-btn\" @click=\"enter\">进入 {{ currentItem.name }}</button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nimport storyImg from '../imgs/Game1.l.png'\r\nimport interactiveImg from '../imgs/Game1.m.png'\r\nimport scrollImg from '../imgs/Game1.r.png'\r\n\r\nconst router = useRouter()\r\n\r\nconst modeList = ref([\r\n  { name: '故事聆听模式', img: storyImg, path: '/story' },\r\n  { name: '现场交互模式', img: interactiveImg, path: '/interactive' },\r\n  { name: '线上绘卷模式', img: scrollImg, path: '/scroll' },\r\n])\r\n\r\nconst current = ref(1) // 永远中间是选中项\r\n\r\n// 计算位移：让当前项居中\r\nconst offset = computed(() => {\r\n  return -(current.value - 1) * 33.33\r\n})\r\n\r\nconst currentItem = computed(() => modeList.value[current.value])\r\n\r\n// 左切换\r\nfunction prev() {\r\n  current.value = current.value === 0 ? 2 : current.value - 1\r\n}\r\n\r\n// 右切换\r\nfunction next() {\r\n  current.value = current.value === 2 ? 0 : current.value + 1\r\n}\r\n\r\nfunction select(i) {\r\n  current.value = i\r\n}\r\n\r\nfunction goBack() {\r\n  router.back()\r\n}\r\n\r\nfunction enter() {\r\n  router.push(currentItem.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background: url(../imgs/Gamecover_1.png) no-repeat center center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n\r\n.title {\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 30px;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 轮播容器 */\r\n.carousel-container {\r\n  position: relative;\r\n  width: 100%;\r\n  max-width: 1000px;\r\n  height: 450px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n/* 箭头 */\r\n.arrow {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 50px;\r\n  height: 50px;\r\n  background: rgba(255,255,255,0.2);\r\n  border: 2px solid #fff;\r\n  border-radius: 50%;\r\n  color: #fff;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  z-index: 10;\r\n}\r\n.arrow.left { left: 0px; }\r\n.arrow.right { right: 0px; }\r\n\r\n/* 三张图并排 */\r\n.carousel-wrapper {\r\n  display: flex;\r\n  width: 100%;\r\n  transition: transform 0.5s ease;\r\n  transform: translateX(v-bind('offset + \"%'));\r\n}\r\n\r\n/* 卡片 */\r\n.mode-card {\r\n  width: 33.333%;\r\n  height: 400px;\r\n  flex-shrink: 0;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.4s ease;\r\n  transform: scale(0.85);\r\n  opacity: 0.8;\r\n}\r\n\r\n/* 中间激活放大 */\r\n.mode-card.active {\r\n  transform: scale(1);\r\n  opacity: 1;\r\n}\r\n\r\n/* 图片 */\r\n.mode-img {\r\n  width: 100%;\r\n  height: 350px;\r\n  object-fit: cover;\r\n}\r\n\r\n/* 文字 */\r\n.label {\r\n  margin-top: 10px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  text-shadow: 0 2px 5px rgba(0,0,0,0.7);\r\n  text-align: center;\r\n}\r\n\r\n/* 进入按钮 */\r\n.enter-btn {\r\n  margin-top: 20px;\r\n  padding: 14px 50px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAW;;EAMfA,KAAK,EAAC;AAAoB;;EAIxBA,KAAK,EAAC;AAAkB;;;;EASpBA,KAAK,EAAC;AAAO;;;;;;;;uBAnB1BC,mBAAA,CA8BM,OA9BNC,UA8BM,GA7BJC,mBAAA,CAAgD;IAA3CH,KAAK,EAAC,UAAU;IAAEI,OAAK,EAAAC,MAAA,QAAAA,MAAA,UAAAC,IAAA,KAAEC,IAAA,CAAAC,MAAA,IAAAD,IAAA,CAAAC,MAAA,IAAAF,IAAA,CAAM;KAAE,MAAI,G,0BAE1CH,mBAAA,CAAuC;IAAnCH,KAAK,EAAC;EAAO,GAAC,kBAAgB,qBAElCS,mBAAA,YAAe,EACfN,mBAAA,CAqBM,OArBNO,UAqBM,GApBJP,mBAAA,CAA6C;IA