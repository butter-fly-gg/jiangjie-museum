00%;\r\n}\r\n\r\n/* 背景图：全屏铺满，无拉伸 */\r\n.bg-image {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  object-position: center;\r\n}\r\n\r\n/* 按钮容器：绝对定位在底部居中 */\r\n.enter-btn-container {\r\n  position: absolute;\r\n  bottom: 8%;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  z-index: 10;\r\n}\r\n\r\n/* 进入探索按钮：完全匹配参考图样式 */\r\n.enter-btn {\r\n  background: transparent;\r\n  border: none;\r\n  cursor: pointer;\r\n  padding: 10px 20px;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n/* 按钮主文字 */\r\n.btn-text {\r\n  display: block;\r\n  font-size: 32px;\r\n  font-weight: bold;\r\n  color: #fff;\r\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.6);\r\n  letter-spacing: 8px;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n/* 按钮英文副标题 */\r\n.btn-subtext {\r\n  display: block;\r\n  font-size: 16px;\r\n  color: #fff;\r\n  text-shadow: 1px 1px 2px rgba(0,0,0,0.6);\r\n  letter-spacing: 4px;\r\n  opacity: 0.9;\r\n}\r\n\r\n/* 按钮hover效果 */\r\n.enter-btn:hover .btn-text {\r\n  color: #ffd700;\r\n  transform: scale(1.05);\r\n}\r\n\r\n/* 右侧悬浮按钮组 */\r\n.float-buttons {\r\n  position: absolute;\r\n  top: 10%;\r\n  right: 2%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n  z-index: 10;\r\n}\r\n\r\n.float-btn {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n  border: 2px solid rgba(255,255,255,0.8);\r\n  background: rgba(0,0,0,0.3);\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.float-btn:hover {\r\n  background: rgba(192, 57, 43, 0.8);\r\n  border-color: #fff;\r\n}\r\n\r\n/* 左下角版本信息 */\r\n.version-info {\r\n  position: absolute;\r\n  bottom: 2%;\r\n  left: 2%;\r\n  color: #fff;\r\n  font-size: 12px;\r\n  text-shadow: 1px 1px 2px rgba(0,0,0,0.8);\r\n  z-index: 10;\r\n}\r\n\r\n.agreement {\r\n  margin-top: 4px;\r\n  font-size: 10px;\r\n  opacity: 0.8;\r\n}\r\n\r\n/* 响应式适配：手机端缩小字号 */\r\n@media (max-width: 768px) {\r\n 