{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  __name: 'ModeSelectView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n\n    // 模式数据\n    const modeList = ref([{\n      name: \"故事模式\",\n      desc: \"沉浸式讲述江姐革命事迹\",\n      path: \"/story\"\n    }, {\n      name: \"互动模式\",\n      desc: \"趣味问答，学习红色知识\",\n      path: \"/interactive\"\n    }, {\n      name: \"卷轴模式\",\n      desc: \"长卷浏览，一览生平历程\",\n      path: \"/scroll\"\n    }]);\n\n    // 当前选中\n    const current = ref(0);\n\n    // 选择\n    function select(index) {\n      current.value = index;\n    }\n\n    // 返回\n    function goBack() {\n      router.back();\n    }\n\n    // 进入模式\n    function enterMode() {\n      const target = modeList.value[current.value];\n      alert(\"即将进入：\" + target.name);\n      router.push(target.path);\n    }\n    const __returned__ = {\n      router,\n      modeList,\n      current,\n      select,\n      goBack,\n      enterMode,\n      ref,\n      get useRouter() {\n        return useRouter;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","useRouter","router","modeList","name","desc","path","current","select","index","value","goBack","back","enterMode","target","alert","push"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <!-- 返回按钮 -->\r\n    <div class=\"back-bar\" @click=\"goBack\">\r\n      ← 返回\r\n    </div>\r\n\r\n    <!-- 标题 -->\r\n    <h2 class=\"title\">选择参观模式</h2>\r\n\r\n    <!-- 模式选择 -->\r\n    <div class=\"mode-list\">\r\n      <div \r\n        class=\"mode-item\" \r\n        :class=\"{ active: current === index }\"\r\n        v-for=\"(item, index) in modeList\" \r\n        :key=\"index\"\r\n        @click=\"select(index)\"\r\n      >\r\n        <h3>{{ item.name }}</h3>\r\n        <p>{{ item.desc }}</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 进入按钮 -->\r\n    <button class=\"enter-btn\" @click=\"enterMode\">\r\n      进入当前模式\r\n    </button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nconst router = useRouter()\r\n\r\n// 模式数据\r\nconst modeList = ref([\r\n  {\r\n    name: \"故事模式\",\r\n    desc: \"沉浸式讲述江姐革命事迹\",\r\n    path: \"/story\"\r\n  },\r\n  {\r\n    name: \"互动模式\",\r\n    desc: \"趣味问答，学习红色知识\",\r\n    path: \"/interactive\"\r\n  },\r\n  {\r\n    name: \"卷轴模式\",\r\n    desc: \"长卷浏览，一览生平历程\",\r\n    path: \"/scroll\"\r\n  }\r\n])\r\n\r\n// 当前选中\r\nconst current = ref(0)\r\n\r\n// 选择\r\nfunction select(index) {\r\n  current.value = index\r\n}\r\n\r\n// 返回\r\nfunction goBack() {\r\n  router.back()\r\n}\r\n\r\n// 进入模式\r\nfunction enterMode() {\r\n  const target = modeList.value[current.value]\r\n  alert(\"即将进入：\" + target.name)\r\n  router.push(target.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 关键修复：使用你现有的图片资源路径 */\r\n.mode-page {\r\n  padding: 20px;\r\n  min-height: 100vh;\r\n  background: url(\"/src/imgs/Gamecover_1.png\") no-repeat center center;\r\n  background-size: cover;\r\n  background-color: #fdf3f2; /* 备用背景色 */\r\n}\r\n\r\n.back-bar {\r\n  font-size: 16px;\r\n  color: #c0392b;\r\n  cursor: pointer;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.title {\r\n  text-align: center;\r\n  color: #c0392b;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.mode-list {\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.mode-item {\r\n  background: white;\r\n  padding: 20px;\r\n  border-radius: 12px;\r\n  margin-bottom: 12px;\r\n  border: 2px solid transparent;\r\n  cursor: pointer;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.1);\r\n}\r\n\r\n.mode-item.active {\r\n  border-color: #c0392b;\r\n  background: #fdf3f2;\r\n}\r\n\r\n.mode-item h3 {\r\n  margin: 0 0 8px 0;\r\n  color: #333;\r\n}\r\n\r\n.mode-item p {\r\n  margin: 0;\r\n  color: #666;\r\n  font-size: 14px;\r\n}\r\n\r\n.enter-btn {\r\n  width: 100%;\r\n  padding: 14px;\r\n  background: #c0392b;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 16px;\r\n}\r\n</style>"],"mappings":";AAgCA,SAASA,GAAG,QAAQ,KAAK;AACzB,SAASC,SAAS,QAAQ,YAAY;;;;;;;IAEtC,MAAMC,MAAM,GAAGD,SAAS,CAAC,CAAC;;IAE1B;IACA,MAAME,QAAQ,GAAGH,GAAG,CAAC,CACnB;MACEI,IAAI,EAAE,MAAM;MACZC,IAAI,EAAE,aAAa;MACnBC,IAAI,EAAE;IACR,CAAC,EACD;MACEF,IAAI,EAAE,MAAM;MACZC,IAAI,EAAE,aAAa;MACnBC,IAAI,EAAE;IACR,CAAC,EACD;MACEF,IAAI,EAAE,MAAM;MACZC,IAAI,EAAE,aAAa;MACnBC,IAAI,EAAE;IACR,CAAC,CACF,CAAC;;IAEF;IACA,MAAMC,OAAO,GAAGP,GAAG,CAAC,CAAC,CAAC;;IAEtB;IACA,SAASQ,MAAMA,CAACC,KAAK,EAAE;MACrBF,OAAO,CAACG,KAAK,GAAGD,KAAK;IACvB;;IAEA;IACA,SAASE,MAAMA,CAAA,EAAG;MAChBT,MAAM,CAACU,IAAI,CAAC,CAAC;IACf;;IAEA;IACA,SAASC,SAASA,CAAA,EAAG;MACnB,MAAMC,MAAM,GAAGX,QAAQ,CAACO,KAAK,CAACH,OAAO,CAACG,KAAK,CAAC;MAC5CK,KAAK,CAAC,OAAO,GAAGD,MAAM,CAACV,IAAI,CAAC;MAC5BF,MAAM,CAACc,IAAI,CAACF,MAAM,CAACR,IAAI,CAAC;IAC1B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}