{"ast":null,"code":"export default {\n  name: 'StaticMapNav',\n  data() {\n    return {\n      transport: 'bus' // 默认公交\n    };\n  },\n  methods: {\n    handleLocate() {\n      alert('📍 已定位到当前位置');\n    },\n    handleRefresh() {\n      alert('🔄 正在为您重新规划路线...');\n    },\n    handleStartNav() {\n      const modeMap = {\n        car: '驾车',\n        bus: '公交',\n        bike: '骑行',\n        walk: '步行'\n      };\n      alert(`✅ 已选择【${modeMap[this.transport]}】\\n开始导航：江姐故里 → 东锅厂`);\n    }\n  }\n};","map":{"version":3,"names":["name","data","transport","methods","handleLocate","alert","handleRefresh","handleStartNav","modeMap","car","bus","bike","walk"],"sources":["E:\\jiangjie-museum\\GitHub\\jiangjie-museum\\src\\views\\BeautifulMap.vue"],"sourcesContent":["<template>\r\n  <div class=\"map-page\">\r\n    \r\n    <!-- ========== 顶部 Hero 区域 ========== -->\r\n    <div class=\"hero-section\">\r\n      <img \r\n        src=\"@/assets/images/beautiful/bg-map.jpg\" \r\n        alt=\"自贡游玩背景\" \r\n        class=\"hero-bg\"\r\n      />\r\n      <div class=\"hero-overlay\"></div>\r\n      \r\n      <div class=\"hero-content\">\r\n        <div class=\"status-bar\">\r\n          <span class=\"carrier\">VIRGIN</span>\r\n          <span class=\"time\">4:21 PM</span>\r\n          <span class=\"battery\">95%</span>\r\n        </div>\r\n        \r\n        <h1 class=\"page-title\">自贡游玩路线推荐</h1>\r\n        \r\n        <div class=\"route-search-bar\">\r\n          <span class=\"location-icon\">📍</span>\r\n          <span class=\"route-name\">江姐故里-东锅厂</span>\r\n          <span class=\"dropdown-arrow\">▼</span>\r\n        </div>\r\n        \r\n        <div class=\"hero-actions\">\r\n          <button class=\"icon-btn\">🔍</button>\r\n          <button class=\"icon-btn\">🧭</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- ========== 主内容区域 ========== -->\r\n    <div class=\"main-content\">\r\n      \r\n      <!-- 左侧地图区域 -->\r\n      <div class=\"map-container\">\r\n        <!-- 背景底图 -->\r\n        <img \r\n          src=\"@/assets/images/beautiful/bg-map.jpg\" \r\n          alt=\"地图底图\" \r\n          class=\"map-bg\"\r\n        />\r\n        \r\n        <!-- SVG 路线层 -->\r\n        <svg class=\"route-layer\" viewBox=\"0 0 375 667\" preserveAspectRatio=\"xMidYMid slice\">\r\n          <defs>\r\n            <filter id=\"routeShadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\r\n              <feDropShadow dx=\"0\" dy=\"2\" stdDeviation=\"3\" flood-opacity=\"0.3\"/>\r\n            </filter>\r\n          </defs>\r\n          \r\n          <!-- 绿色路线 (实线) -->\r\n          <path \r\n            class=\"route-line\"\r\n            d=\"M 60 480 L 80 450 L 120 420 L 180 400 L 220 380 L 260 360 L 280 340 L 300 320 L 320 300 L 340 280\"\r\n            stroke=\"#4CAF50\"\r\n            stroke-width=\"6\"\r\n            fill=\"none\"\r\n            stroke-linecap=\"round\"\r\n            stroke-linejoin=\"round\"\r\n            filter=\"url(#routeShadow)\"\r\n          />\r\n          \r\n          <!-- 起点标记 -->\r\n          <g class=\"marker start-marker\" transform=\"translate(60, 480)\">\r\n            <circle r=\"10\" fill=\"#2E7D32\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n            <text y=\"25\" text-anchor=\"middle\" font-size=\"12\" font-weight=\"bold\" fill=\"#333\">起点</text>\r\n            <text y=\"40\" text-anchor=\"middle\" font-size=\"10\" fill=\"#666\">江姐故里</text>\r\n          </g>\r\n          \r\n          <!-- 终点标记 -->\r\n          <g class=\"marker end-marker\" transform=\"translate(340, 280)\">\r\n            <circle r=\"10\" fill=\"#D32F2F\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n            <text y=\"25\" text-anchor=\"middle\" font-size=\"12\" font-weight=\"bold\" fill=\"#333\">终点</text>\r\n            <text y=\"40\" text-anchor=\"middle\" font-size=\"10\" fill=\"#666\">东锅厂</text>\r\n          </g>\r\n          \r\n          <!-- 途经点气泡 1 -->\r\n          <foreignObject x=\"100\" y=\"350\" width=\"100\" height=\"120\" class=\"spot-bubble\">\r\n            <div xmlns=\"http://www.w3.org/1999/xhtml\" class=\"bubble-wrapper\">\r\n              <img src=\"@/assets/images/beautiful/spot-1.jpg\" alt=\"途经点1\" class=\"bubble-img\" />\r\n              <div class=\"bubble-arrow\"></div>\r\n            </div>\r\n          </foreignObject>\r\n          \r\n          <!-- 途经点气泡 2 -->\r\n          <foreignObject x=\"200\" y=\"320\" width=\"100\" height=\"120\" class=\"spot-bubble\">\r\n            <div xmlns=\"http://www.w3.org/1999/xhtml\" class=\"bubble-wrapper\">\r\n              <img src=\"@/assets/images/beautiful/spot-2.jpg\" alt=\"途经点2\" class=\"bubble-img\" />\r\n              <div class=\"bubble-arrow\"></div>\r\n            </div>\r\n          </foreignObject>\r\n          \r\n          <!-- 途经点气泡 3 -->\r\n          <foreignObject x=\"300\" y=\"250\" width=\"100\" height=\"120\" class=\"spot-bubble\">\r\n            <div xmlns=\"http://www.w3.org/1999/xhtml\" class=\"bubble-wrapper\">\r\n              <img src=\"@/assets/images/beautiful/spot-3.jpg\" alt=\"途经点3\" class=\"bubble-img\" />\r\n              <div class=\"bubble-arrow\"></div>\r\n            </div>\r\n          </foreignObject>\r\n          \r\n          <!-- 橙色兴趣点 -->\r\n          <circle cx=\"50\" cy=\"300\" r=\"4\" fill=\"#FF9800\" opacity=\"0.8\"/>\r\n          <circle cx=\"150\" cy=\"500\" r=\"4\" fill=\"#FF9800\" opacity=\"0.8\"/>\r\n          <circle cx=\"250\" cy=\"450\" r=\"4\" fill=\"#FF9800\" opacity=\"0.8\"/>\r\n          <circle cx=\"320\" cy=\"200\" r=\"4\" fill=\"#FF9800\" opacity=\"0.8\"/>\r\n          <circle cx=\"80\" cy=\"250\" r=\"4\" fill=\"#FF9800\" opacity=\"0.8\"/>\r\n          <circle cx=\"350\" cy=\"400\" r=\"4\" fill=\"#FF9800\" opacity=\"0.8\"/>\r\n        </svg>\r\n        \r\n        <!-- 定位按钮 -->\r\n        <button class=\"locate-btn\" @click=\"handleLocate\">\r\n          <span>📍</span>\r\n        </button>\r\n      </div>\r\n\r\n      <!-- 右侧信息面板 -->\r\n      <div class=\"info-panel\">\r\n        <div class=\"panel-wrapper\">\r\n          \r\n          <!-- 统计信息区 -->\r\n          <div class=\"stats-section\">\r\n            <div class=\"stats-header\">\r\n              <h2>行程概览</h2>\r\n            </div>\r\n            \r\n            <div class=\"distance-block\">\r\n              <div class=\"distance-label\">总计距离 <span class=\"en-label\">DISTANCE</span></div>\r\n              <div class=\"distance-value\">14<span class=\"km-unit\">km</span></div>\r\n            </div>\r\n            \r\n            <div class=\"info-list\">\r\n              <div class=\"info-row\">\r\n                <span class=\"info-key\">途径地点</span>\r\n                <span class=\"info-value\">燊海井 / 105厂</span>\r\n              </div>\r\n              <div class=\"info-row\">\r\n                <span class=\"info-key\">预计行程时间</span>\r\n                <span class=\"info-value\">2 小时 25 分</span>\r\n              </div>\r\n              <div class=\"info-row\">\r\n                <span class=\"info-key\">餐饮计划</span>\r\n                <span class=\"info-value phone\">105号肥肠馆 📞</span>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"recommend-card\">\r\n              <div class=\"rec-badge\">推荐最优</div>\r\n              <button class=\"rec-refresh\" @click=\"handleRefresh\">\r\n                <span class=\"refresh-icon\">🔄</span>\r\n                <span class=\"refresh-text\">立即更换</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 分隔线 -->\r\n          <div class=\"panel-divider\"></div>\r\n          \r\n          <!-- 交通方式选择 -->\r\n          <div class=\"transport-section\">\r\n            <div class=\"transport-header\">\r\n              <h3>交通方式</h3>\r\n            </div>\r\n            \r\n            <div class=\"transport-grid\">\r\n              <button \r\n                class=\"transport-item\"\r\n                :class=\"{ active: transport === 'car' }\"\r\n                @click=\"transport = 'car'\"\r\n              >\r\n                <span class=\"t-icon\">🚗</span>\r\n                <span class=\"t-label\">驾车</span>\r\n              </button>\r\n              \r\n              <button \r\n                class=\"transport-item\"\r\n                :class=\"{ active: transport === 'bus' }\"\r\n                @click=\"transport = 'bus'\"\r\n              >\r\n                <span class=\"t-icon\">🚌</span>\r\n                <span class=\"t-label\">公交</span>\r\n              </button>\r\n              \r\n              <button \r\n                class=\"transport-item\"\r\n                :class=\"{ active: transport === 'bike' }\"\r\n                @click=\"transport = 'bike'\"\r\n              >\r\n                <span class=\"t-icon\">🚲</span>\r\n                <span class=\"t-label\">骑行</span>\r\n              </button>\r\n              \r\n              <button \r\n                class=\"transport-item\"\r\n                :class=\"{ active: transport === 'walk' }\"\r\n                @click=\"transport = 'walk'\"\r\n              >\r\n                <span class=\"t-icon\">🚶</span>\r\n                <span class=\"t-label\">步行</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 导航按钮 -->\r\n          <button class=\"nav-button\" @click=\"handleStartNav\">\r\n            <span class=\"flower\">❀</span>\r\n            选定并开始导航\r\n          </button>\r\n          \r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'StaticMapNav',\r\n  data() {\r\n    return {\r\n      transport: 'bus'  // 默认公交\r\n    };\r\n  },\r\n  methods: {\r\n    handleLocate() {\r\n      alert('📍 已定位到当前位置');\r\n    },\r\n    handleRefresh() {\r\n      alert('🔄 正在为您重新规划路线...');\r\n    },\r\n    handleStartNav() {\r\n      const modeMap = {\r\n        car: '驾车',\r\n        bus: '公交',\r\n        bike: '骑行',\r\n        walk: '步行'\r\n      };\r\n      alert(`✅ 已选择【${modeMap[this.transport]}】\\n开始导航：江姐故里 → 东锅厂`);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* ========== 全局重置 ========== */\r\n* {\r\n  margin: 0;\r\n  padding: 0;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.map-page {\r\n  width: 100%;\r\n  height: 100vh;\r\n  overflow: hidden;\r\n  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;\r\n  background: #f5f5dc;\r\n  position: relative;\r\n}\r\n\r\n/* ========== Hero 区域 ========== */\r\n.hero-section {\r\n  position: relative;\r\n  height: 220px;\r\n  overflow: hidden;\r\n}\r\n\r\n.hero-bg {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.hero-overlay {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 50%, rgba(245,245,220,1) 100%);\r\n}\r\n\r\n.hero-content {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  padding: 15px 20px;\r\n  z-index: 10;\r\n}\r\n\r\n.status-bar {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  color: #fff;\r\n  font-size: 12px;\r\n  margin-bottom: 15px;\r\n  text-shadow: 0 1px 3px rgba(0,0,0,0.5);\r\n}\r\n\r\n.page-title {\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: 600;\r\n  text-align: center;\r\n  text-shadow: 0 2px 8px rgba(0,0,0,0.5);\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.route-search-bar {\r\n  background: #fff;\r\n  border-radius: 25px;\r\n  padding: 10px 20px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 8px;\r\n  max-width: 320px;\r\n  margin: 0 auto;\r\n  box-shadow: 0 4px 15px rgba(0,0,0,0.2);\r\n}\r\n\r\n.location-icon {\r\n  color: #D32F2F;\r\n  font-size: 16px;\r\n}\r\n\r\n.route-name {\r\n  color: #333;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n}\r\n\r\n.dropdown-arrow {\r\n  color: #999;\r\n  font-size: 10px;\r\n}\r\n\r\n.hero-actions {\r\n  position: absolute;\r\n  top: 50px;\r\n  right: 20px;\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\n\r\n.icon-btn {\r\n  width: 36px;\r\n  height: 36px;\r\n  border: none;\r\n  border-radius: 50%;\r\n  background: rgba(0,0,0,0.4);\r\n  backdrop-filter: blur(10px);\r\n  color: #fff;\r\n  font-size: 16px;\r\n  cursor: pointer;\r\n  transition: background 0.2s;\r\n}\r\n\r\n.icon-btn:hover {\r\n  background: rgba(0,0,0,0.6);\r\n}\r\n\r\n/* ========== 移动端布局 ========== */\r\n@media (max-width: 767px) {\r\n  .main-content {\r\n    position: absolute;\r\n    top: 180px;\r\n    left: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    display: flex;\r\n    flex-direction: column;\r\n  }\r\n  \r\n  .map-container {\r\n    flex: 1;\r\n    position: relative;\r\n    overflow: hidden;\r\n  }\r\n  \r\n  .info-panel {\r\n    position: absolute;\r\n    bottom: 0;\r\n    left: 0;\r\n    right: 0;\r\n    background: #fff;\r\n    border-radius: 24px 24px 0 0;\r\n    box-shadow: 0 -8px 30px rgba(0,0,0,0.15);\r\n    padding: 20px;\r\n    z-index: 30;\r\n  }\r\n  \r\n  .panel-wrapper {\r\n    max-width: 400px;\r\n    margin: 0 auto;\r\n  }\r\n  \r\n  .stats-section {\r\n    display: flex;\r\n    align-items: flex-start;\r\n    gap: 15px;\r\n    margin-bottom: 20px;\r\n  }\r\n  \r\n  .distance-block {\r\n    flex-shrink: 0;\r\n  }\r\n  \r\n  .info-list {\r\n    flex: 1;\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 6px;\r\n  }\r\n  \r\n  .recommend-card {\r\n    flex-shrink: 0;\r\n    width: 85px;\r\n    background: linear-gradient(135deg, #FFD54F 0%, #FFB300 100%);\r\n    border-radius: 12px;\r\n    padding: 10px 8px;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    box-shadow: 0 4px 12px rgba(255, 179, 0, 0.4);\r\n  }\r\n  \r\n  .transport-section {\r\n    margin-top: 20px;\r\n  }\r\n  \r\n  .transport-grid {\r\n    display: flex;\r\n    justify-content: space-around;\r\n    margin-top: 15px;\r\n  }\r\n  \r\n  .transport-item {\r\n    width: 60px;\r\n    height: 60px;\r\n    border: none;\r\n    border-radius: 16px;\r\n    background: transparent;\r\n    cursor: pointer;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    justify-content: center;\r\n    gap: 4px;\r\n    font-size: 24px;\r\n    transition: all 0.3s ease;\r\n    opacity: 0.5;\r\n    color: #666;\r\n  }\r\n  \r\n  .transport-item.active {\r\n    background: linear-gradient(135deg, #D32F2F, #E53935);\r\n    opacity: 1;\r\n    transform: translateY(-5px);\r\n    box-shadow: 0 8px 20px rgba(211, 47, 47, 0.4);\r\n    color: #fff;\r\n  }\r\n  \r\n  .nav-button {\r\n    width: 100%;\r\n    height: 56px;\r\n    background: linear-gradient(135deg, #D32F2F 0%, #E53935 100%);\r\n    border: none;\r\n    border-radius: 16px;\r\n    color: #fff;\r\n    font-size: 18px;\r\n    font-weight: 700;\r\n    cursor: pointer;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    gap: 10px;\r\n    box-shadow: 0 8px 25px rgba(211, 47, 47, 0.4);\r\n    margin-top: 20px;\r\n    transition: all 0.3s ease;\r\n  }\r\n  \r\n  .nav-button:hover {\r\n    transform: translateY(-2px);\r\n    box-shadow: 0 12px 30px rgba(211, 47, 47, 0.5);\r\n  }\r\n}\r\n\r\n/* ========== Web端布局 ========== */\r\n@media (min-width: 768px) {\r\n  .main-content {\r\n    display: flex;\r\n    height: calc(100vh - 220px);\r\n  }\r\n  \r\n  /* 左侧地图区域 */\r\n  .map-container {\r\n    flex: 1;\r\n    position: relative;\r\n    overflow: hidden;\r\n    background: #f5f5dc;\r\n  }\r\n  \r\n  .map-bg {\r\n    width: 100%;\r\n    height: 100%;\r\n    object-fit: cover;\r\n  }\r\n  \r\n  .route-layer {\r\n    position: absolute;\r\n    top: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n  }\r\n  \r\n  .locate-btn {\r\n    position: absolute;\r\n    left: 30px;\r\n    bottom: 30px;\r\n    width: 56px;\r\n    height: 56px;\r\n    border-radius: 50%;\r\n    background: #333;\r\n    border: none;\r\n    color: #fff;\r\n    font-size: 24px;\r\n    cursor: pointer;\r\n    box-shadow: 0 6px 20px rgba(0,0,0,0.3);\r\n    transition: transform 0.2s;\r\n    z-index: 20;\r\n  }\r\n  \r\n  .locate-btn:hover {\r\n    transform: scale(1.1);\r\n  }\r\n  \r\n  /* 右侧信息面板 */\r\n  .info-panel {\r\n    width: 420px;\r\n    background: #fff;\r\n    box-shadow: -5px 0 30px rgba(0,0,0,0.1);\r\n    overflow-y: auto;\r\n    display: flex;\r\n    flex-direction: column;\r\n  }\r\n  \r\n  .panel-wrapper {\r\n    padding: 30px;\r\n    height: 100%;\r\n    display: flex;\r\n    flex-direction: column;\r\n  }\r\n  \r\n  .stats-header h2,\r\n  .transport-header h3 {\r\n    font-size: 18px;\r\n    font-weight: 700;\r\n    color: #333;\r\n    margin-bottom: 20px;\r\n    padding-bottom: 12px;\r\n    border-bottom: 2px solid #f0f0f0;\r\n  }\r\n  \r\n  .stats-section {\r\n    margin-bottom: 30px;\r\n  }\r\n  \r\n  .distance-block {\r\n    margin-bottom: 25px;\r\n  }\r\n  \r\n  .distance-label {\r\n    font-size: 13px;\r\n    color: #999;\r\n    margin-bottom: 8px;\r\n  }\r\n  \r\n  .en-label {\r\n    font-size: 10px;\r\n    letter-spacing: 1px;\r\n    display: block;\r\n    opacity: 0.7;\r\n  }\r\n  \r\n  .distance-value {\r\n    font-size: 48px;\r\n    font-weight: 800;\r\n    color: #333;\r\n    line-height: 1;\r\n  }\r\n  \r\n  .km-unit {\r\n    font-size: 20px;\r\n    font-weight: 400;\r\n    color: #666;\r\n    margin-left: 4px;\r\n  }\r\n  \r\n  .info-list {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 12px;\r\n    margin-bottom: 25px;\r\n  }\r\n  \r\n  .info-row {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    font-size: 14px;\r\n    padding: 10px 0;\r\n    border-bottom: 1px solid #f5f5f5;\r\n  }\r\n  \r\n  .info-row:last-child {\r\n    border-bottom: none;\r\n  }\r\n  \r\n  .info-key {\r\n    color: #999;\r\n    font-weight: 500;\r\n  }\r\n  \r\n  .info-value {\r\n    color: #333;\r\n    font-weight: 600;\r\n  }\r\n  \r\n  .info-value.phone {\r\n    color: #2196F3;\r\n 