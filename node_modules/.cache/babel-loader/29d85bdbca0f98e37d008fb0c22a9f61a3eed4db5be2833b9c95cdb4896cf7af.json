{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/web.url-search-params.delete.js\";\nimport \"core-js/modules/web.url-search-params.has.js\";\nimport \"core-js/modules/web.url-search-params.size.js\";\nimport { ref, computed } from 'vue';\nimport { useRouter } from 'vue-router';\nconst cardWidth = 320;\n// 卡片间距\nconst gap = 20;\n\n// 计算轨道偏移量，实现居中\n\nexport default {\n  __name: 'ModeSelectView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n\n    // 模式数据（对应三张图片）\n    const modeList = ref([{\n      name: \"故事聆听模式\",\n      img: \"Game1.l.png\",\n      path: \"/story\",\n      desc: \"沉浸式讲述江姐革命事迹\"\n    }, {\n      name: \"现场交互模式\",\n      img: \"Game1.m.png\",\n      path: \"/interactive\",\n      desc: \"趣味问答，学习红色知识\"\n    }, {\n      name: \"线上绘卷模式\",\n      img: \"Game1.r.png\",\n      path: \"/scroll\",\n      desc: \"长卷浏览，一览生平历程\"\n    }]);\n\n    // 当前选中的索引（默认中间的交互模式）\n    const currentIndex = ref(1);\n    // 卡片宽度（用于计算位移）\n    const offset = computed(() => {\n      // 让当前选中的卡片居中，偏移量 = -(索引 * (卡片宽度+间距)) + (容器宽度 - 卡片宽度)/2\n      return -(currentIndex.value * (cardWidth + gap)) + (960 - cardWidth) / 2;\n    });\n\n    // 当前选中的模式\n    const currentMode = computed(() => modeList.value[currentIndex.value]);\n\n    // 获取正确的图片路径（适配当前目录层级）\n    function getImgUrl(imgName) {\n      // 你的组件在 views 文件夹，imgs 在 src 同级，所以用 ../imgs/\n      return new URL(`../imgs/${imgName}`, import.meta.url).href;\n    }\n\n    // 上一个模式\n    function prevMode() {\n      currentIndex.value = currentIndex.value === 0 ? modeList.value.length - 1 : currentIndex.value - 1;\n    }\n\n    // 下一个模式\n    function nextMode() {\n      currentIndex.value = currentIndex.value === modeList.value.length - 1 ? 0 : currentIndex.value + 1;\n    }\n\n    // 点击卡片直接选中\n    function selectMode(index) {\n      currentIndex.value = index;\n    }\n\n    // 返回上一页\n    function goBack() {\n      router.back();\n    }\n\n    // 进入当前选中的模式\n    function enterCurrentMode() {\n      router.push(currentMode.value.path);\n    }\n    const __returned__ = {\n      router,\n      modeList,\n      currentIndex,\n      cardWidth,\n      gap,\n      offset,\n      currentMode,\n      getImgUrl,\n      prevMode,\n      nextMode,\n      selectMode,\n      goBack,\n      enterCurrentMode,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","cardWidth","gap","router","modeList","name","img","path","desc","currentIndex","offset","value","currentMode","getImgUrl","imgName","URL","import","meta","url","href","prevMode","length","nextMode","selectMode","index","goBack","back","enterCurrentMode","push"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <!-- 返回按钮 -->\r\n    <div class=\"back-bar\" @click=\"goBack\">\r\n      ← 返回\r\n    </div>\r\n\r\n    <!-- 标题 -->\r\n    <h2 class=\"title\">—— 请选择您想体验的模式 ——</h2>\r\n\r\n    <!-- 横向三图轮播容器 -->\r\n    <div class=\"carousel-container\">\r\n      <!-- 左箭头 -->\r\n      <button class=\"arrow-btn left-arrow\" @click=\"prevMode\">\r\n        <span class=\"arrow-icon\">❮</span>\r\n      </button>\r\n\r\n      <!-- 三图显示轨道 -->\r\n      <div class=\"carousel-track\" :style=\"{ transform: `translateX(${offset}px)` }\">\r\n        <div \r\n          class=\"mode-card\" \r\n          :class=\"{ active: currentIndex === index }\"\r\n          v-for=\"(item, index) in modeList\" \r\n          :key=\"index\"\r\n          @click=\"selectMode(index)\"\r\n        >\r\n          <!-- 模式图片 -->\r\n          <img :src=\"getImgUrl(item.img)\" :alt=\"item.name\" class=\"mode-img\">\r\n          <!-- 模式名称 -->\r\n          <div class=\"mode-name\">{{ item.name }}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 右箭头 -->\r\n      <button class=\"arrow-btn right-arrow\" @click=\"nextMode\">\r\n        <span class=\"arrow-icon\">❯</span>\r\n      </button>\r\n    </div>\r\n\r\n    <!-- 进入按钮 -->\r\n    <button class=\"enter-btn\" @click=\"enterCurrentMode\">\r\n      进入 {{ currentMode.name }}\r\n    </button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nconst router = useRouter()\r\n\r\n// 模式数据（对应三张图片）\r\nconst modeList = ref([\r\n  {\r\n    name: \"故事聆听模式\",\r\n    img: \"Game1.l.png\",\r\n    path: \"/story\",\r\n    desc: \"沉浸式讲述江姐革命事迹\"\r\n  },\r\n  {\r\n    name: \"现场交互模式\",\r\n    img: \"Game1.m.png\",\r\n    path: \"/interactive\",\r\n    desc: \"趣味问答，学习红色知识\"\r\n  },\r\n  {\r\n    name: \"线上绘卷模式\",\r\n    img: \"Game1.r.png\",\r\n    path: \"/scroll\",\r\n    desc: \"长卷浏览，一览生平历程\"\r\n  }\r\n])\r\n\r\n// 当前选中的索引（默认中间的交互模式）\r\nconst currentIndex = ref(1)\r\n// 卡片宽度（用于计算位移）\r\nconst cardWidth = 320\r\n// 卡片间距\r\nconst gap = 20\r\n\r\n// 计算轨道偏移量，实现居中\r\nconst offset = computed(() => {\r\n  // 让当前选中的卡片居中，偏移量 = -(索引 * (卡片宽度+间距)) + (容器宽度 - 卡片宽度)/2\r\n  return -(currentIndex.value * (cardWidth + gap)) + (960 - cardWidth) / 2\r\n})\r\n\r\n// 当前选中的模式\r\nconst currentMode = computed(() => modeList.value[currentIndex.value])\r\n\r\n// 获取正确的图片路径（适配当前目录层级）\r\nfunction getImgUrl(imgName) {\r\n  // 你的组件在 views 文件夹，imgs 在 src 同级，所以用 ../imgs/\r\n  return new URL(`../imgs/${imgName}`, import.meta.url).href\r\n}\r\n\r\n// 上一个模式\r\nfunction prevMode() {\r\n  currentIndex.value = currentIndex.value === 0 ? modeList.value.length - 1 : currentIndex.value - 1\r\n}\r\n\r\n// 下一个模式\r\nfunction nextMode() {\r\n  currentIndex.value = currentIndex.value === modeList.value.length - 1 ? 0 : currentIndex.value + 1\r\n}\r\n\r\n// 点击卡片直接选中\r\nfunction selectMode(index) {\r\n  currentIndex.value = index\r\n}\r\n\r\n// 返回上一页\r\nfunction goBack() {\r\n  router.back()\r\n}\r\n\r\n// 进入当前选中的模式\r\nfunction enterCurrentMode() {\r\n  router.push(currentMode.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 页面容器 */\r\n.mode-page {\r\n  width: 100vw;\r\n  min-height: 100vh;\r\n  background: url(\"../imgs/Gamecover_1.png\") no-repeat center center;\r\n  background-size: cover;\r\n  background-color: #1a1a1a;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n}\r\n\r\n/* 返回按钮 */\r\n.back-bar {\r\n  align-self: flex-start;\r\n  font-size: 18px;\r\n  color: #fff;\r\n  cursor: pointer;\r\n  margin-bottom: 30px;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 标题 */\r\n.title {\r\n  text-align: center;\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 50px;\r\n  text-shadow: 0 2px 8px rgba(0,0,0,0.7);\r\n  letter-spacing: 4px;\r\n}\r\n\r\n/* 轮播容器 */\r\n.carousel-container {\r\n  position: relative;\r\n  width: 960px;\r\n  height: 480px;\r\n  overflow: hidden;\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n/* 滚动轨道 */\r\n.carousel-track {\r\n  display: flex;\r\n  gap: ${gap}px;\r\n  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);\r\n  position: absolute;\r\n  left: 0;\r\n}\r\n\r\n/* 模式卡片 */\r\n.mode-card {\r\n  width: ${cardWidth}px;\r\n  height: 420px;\r\n  flex-shrink: 0;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  opacity: 0.6;\r\n  transform: scale(0.9);\r\n  transition: all 0.4s ease;\r\n  cursor: pointer;\r\n}\r\n\r\n/* 选中的卡片（中间高亮放大） */\r\n.mode-card.active {\r\n  opacity: 1;\r\n  transform: scale(1.05);\r\n  z-index: 10;\r\n}\r\n\r\n/* 模式图片 */\r\n.mode-img {\r\n  width: 100%;\r\n  height: 360px;\r\n  object-fit: cover;\r\n  border-radius: 16px;\r\n  box-shadow: 0 8px 24px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 模式名称 */\r\n.mode-name {\r\n  margin-top: 16px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  text-shadow: 0 2px 6px rgba(0,0,0,0.8);\r\n  letter-spacing: 2px;\r\n}\r\n\r\n/* 箭头按钮 */\r\n.arrow-btn {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 56px;\r\n  height: 56px;\r\n  border-radius: 50%;\r\n  border: 2px solid rgba(255,255,255,0.8);\r\n  background: rgba(0,0,0,0.3);\r\n  backdrop-filter: blur(4px);\r\n  color: #fff;\r\n  font-size: 24px;\r\n  cursor: pointer;\r\n  z-index: 20;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.arrow-btn:hover {\r\n  background: rgba(192, 57, 43, 0.8);\r\n  border-color: #fff;\r\n  transform: translateY(-50%) scale(1.1);\r\n}\r\n\r\n.left-arrow {\r\n  left: 20px;\r\n}\r\n\r\n.right-arrow {\r\n  right: 20px;\r\n}\r\n\r\n.arrow-icon {\r\n  line-height: 1;\r\n}\r\n\r\n/* 进入按钮 */\r\n.enter-btn {\r\n  padding: 16px 60px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n  font-weight: bold;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 16px rgba(0,0,0,0.4);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.enter-btn:hover {\r\n  background: #e74c3c;\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 6px 20px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 响应式适配 */\r\n@media (max-width: 1024px) {\r\n  .carousel-container {\r\n    width: 720px;\r\n  }\r\n  .mode-card {\r\n    width: 260px;\r\n    height: 380px;\r\n  }\r\n  .mode-img {\r\n    height: 320px;\r\n  }\r\n}\r\n</style>"],"mappings":";;;;AA+CA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,QAAQ,YAAY;AA6BtC,MAAMC,SAAS,GAAG,GAAG;AACrB;AACA,MAAMC,GAAG,GAAG,EAAE;;AAEd;;;;;;;;IA/BA,MAAMC,MAAM,GAAGH,SAAS,CAAC,CAAC;;IAE1B;IACA,MAAMI,QAAQ,GAAGN,GAAG,CAAC,CACnB;MACEO,IAAI,EAAE,QAAQ;MACdC,GAAG,EAAE,aAAa;MAClBC,IAAI,EAAE,QAAQ;MACdC,IAAI,EAAE;IACR,CAAC,EACD;MACEH,IAAI,EAAE,QAAQ;MACdC,GAAG,EAAE,aAAa;MAClBC,IAAI,EAAE,cAAc;MACpBC,IAAI,EAAE;IACR,CAAC,EACD;MACEH,IAAI,EAAE,QAAQ;MACdC,GAAG,EAAE,aAAa;MAClBC,IAAI,EAAE,SAAS;MACfC,IAAI,EAAE;