  },\r\n  {\r\n    name: '现场交互模式',\r\n    img: interactiveImg,\r\n    path: '/interactive'\r\n  },\r\n  {\r\n    name: '线上绘卷模式',\r\n    img: scrollImg,\r\n    path: '/scroll'\r\n  },\r\n])\r\n\r\nconst current = ref(1)\r\n\r\nconst pos = computed(() => {\r\n  return -current.value * 33.33\r\n})\r\n\r\nconst currentItem = computed(() => modeList.value[current.value])\r\n\r\nfunction prev() {\r\n  current.value = current.value === 0 ? 2 : current.value - 1\r\n}\r\nfunction next() {\r\n  current.value = current.value === 2 ? 0 : current.value + 1\r\n}\r\nfunction select(i) {\r\n  current.value = i\r\n}\r\nfunction goBack() {\r\n  router.back()\r\n}\r\nfunction enter() {\r\n  router.push(currentItem.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background: url(../imgs/1（背景图）.png) no-repeat center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n\r\n.title {\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.carousel-container {\r\n  position: relative;\r\n  width: 100%;\r\n  max-width: 900px;\r\n  height: 460px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden;\r\n}\r\n\r\n.arrow {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 50px;\r\n  height: 50px;\r\n  background: rgba(255,255,255,0.2);\r\n  border: 2px solid #fff;\r\n  border-radius: 50%;\r\n  color: #fff;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  z-index: 10;\r\n}\r\n.arrow.left { left: 10px; }\r\n.arrow.right { right: 10px; }\r\n\r\n.carousel-track {\r\n  display: flex;\r\n  width: 300%;\r\n  transition: transform 0.5s ease;\r\n}\r\n\r\n.mode-card {\r\n  width: 33.333%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  opacity: 0.6;\r\n  transform: scale(0.9);\r\n  transition: all 0.4s ease;\r\n}\r\n.mode-card.active {\r\n  opacity: 1;\r\n  transform: scale(1);\r\n}\r\n\r\n.mode-img {\r\n  width: 280px;\r\n  height: 380px;\r\n  object-fit: cover;\r\n  border-radius: 16px;\r\n}\r\n\r\n.label {\r\n  margin-top: 12px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n}\r\n\r\n.enter-btn {\r\n  margin-top: 20px;\r\n  padding: 14px 50px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAW;;EAKfA,KAAK,EAAC;AAAoB;;;;EAYpBA,KAAK,EAAC;AAAO;;uBAjB1BC,mBAAA,CAyBM,OAzBNC,UAyBM,GAxBJC,mBAAA,CAAgD;IAA3CH,KAAK,EAAC,UAAU;IAAEI,OAAK,EAAEC,MAAA,CAAAC;KAAQ,MAAI,G,0BAE1CH,mBAAA,CAAuC;IAAnCH,KAAK,EAAC;EAAO,GAAC,kBAAgB,qBAElCG,mBAAA,CAiBM,OAjBNI,UAiBM,GAhBJJ,mBAAA,CAA6C;IAAxCH,KAAK,EAAC,YAAY;IAAEI,OAAK,EAAEC,MAAA,CAAAG;KAAM,GAAC,GAEvCL,mBAAA,CAWM;IAXDH,KAAK,EAAC,gBAAgB;IAAES,KAAK,EAAAC,eAAA;MAAAC,SAAA,gBAA6BN,MAAA,CAAAO,GAAG;IAAA;yBAChEX,mBAAA,CASMY,SAAA,QAAAC,WAAA,CANoBT,MAAA,CAAAU,QAAQ,GAAxBC,IAAI,EAAEC,KAAK;yBAHrBhB,mBAAA,CASM;MARJD,KAAK,EAAAkB,eAAA,EAAC,WAAW;QAAAC,MAAA,EACCd,MAAA,CAAAe,OAAO,KAAKH;MAAK;MAElCI,GAAG,EAAEJ,KAAK;MACVb,OAAK,EAAAkB,MAAA,IAAEjB,MAAA,CAAAkB,MAAM,CAACN,KAAK;QAEpBd,mBAAA,CAAwC;MAAnCH,KAAK,EAAC,UAAU;MAAEwB,GAAG,EAAER,IAAI,CAACS;yCACjCtB,mBAAA,CAAwC,OAAxCuB,UAAwC,EAAAC,gBAAA,CAAlBX,IAAI,CAACY,IAAI,iB;mDAInCzB,mBAAA,CAA8C;IAAzCH,KAAK,EAAC,aAAa;IAAEI,OAAK,EAAEC,MAAA,CAAAwB;KAAM,GAAC,E,GAG1C1B,mBAAA,CAA2E;IAAnEH,KAAK,EAAC,WAAW;IAAEI,OAAK,EAAEC,MAAA,CAAAyB;KAAO,KAAG,GAAAH,gBAAA,CAAGtB,MAAA,CAAA0B,WAAW,CAACH,IAAI,iB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}