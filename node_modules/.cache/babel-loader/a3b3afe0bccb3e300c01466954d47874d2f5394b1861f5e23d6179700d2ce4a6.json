{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport { ref, onMounted } from 'vue';\nimport { travelAPI } from '@/api';\n\n// 数据\n\nexport default {\n  __name: 'TravelPage',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const panoramas = ref([]);\n    const searchKeyword = ref('');\n\n    // 获取全景展示数据\n    const fetchPanoramas = async () => {\n      try {\n        const response = await travelAPI.getPanoramas();\n        if (response.success) {\n          panoramas.value = response.data;\n        }\n      } catch (error) {\n        console.error('获取全景数据失败:', error);\n      }\n    };\n\n    // 搜索功能\n    const handleSearch = async () => {\n      if (!searchKeyword.value.trim()) return;\n      try {\n        const response = await travelAPI.searchGuides(searchKeyword.value);\n        if (response.success && response.data.length > 0) {\n          // 滚动到全景展示区域\n          const panoramaSection = document.querySelector('.panorama-list');\n          if (panoramaSection) {\n            panoramaSection.scrollIntoView({\n              behavior: 'smooth',\n              block: 'start'\n            });\n          }\n          // 高亮匹配的项目\n          highlightMatchingItems(response.data);\n        } else {\n          alert('未找到相关结果');\n        }\n      } catch (error) {\n        console.error('搜索失败:', error);\n        alert('搜索失败，请稍后重试');\n      }\n    };\n\n    // 高亮匹配的导览项目\n    const highlightMatchingItems = results => {\n      // 移除之前的高亮\n      document.querySelectorAll('.pano-item.highlighted').forEach(el => {\n        el.classList.remove('highlighted');\n      });\n\n      // 添加高亮 - 简化版本，直接滚动到第一个匹配项\n      const elements = document.querySelectorAll('.pano-item');\n      if (elements.length > 0 && results.length > 0) {\n        elements[0].classList.add('highlighted');\n        elements[0].scrollIntoView({\n          behavior: 'smooth',\n          block: 'center'\n        });\n      }\n    };\n\n    // 方法\n    const openAR = () => {\n      alert('AR 实景导览功能暂未开放');\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      fetchPanoramas();\n    });\n    const __returned__ = {\n      panoramas,\n      searchKeyword,\n      fetchPanoramas,\n      handleSearch,\n      highlightMatchingItems,\n      openAR,\n      ref,\n      onMounted,\n      get travelAPI() {\n        return travelAPI;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","travelAPI","panoramas","searchKeyword","fetchPanoramas","response","getPanoramas","success","value","data","error","console","handleSearch","trim","searchGuides","length","panoramaSection","document","querySelector","scrollIntoView","behavior","block","highlightMatchingItems","alert","results","querySelectorAll","forEach","el","classList","remove","elements","add","openAR"],"sources":["F:/project/jiangjie-museum/src/views/TravelPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"travel-page\">\r\n    <!-- 头部区域 -->\r\n    <header class=\"header\">\r\n      <div class=\"user-avatar\">\r\n        <img\r\n          src=\"data:image/svg+xml;base64,\"\r\n          alt=\"用户\"\r\n        />\r\n      </div>\r\n      <div class=\"location\">当前位置<br /><span>自贡市, 沿滩区</span></div>\r\n      <div class=\"settings\">\r\n        <img src=\"../imgs/客服.png\" alt=\"设置\" class=\"setting-icon\" />\r\n      </div>\r\n    </header>\r\n\r\n    <!-- 搜索框 -->\r\n    <div class=\"search-bar\">\r\n      <input \r\n        type=\"text\" \r\n        v-model=\"searchKeyword\"\r\n        @keyup.enter=\"handleSearch\"\r\n        placeholder=\"搜索 江姐故里教育基地景区内部 或 自贡文旅\" \r\n        class=\"search-input\"\r\n      />\r\n      <button @click=\"handleSearch\" class=\"search-btn\">\r\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#666\" stroke-width=\"2\">\r\n          <circle cx=\"11\" cy=\"11\" r=\"8\" />\r\n          <path d=\"M21 21l-4.35-4.35\" />\r\n        </svg>\r\n      </button>\r\n    </div>\r\n\r\n    <!-- 广告横幅 -->\r\n    <div class=\"banner-card\">\r\n      <img\r\n        src=\"data:image/svg+xml;base64,\"\r\n        alt=\"大美自贡\"\r\n      />\r\n      <button class=\"banner-btn\">立即前往</button>\r\n    </div>\r\n\r\n    <!-- 导览区域标题 -->\r\n    <div class=\"section-title\">江姐故里园区导览</div>\r\n\r\n    <!-- 地图容器 -->\r\n    <div class=\"map-card\">\r\n      <img\r\n        src=\"data:image/svg+xml;base64,\"\r\n        alt=\"江姐故里地图\"\r\n      />\r\n      <button class=\"enter-guide-btn\">进入导览</button>\r\n    </div>\r\n\r\n    <!-- AR地图入口 -->\r\n    <div class=\"ar-entry\" @click=\"openAR\">\r\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2\">\r\n        <path d=\"M21 16V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8\" />\r\n        <path d=\"M3 10h18\" />\r\n        <path d=\"M16 21h-6\" />\r\n        <circle cx=\"12\" cy=\"12\" r=\"3\" />\r\n      </svg>\r\n      <span>AR实景导览</span>\r\n    </div>\r\n\r\n    <!-- 推荐内容（可跳转） -->\r\n    <div class=\"section-title\">推荐</div>\r\n    <div class=\"recommend-grid\">\r\n      <!-- 故里游玩路线规划 -->\r\n      <div class=\"card\">\r\n        <div class=\"card-img-placeholder\"></div>\r\n        <div class=\"card-title\">故里游玩<br />路线规划</div>\r\n        <div class=\"card-desc\">定制专属行程</div>\r\n      </div>\r\n\r\n      <!-- 现场公益讲解 -->\r\n      <router-link to=\"/travel/volunteer\" class=\"card\">\r\n        <div class=\"card-img-placeholder\"></div>\r\n        <div class=\"card-title\">现场公益<br />讲解</div>\r\n        <div class=\"card-desc\">专业志愿者服务</div>\r\n      </router-link>\r\n\r\n      <!-- 文创产品选购 -->\r\n      <router-link to=\"/travel/shop\" class=\"card\">\r\n        <div class=\"card-img-placeholder\"></div>\r\n        <div class=\"card-title\">文创产品<br />选购</div>\r\n        <div class=\"card-desc\">红色文化纪念品</div>\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- 全景展示 -->\r\n    <div class=\"section-title\">全景展示</div>\r\n    <div class=\"panorama-list\">\r\n      <div class=\"pano-item\" v-for=\"panorama in panoramas\" :key=\"panorama._id\">\r\n        <img :src=\"panorama.image\" :alt=\"panorama.title\" class=\"pano-img\" />\r\n        <div class=\"pano-name\">{{ panorama.title }}</div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 底部导航 -->\r\n    <div class=\"bottom-nav\">\r\n      <div class=\"nav-item\">\r\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#999\" stroke-width=\"2\">\r\n          <path d=\"M12 2L2 7l10 5 10-5-10-5z\" />\r\n          <path d=\"M2 17l10 5 10-5\" />\r\n          <path d=\"M2 12l10 5 10-5\" />\r\n        </svg>\r\n        <span>首页</span>\r\n      </div>\r\n      <div class=\"nav-item active\">\r\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c43e3a\" stroke-width=\"2\">\r\n          <path d=\"M12 2L2 7l10 5 10-5-10-5z\" />\r\n          <path d=\"M2 17l10 5 10-5\" />\r\n          <path d=\"M2 12l10 5 10-5\" />\r\n        </svg>\r\n        <span>导览</span>\r\n      </div>\r\n      <div class=\"nav-item\">\r\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#999\" stroke-width=\"2\">\r\n          <path d=\"M12 2L2 7l10 5 10-5-10-5z\" />\r\n          <path d=\"M2 17l10 5 10-5\" />\r\n          <path d=\"M2 12l10 5 10-5\" />\r\n        </svg>\r\n        <span>活动</span>\r\n      </div>\r\n      <div class=\"nav-item\">\r\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#999\" stroke-width=\"2\">\r\n          <path d=\"M12 2L2 7l10 5 10-5-10-5z\" />\r\n          <path d=\"M2 17l10 5 10-5\" />\r\n          <path d=\"M2 12l10 5 10-5\" />\r\n        </svg>\r\n        <span>我的</span>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { travelAPI } from '@/api'\r\n\r\n// 数据\r\nconst panoramas = ref([])\r\nconst searchKeyword = ref('')\r\n\r\n// 获取全景展示数据\r\nconst fetchPanoramas = async () => {\r\n  try {\r\n    const response = await travelAPI.getPanoramas()\r\n    if (response.success) {\r\n      panoramas.value = response.data\r\n    }\r\n  } catch (error) {\r\n    console.error('获取全景数据失败:', error)\r\n  }\r\n}\r\n\r\n// 搜索功能\r\nconst handleSearch = async () => {\r\n  if (!searchKeyword.value.trim()) return\r\n  \r\n  try {\r\n    const response = await travelAPI.searchGuides(searchKeyword.value)\r\n    if (response.success && response.data.length > 0) {\r\n      // 滚动到全景展示区域\r\n      const panoramaSection = document.querySelector('.panorama-list')\r\n      if (panoramaSection) {\r\n        panoramaSection.scrollIntoView({ behavior: 'smooth', block: 'start' })\r\n      }\r\n      // 高亮匹配的项目\r\n      highlightMatchingItems(response.data)\r\n    } else {\r\n      alert('未找到相关结果')\r\n    }\r\n  } catch (error) {\r\n    console.error('搜索失败:', error)\r\n    alert('搜索失败，请稍后重试')\r\n  }\r\n}\r\n\r\n// 高亮匹配的导览项目\r\nconst highlightMatchingItems = (results) => {\r\n  // 移除之前的高亮\r\n  document.querySelectorAll('.pano-item.highlighted').forEach(el => {\r\n    el.classList.remove('highlighted')\r\n  })\r\n  \r\n  // 添加高亮 - 简化版本，直接滚动到第一个匹配项\r\n  const elements = document.querySelectorAll('.pano-item')\r\n  if (elements.length > 0 && results.length > 0) {\r\n    elements[0].classList.add('highlighted')\r\n    elements[0].scrollIntoView({ behavior: 'smooth', block: 'center' })\r\n  }\r\n}\r\n\r\n// 方法\r\nconst openAR = () => {\r\n  alert('AR 实景导览功能暂未开放')\r\n}\r\n\r\n// 组件挂载时获取数据\r\nonMounted(() => {\r\n  fetchPanoramas()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n/* 继承 MinePage 的全局风格 */\r\n.travel-page {\r\n  min-height: 100vh;\r\n  background-color: #f5f0e6; /* ← 关键：统一背景色 */\r\n  font-family: 'Microsoft Yahei', sans-serif;\r\n  padding: 16px;\r\n  padding-bottom: calc(80px + env(safe-area-inset-bottom));\r\n}\r\n\r\n/* === 头部 === */\r\n.header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: 16px;\r\n}\r\n.user-avatar img {\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n}\r\n.location {\r\n  font-size: 14px;\r\n  text-align: center;\r\n  color: #333;\r\n}\r\n.location span {\r\n  font-size: 12px;\r\n  color: #666;\r\n}\r\n.setting-icon {\r\n  width: 24px;\r\n  height: 24px;\r\n  object-fit: contain;\r\n}\r\n\r\n/* === 搜索框 === */\r\n.search-bar {\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n  background: rgba(255, 255, 255, 0.9);\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);\r\n  padding: 0 16px;\r\n}\r\n\r\n.search-input {\r\n  flex: 1;\r\n  height: 40px;\r\n  border: none;\r\n  outline: none;\r\n  font-size: 14px;\r\n  background: transparent;\r\n  color: #333;\r\n}\r\n\r\n.search-input::placeholder {\r\n  color: #999;\r\n}\r\n\r\n.search-btn {\r\n  width: 36px;\r\n  height: 36px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: transparent;\r\n  border: none;\r\n  cursor: pointer;\r\n  border-radius: 50%;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.search-btn:hover {\r\n  background: rgba(0, 0, 0, 0.05);\r\n}\r\n\r\n/* 高亮样式 */\r\n.pano-item.highlighted {\r\n  animation: highlight-pulse 1.5s ease-in-out 3;\r\n}\r\n\r\n@keyframes highlight-pulse {\r\n  0%, 100% {\r\n    transform: scale(1);\r\n    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\r\n  }\r\n  50% {\r\n    transform: scale(1.02);\r\n    box-shadow: 0 4px 16px rgba(255, 165, 0, 0.4);\r\n  }\r\n}\r\n\r\n/* === 通用卡片样式（对齐 MinePage）=== */\r\n.banner-card,\r\n.map-card {\r\n  position: relative;\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n  margin-bottom: 20px;\r\n  background: rgba(255, 255, 255, 0.7);\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\r\n}\r\n.banner-card img,\r\n.map-card img {\r\n  width: 100%;\r\n  display: block;\r\n  height: auto;\r\n}\r\n\r\n/* === 按钮 === */\r\n.banner-btn,\r\n.enter-guide-btn {\r\n  position: absolute;\r\n  background: #c43e3a; /* ← 使用 MinePage 的主色 */\r\n  color: white;\r\n  border: none;\r\n  border-radius: 20px;\r\n  font-weight: bold;\r\n  z-index: 2;\r\n}\r\n.banner-btn {\r\n  bottom: 10px;\r\n  right: 10px;\r\n  padding: 4px 12px;\r\n  font-size: 12px;\r\n}\r\n.enter-guide-btn {\r\n  bottom: 16px;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  padding: 6px 20px;\r\n  font-size: 14px;\r\n}\r\n\r\n/* === 区块标题（对齐 MinePage 的 tab 风格）=== */\r\n.section-title {\r\n  font-size: 16px;\r\n  font-weight: bold;\r\n  color: #333;\r\n  margin: 20px 0 12px;\r\n  padding-left: 4px;\r\n  border-left: 3px solid #c43e3a; /* ← 左侧色条，呼应 MinePage 主色 */\r\n}\r\n\r\n/* === AR入口 === */\r\n.ar-entry {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 8px;\r\n  background: #c43e3a;\r\n  color: white;\r\n  padding: 10px;\r\n  border-radius: 12px;\r\n  margin-bottom: 20px;\r\n  cursor: pointer;\r\n  font-size: 14px;\r\n}\r\n.ar-entry svg {\r\n  width: 20px;\r\n  height: 20px;\r\n}\r\n\r\n/* === 推荐卡片（支持 router-link）=== */\r\n.recommend-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));\r\n  gap: 16px;\r\n  margin-bottom: 20px;\r\n}\r\n.card {\r\n  background: rgba(255, 255, 255, 0.8);\r\n  border-radius: 12px;\r\n  padding: 12px;\r\n  text-align: center;\r\n  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);\r\n  text-decoration: none;\r\n  color: inherit;\r\n  transition: transform 0.2s;\r\n}\r\n.card:hover {\r\n  transform: translateY(-2px);\r\n}\r\n.card-img-placeholder {\r\n  width: 100%;\r\n  height: 80px;\r\n  background: #eee;\r\n  border-radius: 8px;\r\n  margin-bottom: 8px;\r\n}\r\n.card-title {\r\n  font-weight: bold;\r\n  font-size: 14px;\r\n  margin-bottom: 4px;\r\n  color: #333;\r\n  line-height: 1.3;\r\n}\r\n.card-desc {\r\n  font-size: 12px;\r\n  color: #888;\r\n}\r\n\r\n/* === 全景展示 === */\r\n.panorama-list {\r\n  display: flex;\r\n  gap: 16px;\r\n  overflow-x: auto;\r\n  padding-bottom: 10px;\r\n  -webkit-overflow-scrolling: touch;\r\n}\r\n.pano-item {\r\n  flex: 0 0 auto;\r\n  text-align: center;\r\n  min-width: 90px;\r\n}\r\n.pano-img {\r\n  width: 90px;\r\n  height: 90px;\r\n  object-fit: cover;\r\n  border-radius: 10px;\r\n  margin-bottom: 8px;\r\n}\r\n.pano-name {\r\n  font-size: 13px;\r\n  color: #333;\r\n}\r\n\r\n/* === 底部导航 === */\r\n.bottom-nav {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  padding: 12px;\r\n  background: #f5f0e6;\r\n  border-top: 1px solid #ddd;\r\n  position: fixed;\r\n  bottom: 0;\r\n  left: 0;\r\n  right: 0;\r\n  z-index: 10;\r\n  border-radius: 20px 20px 0 0;\r\n}\r\n.nav-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: 4px;\r\n  color: #999;\r\n  font-size: 12px;\r\n  cursor: pointer;\r\n}\r\n.nav-item.active {\r\n  color: #c43e3a;\r\n}\r\n.nav-item svg {\r\n  width: 20px;\r\n  height: 20px;\r\n}\r\n</style>"],"mappings":";;AA0IA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,OAAO;;AAEjC;;;;;;;;IACA,MAAMC,SAAS,GAAGH,GAAG,CAAC,EAAE,CAAC;IACzB,MAAMI,aAAa,GAAGJ,GAAG,CAAC,EAAE,CAAC;;IAE7B;IACA,MAAMK,cAAc,GAAG,MAAAA,CAAA,KAAY;MACjC,IAAI;QACF,MAAMC,QAAQ,GAAG,MAAMJ,SAAS,CAACK,YAAY,CAAC,CAAC;QAC/C,IAAID,QAAQ,CAACE,OAAO,EAAE;UACpBL,SAAS,CAACM,KAAK,GAAGH,QAAQ,CAACI,IAAI;QACjC;MACF,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK,CAAC;MACnC;IACF,CAAC;;IAED;IACA,MAAME,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/B,IAAI,CAACT,aAAa,CAACK,KAAK,CAACK,IAAI,CAAC,CAAC,EAAE;MAEjC,IAAI;QACF,MAAMR,QAAQ,GAAG,MAAMJ,SAAS,CAACa,YAAY,CAACX,aAAa,CAACK,KAAK,CAAC;QAClE,IAAIH,QAAQ,CAACE,OAAO,IAAIF,QAAQ,CAACI,IAAI,CAACM,MAAM,GAAG,CAAC,EAAE;UAChD;UACA,MAAMC,eAAe,GAAGC,QAAQ,CAACC,aAAa,CAAC,gBAAgB,CAAC;UAChE,IAAIF,eAAe,EAAE;YACnBA,eAAe,CAACG,cAAc,CAAC;cAAEC,QAAQ,EAAE,QAAQ;cAAEC,KAAK,EAAE;YAAQ,CAAC,CAAC;UACxE;UACA;UAC