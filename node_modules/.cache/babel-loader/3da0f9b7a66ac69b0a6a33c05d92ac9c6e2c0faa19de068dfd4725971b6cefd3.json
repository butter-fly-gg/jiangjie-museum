{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { showToast } from 'vant';\n\n// 路由实例\n\nexport default {\n  __name: 'ModeSelectView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 👉 核心修改：删掉 lang=\"ts\"，纯 JS 写法\n    const router = useRouter();\n\n    // 江姐博物馆模式配置（对应你的项目路由）\n    const modeList = ref([{\n      name: '故事模式',\n      desc: '沉浸式讲述江姐革命事迹，适合深度参观',\n      path: '/story'\n    }, {\n      name: '互动模式',\n      desc: '趣味互动问答，解锁红色文化知识',\n      path: '/interactive'\n    }, {\n      name: '卷轴模式',\n      desc: '全景长卷浏览，一览江姐生平历程',\n      path: '/scroll'\n    }]);\n\n    // 当前选中索引\n    const currentIndex = ref(0);\n\n    // 计算当前选中模式名称\n    const currentModeName = computed(() => {\n      return modeList.value[currentIndex.value]?.name || '模式';\n    });\n\n    // 返回首页\n    const goBack = () => {\n      router.back();\n    };\n\n    // 选择模式\n    const selectMode = index => {\n      // 👉 去掉 TS 的类型声明 : number\n      currentIndex.value = index;\n    };\n\n    // 进入模式（路由跳转）\n    const enterMode = () => {\n      const targetMode = modeList.value[currentIndex.value];\n      showToast(`正在进入${targetMode.name}...`);\n      // 跳转到对应页面\n      router.push(targetMode.path);\n    };\n    const __returned__ = {\n      router,\n      modeList,\n      currentIndex,\n      currentModeName,\n      goBack,\n      selectMode,\n      enterMode,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      },\n      get showToast() {\n        return showToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","showToast","router","modeList","name","desc","path","currentIndex","currentModeName","value","goBack","back","selectMode","index","enterMode","targetMode","push"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-select-container\">\r\n    <!-- 顶部返回栏 -->\r\n    <div class=\"header\">\r\n      <van-icon name=\"arrow-left\" class=\"back-icon\" @click=\"goBack\" />\r\n      <span class=\"title\">选择参观模式</span>\r\n    </div>\r\n\r\n    <!-- 模式选择卡片 -->\r\n    <div class=\"mode-list\">\r\n      <div\r\n        class=\"mode-card\"\r\n        :class=\"{ active: currentIndex === index }\"\r\n        v-for=\"(item, index) in modeList\"\r\n        :key=\"index\"\r\n        @click=\"selectMode(index)\"\r\n      >\r\n        <div class=\"mode-title\">{{ item.name }}</div>\r\n        <div class=\"mode-desc\">{{ item.desc }}</div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 底部确认按钮 -->\r\n    <div class=\"footer\">\r\n      <van-button type=\"primary\" block round @click=\"enterMode\">\r\n        进入{{ currentModeName }}\r\n      </van-button>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\n// 👉 核心修改：删掉 lang=\"ts\"，纯 JS 写法\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\nimport { showToast } from 'vant'\r\n\r\n// 路由实例\r\nconst router = useRouter()\r\n\r\n// 江姐博物馆模式配置（对应你的项目路由）\r\nconst modeList = ref([\r\n  {\r\n    name: '故事模式',\r\n    desc: '沉浸式讲述江姐革命事迹，适合深度参观',\r\n    path: '/story'\r\n  },\r\n  {\r\n    name: '互动模式',\r\n    desc: '趣味互动问答，解锁红色文化知识',\r\n    path: '/interactive'\r\n  },\r\n  {\r\n    name: '卷轴模式',\r\n    desc: '全景长卷浏览，一览江姐生平历程',\r\n    path: '/scroll'\r\n  }\r\n])\r\n\r\n// 当前选中索引\r\nconst currentIndex = ref(0)\r\n\r\n// 计算当前选中模式名称\r\nconst currentModeName = computed(() => {\r\n  return modeList.value[currentIndex.value]?.name || '模式'\r\n})\r\n\r\n// 返回首页\r\nconst goBack = () => {\r\n  router.back()\r\n}\r\n\r\n// 选择模式\r\nconst selectMode = (index) => {\r\n  // 👉 去掉 TS 的类型声明 : number\r\n  currentIndex.value = index\r\n}\r\n\r\n// 进入模式（路由跳转）\r\nconst enterMode = () => {\r\n  const targetMode = modeList.value[currentIndex.value]\r\n  showToast(`正在进入${targetMode.name}...`)\r\n  // 跳转到对应页面\r\n  router.push(targetMode.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-select-container {\r\n  width: 100%;\r\n  min-height: 100vh;\r\n  background: linear-gradient(135deg, #8B0000 0%, #B22222 100%);\r\n  display: flex;\r\n  flex-direction: column;\r\n  padding: 0 16px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n/* 头部样式 */\r\n.header {\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 16px 0;\r\n  color: #fff;\r\n}\r\n.back-icon {\r\n  font-size: 20px;\r\n  cursor: pointer;\r\n}\r\n.title {\r\n  flex: 1;\r\n  text-align: center;\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  margin-right: 20px;\r\n}\r\n\r\n/* 模式列表 */\r\n.mode-list {\r\n  flex: 1;\r\n  padding: 20px 0;\r\n}\r\n.mode-card {\r\n  background: rgba(255, 255, 255, 0.95);\r\n  border-radius: 12px;\r\n  padding: 24px;\r\n  margin-bottom: 16px;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n  border: 2px solid transparent;\r\n}\r\n.mode-card.active {\r\n  border-color: #DC143C;\r\n  background: rgba(255, 240, 240, 0.95);\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(220, 20, 60, 0.2);\r\n}\r\n.mode-title {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #8B0000;\r\n  margin-bottom: 8px;\r\n}\r\n.mode-desc {\r\n  font-size: 14px;\r\n  color: #666;\r\n  line-height: 1.5;\r\n}\r\n\r\n/* 底部按钮 */\r\n.footer {\r\n  padding: 16px 0 24px;\r\n}\r\n</style>"],"mappings":";AAiCA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,SAAS,QAAQ,MAAM;;AAEhC;;;;;;;;;IALA;IAMA,MAAMC,MAAM,GAAGF,SAAS,CAAC,CAAC;;IAE1B;IACA,MAAMG,QAAQ,GAAGL,GAAG,CAAC,CACnB;MACEM,IAAI,EAAE,MAAM;MACZC,IAAI,EAAE,oBAAoB;MAC1BC,IAAI,EAAE;IACR,CAAC,EACD;MACEF,IAAI,EAAE,MAAM;MACZC,IAAI,EAAE,iBAAiB;MACvBC,IAAI,EAAE;IACR,CAAC,EACD;MACEF,IAAI,EAAE,MAAM;MACZC,IAAI,EAAE,iBAAiB;MACvBC,IAAI,EAAE;IACR,CAAC,CACF,CAAC;;IAEF;IACA,MAAMC,YAAY,GAAGT,GAAG,CAAC,CAAC,CAAC;;IAE3B;IACA,MAAMU,eAA