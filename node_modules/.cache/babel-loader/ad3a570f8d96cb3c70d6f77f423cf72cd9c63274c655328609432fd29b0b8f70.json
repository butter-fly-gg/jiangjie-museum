ff\",\n    \"stroke-width\": \"2\"\n  }, [_createElementVNode(\"path\", {\n    d: \"M15 19l-7-7 7-7\"\n  })], -1 /* CACHED */)]))]), _cache[1] || (_cache[1] = _createStaticVNode(\"<div class=\\\"title\\\" data-v-3a29caea>文创精选</div><div class=\\\"search-box\\\" data-v-3a29caea><svg xmlns=\\\"http://www.w3.org/2000/svg\\\" width=\\\"18\\\" height=\\\"18\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"#666\\\" stroke-width=\\\"2\\\" data-v-3a29caea><circle cx=\\\"11\\\" cy=\\\"11\\\" r=\\\"8\\\" data-v-3a29caea></circle><line x1=\\\"21\\\" y1=\\\"21\\\" x2=\\\"16.65\\\" y2=\\\"16.65\\\" data-v-3a29caea></line></svg><input type=\\\"text\\\" placeholder=\\\"搜索好物\\\" data-v-3a29caea></div>\", 2))]), _createCommentVNode(\" 2. 横幅广告 (仿参考图：大图背景 + 大字折扣) \"), _cache[6] || (_cache[6] = _createStaticVNode(\"<div class=\\\"banner\\\" data-v-3a29caea><!-- 建议替换为真实的古建筑背景图 --><img src=\\\"https://images.unsplash.com/photo-1599571234909-29ed5d1321d6?q=80&amp;w=2070&amp;auto=format&amp;fit=crop\\\" alt=\\\"全场限时折扣\\\" class=\\\"banner-img\\\" data-v-3a29caea><div class=\\\"banner-overlay\\\" data-v-3a29caea><div class=\\\"banner-subtitle\\\" data-v-3a29caea>THE EXPLORATION OF JIANGJIE HOME</div><h1 class=\\\"banner-main-text\\\" data-v-3a29caea>全场限时折扣中</h1><div class=\\\"banner-discount\\\" data-v-3a29caea><span class=\\\"num\\\" data-v-3a29caea>5/1</span><span class=\\\"symbol\\\" data-v-3a29caea>-</span><span class=\\\"num\\\" data-v-3a29caea>5/5</span></div></div></div>\", 1)), _createCommentVNode(\" 3. 热门文创 (核心修改：错落网格布局) \"), _createElementVNode(\"div\", _hoisted_2, [_cache[4] || (_cache[4] = _createElementVNode(\"div\", {\n    class: \"section-header\"\n  }, [_createElementVNode(\"h2\", {\n    class: \"section-title\"\n  }, \"热门文创\"), _createElementVNode(\"div\", {\n    class: \"more-link\"\n  }, [_createTextVNode(\" 查看更多 \"), _createElementVNode(\"span\", {\n    class: \"arrow\"\n  }, \"→\")])], -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_3, [_createCommentVNode(\" 循环渲染，通过 CSS 控制第一个元素占两行 \"), (_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.hotItems, (item, index) => {\n    return _openBlock(), _createBlock(_resolveDynamicComponent(item.link ? 'router-link' : 'div'), {\n      key: index,\n      to: item.link || null,\n      class: _normalizeClass([\"hot-card\", {\n        'card-large': index === 0\n      }])\n    }, {\n      default: _withCtx(() => [_createCommentVNode(\" 排名标签 \"), _createElementVNode(\"div\", _hoisted_4, _toDisplayString(item.rank), 1 /* TEXT */), _createCommentVNode(\" 顶部英文标签 \"), _createElementVNode(\"div\", _hoisted_5, _toDisplayString(item.engLabel), 1 /* TEXT */), _createCommentVNode(\" 商品图片 \"), _createElementVNode(\"div\", _hoisted_6, [_createElementVNode(\"img\", {\n        src: item.img,\n        alt: item.title,\n        class: \"card-img\"\n      }, null, 8 /* PROPS */, _hoisted_7)]), _createCommentVNode(\" 底部信息区 \"), _createElementVNode(\"div\", _hoisted_8, [_createElementVNode(\"div\", _hoisted_9, [_createElementVNode(\"h3\", _hoisted_10, _toDisplayString(item.title), 1 /* TEXT */), _createElementVNode(\"div\", _hoisted_11, [_cache[2] || (_cache[2] = _createElementVNode(\"span\", {\n        class: \"currency\"\n      }, \"¥\", -1 /* CACHED */)), _createElementVNode(\"span\", _hoisted_12, _toDisplayString(item.price), 1 /* TEXT */)])]), _createCommentVNode(\" 购买按钮 \"), _createElementVNode(\"button\", {\n        class: \"add-cart-btn\",\n        onClick: _withModifiers($event => $setup.addToCart(item), [\"stop\"])\n      }, [...(_cache[3] || (_cache[3] = [_createElementVNode(\"svg\", {\n        xmlns: \"http://www.w3.org/2000/svg\",\n        width: \"16\",\n        height: \"16\",\n        viewBox: \"0 0 24 24\",\n        fill: \"none\",\n        stroke: \"currentColor\",\n        \"stroke-width\": \"2\"\n      }, [_createElementVNode(\"line\", {\n        x1: \"12\",\n        y1: \"5\",\n        x2: \"12\",\n        y2: \"19\"\n      }), _createElementVNode(\"line\", {\n        x1: \"5\",\n        y1: \"12\",\n        x2: \"19\",\n        y2: \"12\"\n      })], -1 /* CACHED */)]))], 8 /* PROPS */, _hoisted_13)])]),\n      _: 2 /* DYNAMIC */\n    }, 1032 /* PROPS, DYNAMIC_SLOTS */, [\"to\", \"class\"]);\n  }), 128 /* KEYED_FRAGMENT */))])]), _createCommentVNode(\" 4. 江姐故里系列 (保持常规网格) \"), _createElementVNode(\"div\", _hoisted_14, [_cache[5] || (_cache[5] = _createElementVNode(\"div\", {\n    class: \"section-header\"\n  }, [_createElementVNode(\"h2\", {\n    class: \"section-title\"\n  }, \"江姐故里系列\"), _createElementVNode(\"div\", {\n    class: \"more-link\"\n  }, [_createTextVNode(\" 查看更多 \"), _createElementVNode(\"span\", {\n    class: \"arrow\"\n  }, \"→\")])], -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_15, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.seriesItems, (item, index) => {\n    return _openBlock(), _createElementBlock(\"div\", {\n      class: \"series-card\",\n      key: index\n    }, [_createElementVNode(\"img\", {\n      src: item.img,\n      alt: \"\",\n      class: \"series-img\"\n    }, null, 8 /* PROPS */, _hoisted_16), _createElementVNode(\"div\", _hoisted_17, _toDisplayString(item.title), 1 /* TEXT */), _createElementVNode(\"div\", _hoisted_18, \"¥\" + _toDisplayString(item.price), 1 /* TEXT */), _createElementVNode(\"button\", {\n      class: \"series-add-btn\",\n      onClick: $event => $setup.addToCart(item)\n    }, \"+\", 8 /* PROPS */, _hoisted_19)]);\n  }), 128 /* KEYED_FRAGMENT */))])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createCommentVNode","_createElementVNode","onClick","$setup","goBack","xmlns","width","height","viewBox","fill","stroke","d","_hoisted_2","_hoisted_3","_Fragment","_renderList","hotItems","item","index","_createBlock","_resolveDynamicComponent","link","to","_normalizeClass","_hoisted_4","_toDisplayString","rank","_hoisted_5","engLabel","_hoisted_6","src","img","alt","title","_hoisted_8","_hoisted_9","_hoisted_10","_hoisted_11","_hoisted_12","price","_withModifiers","$event","addToCart","x1","y1","x2","y2","_hoisted_14","_hoisted_15","seriesItems","key","_hoisted_17","_hoisted_18","_hoisted_19"],"sources":["F:\\project\\jiangjie-museum\\src\\views\\TravelShop.vue"],"sourcesContent":["<template>\r\n  <div class=\"travel-shop-page\">\r\n    <!-- 1. 顶部导航 (悬浮透明风格) -->\r\n    <header class=\"header\">\r\n      <div class=\"back-btn\" @click=\"goBack\">\r\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\">\r\n          <path d=\"M15 19l-7-7 7-7\"/>\r\n        </svg>\r\n      </div>\r\n      <div class=\"title\">文创精选</div>\r\n      <div class=\"search-box\">\r\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#666\" stroke-width=\"2\">\r\n          <circle cx=\"11\" cy=\"11\" r=\"8\"></circle>\r\n          <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"></line>\r\n        </svg>\r\n        <input type=\"text\" placeholder=\"搜索好物\" />\r\n      </div>\r\n    </header>\r\n\r\n    <!-- 2. 横幅广告 (仿参考图：大图背景 + 大字折扣) -->\r\n    <div class=\"banner\">\r\n      <!-- 建议替换为真实的古建筑背景图 -->\r\n      <img \r\n        src=\"https://images.unsplash.com/photo-1599571234909-29ed5d1321d6?q=80&w=2070&auto=format&fit=crop\" \r\n        alt=\"全场限时折扣\" \r\n        class=\"banner-img\"\r\n      />\r\n      <div class=\"banner-overlay\">\r\n        <div class=\"banner-subtitle\">THE EXPLORATION OF JIANGJIE HOME</div>\r\n        <h1 class=\"banner-main-text\">全场限时折扣中</h1>\r\n        <div class=\"banner-discount\">\r\n          <span class=\"num\">5/1</span>\r\n          <span class=\"symbol\">-</span>\r\n          <span class=\"num\">5/5</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 3. 热门文创 (核心修改：错落网格布局) -->\r\n    <div class=\"section\">\r\n      <div class=\"section-header\">\r\n        <h2 class=\"section-title\">热门文创</h2>\r\n        <div class=\"more-link\">\r\n          查看更多 <span class=\"arrow\">→</span>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"hot-grid\">\r\n        <!-- 循环渲染，通过 CSS 控制第一个元素占两行 -->\r\n        <template v-for=\"(item, index) in hotItems\" :key=\"index\">\r\n          \r\n          <component \r\n            :is=\"item.link ? 'router-link' : 'div'\" \r\n            :to=\"item.link || null\"\r\n            class=\"hot-card\"\r\n            :class=\"{ 'card-large': index === 0 }\" \r\n          >\r\n            <!-- 排名标签 -->\r\n            <div class=\"rank-tag\">{{ item.rank }}</div>\r\n            \r\n            <!-- 顶部英文标签 -->\r\n            <div class=\"eng-label\">{{ item.engLabel }}</div>\r\n\r\n            <!-- 商品图片 -->\r\n            <div class=\"img-wrapper\">\r\n              <img :src=\"item.img\" :alt=\"item.title\" class=\"card-img\" />\r\n            </div>\r\n\r\n            <!-- 底部信息区 -->\r\n            <div class=\"card-info\">\r\n              <div class=\"info-top\">\r\n                <h3 class=\"card-title\">{{ item.title }}</h3>\r\n                <div class=\"price-box\">\r\n                  <span class=\"currency\">¥</span>\r\n                  <span class=\"price-num\">{{ item.price }}</span>\r\n                </div>\r\n              </div>\r\n              \r\n              <!-- 购买按钮 -->\r\n              <button class=\"add-cart-btn\" @click.stop=\"addToCart(item)\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\r\n                  <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line>\r\n                  <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line>\r\n                </svg>\r\n              </button>\r\n            </div>\r\n          </component>\r\n\r\n        </template>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 4. 江姐故里系列 (保持常规网格) -->\r\n    <div class=\"section\">\r\n      <div class=\"section-header\">\r\n        <h2 class=\"section-title\">江姐故里系列</h2>\r\n        <div class=\"more-link\">\r\n          查看更多 <span class=\"arrow\">→</span>\r\n        </div>\r\n      </div>\r\n      <div class=\"series-grid\">\r\n        <div class=\"series-card\" v-for=\"(item, index) in seriesItems\" :key=\"index\">\r\n          <img :src=\"item.img\" alt=\"\" class=\"series-img\" />\r\n          <div class=\"series-title\">{{ item.title }}</div>\r\n          <div class=\"series-price\">¥{{ item.price }}</div>\r\n          <button class=\"series-add-btn\" @click=\"addToCart(item)\">+</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router' \r\n// import { shopAPI } from '@/api' // 实际项目中取消注释\r\n\r\nconst router = useRouter()\r\n\r\n// 数据定义\r\nconst hotItems = ref([])\r\nconst seriesItems = ref([])\r\n\r\nconst goBack = () => {\r\n  router.push('/travel')\r\n}\r\n\r\nconst addToCart = (item) => {\r\n  console.log('加入购物:', item.title)\r\n  alert(`已将 \"${item.title}\" 加入购物车`)\r\n}\r\n\r\n// 获取热门商品 (模拟参考图数据)\r\nconst fetchHotProducts = async () => {\r\n  // 实际项目中取消注释 API 调用\r\n  /*\r\n  try {\r\n    const response = await shopAPI.getHotProducts()\r\n    if (response.success) { ... }\r\n  } catch ...\r\n  */\r\n\r\n  // 模拟参考图中的具体数据\r\n  hotItems.value = [\r\n    {\r\n      rank: 'NO.1',\r\n      engLabel: 'AR ILLUSTRATION TEENAGERS\\' ARTBOOK',\r\n      title: '《永远的江姐》\\n青少年 AR 研学绘本',\r\n      price: 29,\r\n      img: 'https://placehold.co/400x500/ebe6df/333?text=Book+Cover', // 替换为真实绘本图\r\n      link: '/travel/shop/detail'\r\n    },\r\n    {\r\n      rank: 'NO.2',\r\n      engLabel: 'SNOWY STAMP',\r\n      title: '红梅傲雪公交印章',\r\n      price: 10,\r\n      img: 'https://placehold.co/400x400/ebe6df/333?text=Stamp', // 替换为真实印章图\r\n      link: null\r\n    },\r\n    {\r\n      rank: 'NO.3',\r\n      engLabel: 'SUPERNOVA WINE',\r\n      title: '故居传承高粱酒',\r\n      price: 399,\r\n      img: 'https://placehold.co/400x400/ebe6df/333?text=Wine', // 替换为真实酒瓶图\r\n      link: '/travel/shop/detail'\r\n    }\r\n  ]\r\n}\r\n\r\n// 获取系列商品\r\nconst fetchSeriesProducts = async () => {\r\n  seriesItems.value = [\r\n    { title: '【故里国庆非遗漆扇】', price: 29, img: 'https://placehold.co/300x300/ebe6df/333?text=Fan' },\r\n    { title: '【经络疏通养生锤】', price: 30, img: 'https://placehold.co/300x300/ebe6df/333?text=Hammer' },\r\n    { title: '【江姐故事明信片】', price: 15, img: 'https://placehold.co/300x300/ebe6df/333?text=Card' },\r\n    { title: '【红色记忆书签】', price: 9.9, img: 'https://placehold.co/300x300/ebe6df/333?text=Bookmark' }\r\n  ]\r\n}\r\n\r\nonMounted(() => {\r\n  fetchHotProducts()\r\n  fetchSeriesProducts()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n/* 全局变量 */\r\n.travel-shop-page {\r\n  min-height: 100vh;\r\n  background-color: #f9f7f2; /* 米白色背景，更有文化感 */\r\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\r\n  padding-bottom: 80px;\r\n}\r\n\r\n/* === 1. 头部 (悬浮透明) === */\r\n.header {\r\n  position: absolute; /* 悬浮在 Banner 上 */\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  z-index: 10;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  padding: 16px;\r\n  background: linear-gradient(to bottom, rgba(0,0,0,0.4), transparent);\r\n}\r\n.back-btn {\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n  background: rgba(255, 255, 255, 0.2);\r\n  backdrop-filter: blur(4px);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  transition: background 0.2s;\r\n}\r\n.back-btn:hover { background: rgba(255, 255, 255, 0.4); }\r\n.title {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #fff;\r\n  text-shadow: 0 1px 2px rgba(0,0,0,0.3);\r\n  flex: 1;\r\n  text-align: left;       /* 1. 文字左对齐 */\r\n  padding-left: 30px; \r\n  margin-right: 12px; /* 平衡左侧按钮宽度 */\r\n}\r\n.search-box {\r\n  background: #fff;\r\n  border-radius: 20px;\r\n  padding: 4px 12px;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.1);\r\n  height: 32px; \r\n  box-sizing: border-box;\r\n}\r\n.search-box input {\r\n  border: none;\r\n  outline: none;\r\n  font-size: 13px;\r\n  color: #333;\r\n  width: 120px;\r\n  background: transparent;\r\n  line-height: normal; \r\n  margin: 0;\r\n  padding: 0;\r\n}\r\n.search-box svg {\r\n  width: 14px;\r\n  height: 14px;\r\n  flex-shrink: 0; /* 防止图标被压缩 */\r\n}\r\n\r\n/* === 2. Banner (仿参考图) === */\r\n.banner {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 240px; /* 稍微高一点，突出大气感 */\r\n  margin-bottom: 24px;\r\n  overflow: hidden;\r\n}\r\n.banner-img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  filter: brightness(0.9); /* 稍微压暗背景，突出文字 */\r\n}\r\n.banner-overlay {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  align-items: center;\r\n  color: #fff;\r\n  text-align: center;\r\n  background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.6) 100%);\r\n}\r\n.banner-subtitle {\r\n  font-size: 12px;\r\n  letter-spacing: 2px;\r\n  opacity: 0.8;\r\n  margin-bottom: 8px;\r\n  font-family: serif;\r\n}\r\n.banner-main-text {\r\n  font-size: 28px;\r\n  font-weight: bold;\r\n  color: white;\r\n  margin: 0 0 12px 0;\r\n  font-family: \"Songti SC\", \"SimSun\", serif; /* 宋体更有文化感 */\r\n  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.355);\r\n}\r\n.banner-discount {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  font-family: \"Times New Roman\", serif;\r\n}\r\n.banner-discount .num {\r\n  font-size: 42px;\r\n  font-weight: bold;\r\n  line-height: 1;\r\n}\r\n.banner-discount .symbol {\r\n  font-size: 24px;\r\n  opacity: 0.8;\r\n}\r\n\r\n/* === 3. 区块通用 === */\r\n.section {\r\n  padding: 0 16px;\r\n  margin-bott