{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { useRouter } from 'vue-router';\nexport default {\n  __name: 'HomeView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n\n    // 跳转到模式选择页\n    function goToModeSelect() {\n      router.push('/mode-select');\n    }\n    function goToHome() {\n      router.push('/home'); // 跳转到 /home\n    }\n    const __returned__ = {\n      router,\n      goToModeSelect,\n      goToHome,\n      get useRouter() {\n        return useRouter;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["useRouter","router","goToModeSelect","push","goToHome"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/HomeView.vue"],"sourcesContent":["<template>\r\n  <div class=\"home-page\">\r\n    <!-- 全屏背景图区域 -->\r\n    <div class=\"hero-section\">\r\n      <img src=\"../imgs/Gamecover_1.png\" alt=\"江姐故里数字文创启动页\" class=\"bg-image\">\r\n      <!-- 居中的进入探索按钮 -->\r\n      <div class=\"enter-btn-container\">\r\n        <button class=\"enter-btn\" @click=\"goToModeSelect\">\r\n          <span class=\"btn-text\">🌸进入探索🌸</span>\r\n          <span class=\"btn-subtext\">READY TO START</span>\r\n        </button>\r\n      </div>\r\n      <!-- 右侧悬浮功能按钮（参考图样式） -->\r\n     <div class=\"float-buttons\">\r\n        <button class=\"float-btn\" title=\"设置\">⚙️</button>\r\n        <button class=\"float-btn\" title=\"特殊功能\">SP</button>\r\n        <button class=\"float-btn\" title=\"更多\">⋮⋮</button>\r\n        <button class=\"float-btn\" title=\"返回首页\" @click=\"goToHome\">🏠</button>\r\n    </div>\r\n      <!-- 左下角版本信息（参考图样式） -->\r\n      <div class=\"version-info\">\r\n        <p>VER: 1.0.00</p>\r\n        <p class=\"agreement\">故里红梅用户使用许可及用户协议</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { useRouter } from 'vue-router'\r\n\r\nconst router = useRouter()\r\n\r\n// 跳转到模式选择页\r\nfunction goToModeSelect() {\r\n  router.push('/mode-select')\r\n}\r\nfunction goToHome() {\r\n  router.push('/home') // 跳转到 /home\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 全屏容器，占满整个视口 */\r\n.home-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  overflow: hidden;\r\n  background: #000;\r\n}\r\n\r\n/* 背景图区域，全屏展示 */\r\n.hero-section {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 100%;\r\n}\r\n\r\n/* 背景图：全屏铺满，无拉伸 */\r\n.bg-image {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  object-position: center;\r\n}\r\n\r\n/* 按钮容器：绝对定位在底部居中 */\r\n.enter-btn-container {\r\n  position: absolute;\r\n  bottom: 8%;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  z-index: 10;\r\n}\r\n\r\n/* 进入探索按钮：完全匹配参考图样式 */\r\n.enter-btn {\r\n  background: transparent;\r\n  border: none;\r\n  cursor: pointer;\r\n  padding: 10px 20px;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n/* 按钮主文字 */\r\n.btn-text {\r\n  display: block;\r\n  font-size: 32px;\r\n  font-weight: bold;\r\n  color: #fff;\r\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.6);\r\n  letter-spacing: 8px;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n/* 按钮英文副标题 */\r\n.btn-subtext {\r\n  display: block;\r\n  font-size: 16px;\r\n  color: #fff;\r\n  text-shadow: 1px 1px 2px rgba(0,0,0,0.6);\r\n  letter-spacing: 4px;\r\n  opacity: 0.9;\r\n}\r\n\r\n/* 按钮hover效果 */\r\n.enter-btn:hover .btn-text {\r\n  color: #ffd700;\r\n  transform: scale(1.05);\r\n}\r\n\r\n/* 右侧悬浮按钮组 */\r\n.float-buttons {\r\n  position: absolute;\r\n  top: 5%;\r\n  right: 2%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n  z-index: 10;\r\n}\r\n\r\n.float-btn {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 100%;\r\n  border: 2px solid rgba(255,255,255,0.8);\r\n  background: rgba(0,0,0,0.2);\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.float-btn:hover {\r\n  background: rgba(192, 57, 43, 0.8);\r\n  border-color: #fff;\r\n}\r\n\r\n/* 左下角版本信息 */\r\n.version-info {\r\n  position: absolute;\r\n  bottom: 2%;\r\n  left: 2%;\r\n  color: #fff;\r\n  font-size: 12px;\r\n  text-shadow: 1px 1px 2px rgba(0,0,0,0.8);\r\n  z-index: 10;\r\n}\r\n\r\n.agreement {\r\n  margin-top: 4px;\r\n  font-size: 10px;\r\n  opacity: 0.8;\r\n}\r\n\r\n/* 响应式适配：手机端缩小字号 */\r\n@media (max-width: 768px) {\r\n  .btn-text {\r\n    font-size: 24px;\r\n    letter-spacing: 6px;\r\n  }\r\n  .btn-subtext {\r\n    font-size: 14px;\r\n    letter-spacing: 3px;\r\n  }\r\n  .float-btn {\r\n    width: 36px;\r\n    height: 36px;\r\n    font-size: 16px;\r\n  }\r\n}\r\n</style>"],"mappings":";AA6BA,SAASA,SAAS,QAAQ,YAAY;;;;;;;IAEtC,MAAMC,MAAM,GAAGD,SAAS,CAAC,CAAC;;IAE1B;IACA,SAASE,cAAcA,CAAA,EAAG;MACxBD,MAAM,CAACE,IAAI,CAAC,cAAc,CAAC;IAC7B;IACA,SAASC,QAAQA,CAAA,EAAG;MAClBH,MAAM,CAACE,IAAI,CAAC,OAAO,CAAC,EAAC;IACvB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}