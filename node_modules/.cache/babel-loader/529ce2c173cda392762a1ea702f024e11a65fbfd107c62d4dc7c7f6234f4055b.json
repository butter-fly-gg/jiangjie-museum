{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed } from 'vue';\nimport { useRouter } from 'vue-router';\n\n// 1. 导入图片（import 是最稳的方式）\nimport storyImg from '../imgs/Game1.l.png';\nimport interactiveImg from '../imgs/Game1.m.png';\nimport scrollImg from '../imgs/Game1.r.png';\nexport default {\n  __name: 'ModeSelectView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n\n    // 2. 模式列表\n    const modeList = ref([{\n      name: '故事聆听模式',\n      img: storyImg,\n      path: '/story'\n    }, {\n      name: '现场交互模式',\n      img: interactiveImg,\n      path: '/interactive'\n    }, {\n      name: '线上绘卷模式',\n      img: scrollImg,\n      path: '/scroll'\n    }]);\n\n    // 3. 核心逻辑：无缝循环\n    // current 代表中间显示的卡片索引（0,1,2 循环）\n    const current = ref(1);\n\n    // 4. 计算位移：33.33 * 索引 = 卡片居中\n    const pos = computed(() => {\n      return -current.value * 33.33;\n    });\n    const currentItem = computed(() => modeList.value[current.value]);\n\n    // 🔄 无缝循环算法\n    function prev() {\n      // 上一张：如果当前是0(故事)，则切换到2(卷轴)，实现循环\n      current.value = current.value === 0 ? 2 : current.value - 1;\n    }\n    function next() {\n      // 下一张：如果当前是2(卷轴)，则切换到0(故事)，实现循环\n      current.value = current.value === 2 ? 0 : current.value + 1;\n    }\n    function select(i) {\n      current.value = i;\n    }\n    function goBack() {\n      router.back();\n    }\n    function enter() {\n      router.push(currentItem.value.path);\n    }\n    const __returned__ = {\n      router,\n      modeList,\n      current,\n      pos,\n      currentItem,\n      prev,\n      next,\n      select,\n      goBack,\n      enter,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      },\n      get storyImg() {\n        return storyImg;\n      },\n      get interactiveImg() {\n        return interactiveImg;\n      },\n      get scrollImg() {\n        return scrollImg;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","storyImg","interactiveImg","scrollImg","router","modeList","name","img","path","current","pos","value","currentItem","prev","next","select","i","goBack","back","enter","push"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <div class=\"back-bar\" @click=\"goBack\">← 返回</div>\r\n\r\n    <h2 class=\"title\">—— 请选择您想体验的模式 ——</h2>\r\n\r\n    <!-- 🔑  carousel-container 是视口，必须 overflow: hidden -->\r\n    <div class=\"carousel-container\">\r\n      <div class=\"arrow left\" @click=\"prev\">❮</div>\r\n\r\n      <!-- 🔑   track 承载所有卡片，宽度是 300%，位移通过 translateX 控制 -->\r\n      <div class=\"carousel-track\" :style=\"{ transform: `translateX(${pos}%)` }\">\r\n        <div\r\n          class=\"mode-card\"\r\n          :class=\"{ active: current === index }\"\r\n          v-for=\"(item, index) in modeList\"\r\n          :key=\"index\"\r\n          @click=\"select(index)\"\r\n        >\r\n          <img class=\"mode-img\" :src=\"item.img\" />\r\n          <div class=\"label\">{{ item.name }}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"arrow right\" @click=\"next\">❯</div>\r\n    </div>\r\n\r\n    <button class=\"enter-btn\" @click=\"enter\">进入 {{ currentItem.name }}</button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\n// 1. 导入图片（import 是最稳的方式）\r\nimport storyImg from '../imgs/Game1.l.png'\r\nimport interactiveImg from '../imgs/Game1.m.png'\r\nimport scrollImg from '../imgs/Game1.r.png'\r\n\r\nconst router = useRouter()\r\n\r\n// 2. 模式列表\r\nconst modeList = ref([\r\n  { name: '故事聆听模式', img: storyImg, path: '/story' },\r\n  { name: '现场交互模式', img: interactiveImg, path: '/interactive' },\r\n  { name: '线上绘卷模式', img: scrollImg, path: '/scroll' },\r\n])\r\n\r\n// 3. 核心逻辑：无缝循环\r\n// current 代表中间显示的卡片索引（0,1,2 循环）\r\nconst current = ref(1) \r\n\r\n// 4. 计算位移：33.33 * 索引 = 卡片居中\r\nconst pos = computed(() => {\r\n  return -current.value * 33.33\r\n})\r\n\r\nconst currentItem = computed(() => modeList.value[current.value])\r\n\r\n// 🔄 无缝循环算法\r\nfunction prev() {\r\n  // 上一张：如果当前是0(故事)，则切换到2(卷轴)，实现循环\r\n  current.value = current.value === 0 ? 2 : current.value - 1;\r\n}\r\n\r\nfunction next() {\r\n  // 下一张：如果当前是2(卷轴)，则切换到0(故事)，实现循环\r\n  current.value = current.value === 2 ? 0 : current.value + 1;\r\n}\r\n\r\nfunction select(i) {\r\n  current.value = i\r\n}\r\nfunction goBack() {\r\n  router.back()\r\n}\r\nfunction enter() {\r\n  router.push(currentItem.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  /* 背景图也用 import 进来的变量，确保路径正确 */\r\n  background: url(../imgs/Gamecover_1.png) no-repeat center center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n\r\n.title {\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 40px;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 🔑 关键样式 1：视口容器，溢出隐藏 */\r\n.carousel-container {\r\n  position: relative;\r\n  width: 100%;\r\n  max-width: 900px; /* 可以根据设计稿调整 */\r\n  height: 460px;   /* 卡片高度 */\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden; /* 必须加，只显示中间一张 */\r\n}\r\n\r\n/* 🔑 关键样式 2：箭头位置与美化 */\r\n.arrow {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 50px;\r\n  height: 50px;\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border: 2px solid #fff;\r\n  border-radius: 50%;\r\n  color: #fff;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  z-index: 10;\r\n  transition: all 0.3s;\r\n}\r\n.arrow:hover {\r\n  background: rgba(255, 255, 255, 0.4);\r\n}\r\n.arrow.left { left: 10px; }\r\n.arrow.right { right: 10px; }\r\n\r\n/* 🔑 关键样式 3：轨道宽度 300%，3张卡片并排 */\r\n.carousel-track {\r\n  display: flex;\r\n  width: 300%; /* 100% * 3 */\r\n  height: 100%;\r\n  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* 丝滑动画 */\r\n}\r\n\r\n/* 🔑 关键样式 4：每张卡片占 33.333%，保持连在一起 */\r\n.mode-card {\r\n  width: 33.333%; /* 平均分配 */\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  opacity: 0.7;\r\n  transform: scale(0.85); /* 初始缩小 */\r\n  transition: all 0.4s ease;\r\n  cursor: pointer;\r\n}\r\n\r\n/* 🔑 关键样式 5：中间选中状态，放大高亮 */\r\n.mode-card.active {\r\n  opacity: 1;\r\n  transform: scale(1); /* 中间卡片正常大小 */\r\n}\r\n\r\n.mode-img {\r\n  width: 100%;\r\n  height: 380px;\r\n  object-fit: cover;\r\n  border-radius: 16px;\r\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\r\n}\r\n\r\n.label {\r\n  margin-top: 12px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n.enter-btn {\r\n  margin-top: 20px;\r\n  padding: 14px 50px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 15px rgba(0,0,0,0.3);\r\n}\r\n</style>"],"mappings":";AAgCA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,QAAQ,YAAY;;AAEtC;AACA,OAAOC,QAAQ,MAAM,qBAAqB;AAC1C,OAAOC,cAAc,MAAM,qBAAqB;AAChD,OAAOC,SAAS,MAAM,qBAAqB;;;;;;;IAE3C,MAAMC,MAAM,GAAGJ,SAAS,CAAC,CAAC;;IAE1B;IACA,MAAMK,QAAQ,GAAGP,GAAG,CAAC,CACnB;MAAEQ,IAAI,EAAE,QAAQ;MAAEC,GAAG,EAAEN,QAAQ;MAAEO,IAAI,EAAE;IAAS,CAAC,EACjD;MAAEF,IAAI,EAAE,QAAQ;MAAEC,GAAG,EAAEL,cAAc;MAAEM,IAAI,EAAE;IAAe,CAAC,EAC7D;MAAEF,IAAI,EAAE,QAAQ;MAAEC,GAAG,EAAEJ,SAAS;MAAEK,IAAI,EAAE;IAAU,CAAC,CACpD,CAAC;;IAEF;I