{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nexport default {\n  name: 'BeautifulMap',\n  data() {\n    return {\n      isDesktop: false,\n      selectedTransport: 'walking',\n      bgImage: require('@/assets/images/beautiful/bg-zigong.jpg'),\n      // 请确保路径正确\n      mapImage: require('@/assets/images/beautiful/travel-sky.jpg'),\n      // 请确保路径正确\n      transportModes: [{\n        value: 'walking',\n        label: '步行',\n        icon: '🚶'\n      }, {\n        value: 'bike',\n        label: '骑行',\n        icon: '🚲'\n      }, {\n        value: 'bus',\n        label: '公交',\n        icon: '🚌'\n      }, {\n        value: 'car',\n        label: '驾车',\n        icon: '🚗'\n      }],\n      routeSteps: [{\n        title: '江姐故里',\n        desc: '参观革命烈士纪念馆，感受红色文化',\n        tag: '起点'\n      }, {\n        title: '自流井老街',\n        desc: '体验千年盐都历史文化，品尝小吃',\n        tag: ''\n      }, {\n        title: '燊海井',\n        desc: '世界最古老的盐井，见证古代工艺',\n        tag: '必去'\n      }, {\n        title: '彩灯公园',\n        desc: '欣赏自贡彩灯艺术，夜晚更美',\n        tag: ''\n      }, {\n        title: '东锅厂',\n        desc: '工业遗产，现代自贡的象征',\n        tag: '终点'\n      }]\n    };\n  },\n  mounted() {\n    this.checkDevice();\n    window.addEventListener('resize', this.checkDevice);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.checkDevice);\n  },\n  methods: {\n    checkDevice() {\n      // 768px 为断点，大于此值视为桌面/平板横屏模式\n      this.isDesktop = window.innerWidth >= 768;\n    },\n    selectTransport(mode) {\n      this.selectedTransport = mode;\n      // 这里可以添加逻辑：根据交通方式重新计算路线或时间\n      console.log(`切换到交通方式：${mode}`);\n    },\n    startNavigation() {\n      const modeName = this.transportModes.find(m => m.value === this.selectedTransport)?.label;\n      alert(`🚀 开始${modeName}导航！\\n路线：江姐故里 → ... → 东锅厂`);\n      // 实际项目中可调用地图 SDK 或跳转页面\n      // this.$router.push({ path: '/navigation', query: { mode: this.selectedTransport } });\n    }\n  }\n};","map":{"version":3,"names":["name","data","isDesktop","selectedTransport","bgImage","require","mapImage","transportModes","value","label","icon","routeSteps","title","desc","tag","mounted","checkDevice","window","addEventListener","beforeUnmount","removeEventListener","methods","innerWidth","selectTransport","mode","console","log","startNavigation","modeName","find","m","alert"],"sources":["E:\\jiangjie-museum\\GitHub\\jiangjie-museum\\src\\views\\BeautifulMap.vue"],"sourcesContent":["<template>\r\n  <div class=\"beautiful-map-page\">\r\n    <!-- Hero 区域 (仅在移动端显著显示，桌面端作为背景装饰) -->\r\n    <div class=\"hero\" :class=\"{ 'hero-desktop': isDesktop }\">\r\n      <img class=\"hero-bg\" :src=\"bgImage\" alt=\"自贡地图背景\" />\r\n      <div class=\"hero-mask\"></div>\r\n\r\n      <div class=\"hero-content\">\r\n        <div class=\"hero-title\">\r\n          <div class=\"hero-title-main\">自贡游玩路线</div>\r\n          <div class=\"hero-title-sub\">\r\n            <span class=\"hero-title-sub-text\">江姐故里 → 东锅厂</span>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 桌面端隐藏小图标，移动端保留 -->\r\n        <div class=\"hero-icon\" aria-hidden=\"true\" v-if=\"!isDesktop\">\r\n          <div class=\"hero-icon-ring\"></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 主内容区域：Flex 布局实现响应式分栏 -->\r\n    <div class=\"main-container\">\r\n      \r\n      <!-- 左侧/顶部：信息控制面板 -->\r\n      <div class=\"info-panel\">\r\n        <!-- 路线信息卡片 -->\r\n        <div class=\"route-info-card\">\r\n          <div class=\"route-header\">\r\n            <div class=\"route-title\">江姐故里 → 东锅厂</div>\r\n            <div class=\"route-subtitle\">经典文化探索路线</div>\r\n          </div>\r\n\r\n          <div class=\"route-stats\">\r\n            <div class=\"stat-item\">\r\n              <div class=\"stat-value\">4.2<span class=\"unit\">km</span></div>\r\n              <div class=\"stat-label\">总距离</div>\r\n            </div>\r\n            <div class=\"divider-vertical\"></div>\r\n            <div class=\"stat-item\">\r\n              <div class=\"stat-value\">25<span class=\"unit\">min</span></div>\r\n              <div class=\"stat-label\">预计时间</div>\r\n            </div>\r\n            <div class=\"divider-vertical\"></div>\r\n            <div class=\"stat-item\">\r\n              <div class=\"stat-value\">5<span class=\"unit\">点</span></div>\r\n              <div class=\"stat-label\">途经点</div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"transport-options\">\r\n            <button \r\n              v-for=\"mode in transportModes\" \r\n              :key=\"mode.value\"\r\n              :class=\"['transport-btn', { active: selectedTransport === mode.value }]\"\r\n              @click=\"selectTransport(mode.value)\"\r\n            >\r\n              <span class=\"icon\">{{ mode.icon }}</span>\r\n              {{ mode.label }}\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 路线详情列表 (桌面端在此显示，移动端在地图下方) -->\r\n        <div class=\"route-details-card\">\r\n          <div class=\"card-header\">\r\n            <h3>行程详情</h3>\r\n            <span class=\"badge\">全程导览</span>\r\n          </div>\r\n          \r\n          <div class=\"route-details\">\r\n            <div class=\"detail-item\" v-for=\"(step, index) in routeSteps\" :key=\"index\">\r\n              <div class=\"detail-step\">\r\n                <div class=\"step-number\">{{ index + 1 }}</div>\r\n                <div class=\"step-line\" v-if=\"index !== routeSteps.length - 1\"></div>\r\n              </div>\r\n              <div class=\"detail-content\">\r\n                <div class=\"detail-title\">{{ step.title }}</div>\r\n                <div class=\"detail-desc\">{{ step.desc }}</div>\r\n                <div class=\"detail-tag\" v-if=\"step.tag\">{{ step.tag }}</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 移动端底部导航按钮 (桌面端隐藏，桌面端按钮放在面板底部) -->\r\n        <div class=\"mobile-nav-action\">\r\n          <button class=\"nav-button\" @click=\"startNavigation\">\r\n            <span class=\"btn-icon\">🧭</span> 选定并开始导航\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 右侧/底部：地图可视化区域 -->\r\n      <div class=\"map-visual-container\">\r\n        <div class=\"map-background\">\r\n          <img :src=\"mapImage\" alt=\"地图底图\" class=\"map-image\" />\r\n          \r\n          <!-- 响应式 SVG 路径层 -->\r\n          <svg class=\"route-path-svg\" viewBox=\"0 0 400 600\" preserveAspectRatio=\"xMidYMid slice\">\r\n            <defs>\r\n              <linearGradient id=\"pathGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\r\n                <stop offset=\"0%\" style=\"stop-color:#FF5722; stop-opacity:1\" />\r\n                <stop offset=\"100%\" style=\"stop-color:#4CAF50; stop-opacity:1\" />\r\n              </linearGradient>\r\n              <filter id=\"glow\">\r\n                <feGaussianBlur stdDeviation=\"2.5\" result=\"coloredBlur\"/>\r\n                <feMerge>\r\n                  <feMergeNode in=\"coloredBlur\"/>\r\n                  <feMergeNode in=\"SourceGraphic\"/>\r\n                </feMerge>\r\n              </filter>\r\n            </defs>\r\n            \r\n            <!-- 动态虚线路径 -->\r\n            <path \r\n              class=\"animated-path\"\r\n              d=\"M 50 500 Q 100 400 150 350 T 250 300 T 300 200 T 350 100\" \r\n              stroke=\"url(#pathGradient)\" \r\n              stroke-width=\"5\" \r\n              fill=\"none\" \r\n              stroke-linecap=\"round\"\r\n              stroke-dasharray=\"10, 8\"\r\n              filter=\"url(#glow)\"\r\n            />\r\n            \r\n            <!-- 起点 -->\r\n            <g class=\"marker start\">\r\n              <circle cx=\"50\" cy=\"500\" r=\"10\" fill=\"#FF5722\" stroke=\"#fff\" stroke-width=\"3\"/>\r\n              <text x=\"50\" y=\"480\" text-anchor=\"middle\" class=\"marker-label\">起点</text>\r\n            </g>\r\n            \r\n            <!-- 终点 -->\r\n            <g class=\"marker end\">\r\n              <circle cx=\"350\" cy=\"100\" r=\"10\" fill=\"#4CAF50\" stroke=\"#fff\" stroke-width=\"3\"/>\r\n              <text x=\"350\" y=\"80\" text-anchor=\"middle\" class=\"marker-label\">终点</text>\r\n            </g>\r\n            \r\n            <!-- 途经点 (动态生成位置示例，实际项目可绑定坐标) -->\r\n            <circle cx=\"150\" cy=\"350\" r=\"6\" fill=\"#FFC107\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n            <circle cx=\"250\" cy=\"300\" r=\"6\" fill=\"#FFC107\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n            <circle cx=\"300\" cy=\"200\" r=\"6\" fill=\"#FFC107\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n          </svg>\r\n\r\n          <!-- 地图控制浮层 (模拟) -->\r\n          <div class=\"map-controls\">\r\n            <button class=\"control-btn\" title=\"定位\">📍</button>\r\n            <button class=\"control-btn\" title=\"图层\">🗺️</button>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 桌面端底部操作区 -->\r\n        <div class=\"desktop-nav-action\">\r\n           <button class=\"nav-button large\" @click=\"startNavigation\">\r\n            <span class=\"btn-icon\">🧭</span> 选定并开始导航\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'BeautifulMap',\r\n  data() {\r\n    return {\r\n      isDesktop: false,\r\n      selectedTransport: 'walking',\r\n      bgImage: require('@/assets/images/beautiful/bg-zigong.jpg'), // 请确保路径正确\r\n      mapImage: require('@/assets/images/beautiful/travel-sky.jpg'), // 请确保路径正确\r\n      transportModes: [\r\n        { value: 'walking', label: '步行', icon: '🚶' },\r\n        { value: 'bike', label: '骑行', icon: '🚲' },\r\n        { value: 'bus', label: '公交', icon: '🚌' },\r\n        { value: 'car', label: '驾车', icon: '🚗' }\r\n      ],\r\n      routeSteps: [\r\n        { title: '江姐故里', desc: '参观革命烈士纪念馆，感受红色文化', tag: '起点' },\r\n        { title: '自流井老街', desc: '体验千年盐都历史文化，品尝小吃', tag: '' },\r\n        { title: '燊海井', desc: '世界最古老的盐井，见证古代工艺', tag: '必去' },\r\n        { title: '彩灯公园', desc: '欣赏自贡彩灯艺术，夜晚更美', tag: '' },\r\n        { title: '东锅厂', desc: '工业遗产，现代自贡的象征', tag: '终点' }\r\n      ]\r\n    }\r\n  },\r\n  mounted() {\r\n    this.checkDevice();\r\n    window.addEventListener('resize', this.checkDevice);\r\n  },\r\n  beforeUnmount() {\r\n    window.removeEventListener('resize', this.checkDevice);\r\n  },\r\n  methods: {\r\n    checkDevice() {\r\n      // 768px 为断点，大于此值视为桌面/平板横屏模式\r\n      this.isDesktop = window.innerWidth >= 768;\r\n    },\r\n    selectTransport(mode) {\r\n      this.selectedTransport = mode;\r\n      // 这里可以添加逻辑：根据交通方式重新计算路线或时间\r\n      console.log(`切换到交通方式：${mode}`);\r\n    },\r\n    startNavigation() {\r\n      const modeName = this.transportModes.find(m => m.value === this.selectedTransport)?.label;\r\n      alert(`🚀 开始${modeName}导航！\\n路线：江姐故里 → ... → 东锅厂`);\r\n      // 实际项目中可调用地图 SDK 或跳转页面\r\n      // this.$router.push({ path: '/navigation', query: { mode: this.selectedTransport } });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* ========== 变量定义 ========== */\r\n:root {\r\n  --primary-color: #4CAF50;\r\n  --accent-color: #FF5722;\r\n  --text-main: #333;\r\n  --text-sub: #666;\r\n  --bg-gray: #f5f7fa;\r\n}\r\n\r\n/* ========== 全局基础 ========== */\r\n.beautiful-map-page {\r\n  min-height: 100vh;\r\n  background: #f0f2f5;\r\n  font-family: 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;\r\n  color: #333;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n/* ========== Hero Banner ========== */\r\n.hero {\r\n  position: relative;\r\n  height: 260px;\r\n  overflow: hidden;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.hero-desktop {\r\n  height: 320px;\r\n}\r\n\r\n.hero-bg {\r\n  position: absolute;\r\n  inset: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.hero-mask {\r\n  position: absolute;\r\n  inset: 0;\r\n  background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.1) 60%, rgba(255,255,255,0.8) 100%);\r\n}\r\n\r\n.hero-content {\r\n  position: relative;\r\n  z-index: 2;\r\n  padding: 20px;\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: flex-start;\r\n}\r\n\r\n.hero-title {\r\n  color: #fff;\r\n  text-shadow: 0 4px 12px rgba(0,0,0,0.4);\r\n}\r\n\r\n.hero-title-main {\r\n  font-size: 32px;\r\n  font-weight: 800;\r\n  letter-spacing: 1px;\r\n}\r\n\r\n.hero-title-sub {\r\n  margin-top: 8px;\r\n  display: inline-block;\r\n}\r\n\r\n.hero-title-sub-text {\r\n  font-size: 13px;\r\n  color: #fff;\r\n  padding: 4px 12px;\r\n  border-radius: 20px;\r\n  background: rgba(255, 87, 34, 0.85);\r\n  backdrop-filter: blur(4px);\r\n  font-weight: 600;\r\n}\r\n\r\n.hero-icon {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n  background: rgba(255,255,255,0.2);\r\n  border: 2px solid rgba(255,255,255,0.6);\r\n  display: grid;\r\n  place-items: center;\r\n}\r\n\r\n.hero-icon-ring {\r\n  width: 24px;\r\n  height: 24px;\r\n  border-radius: 50%;\r\n  border: 2px solid #fff;\r\n}\r\n\r\n/* ========== 主容器 (响应式核心) ========== */\r\n.main-container {\r\n  flex: 1;\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n  width: 100%;\r\n  padding: 0;\r\n  display: flex;\r\n  flex-direction: column; /* 默认移动端垂直排列 */\r\n}\r\n\r\n/* ========== 信息面板 (左侧/顶部) ========== */\r\n.info-panel {\r\n  padding: 20px 16px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 20px;\r\n}\r\n\r\n/* 卡片通用样式 */\r\n.route-info-card, .route-details-card {\r\n  background: #fff;\r\n  border-radius: 16px;\r\n  padding: 20px;\r\n  box-shadow: 0 8px 24px rgba(0,0,0,0.06);\r\n}\r\n\r\n/* 路线统计 */\r\n.route-header {\r\n  margin-bottom: 16px;\r\n}\r\n.route-title { font-size: 20px; font-weight: 800; color: #2c3e50; }\r\n.route-subtitle { font-size: 13px; color: #7f8c8d; margin-top: 4px; }\r\n\r\n.route-stats {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background: #f8f9fa;\r\n  border-radius: 12px;\r\n  padding: 12px 0;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.stat-item {\r\n  flex: 1;\r\n  text-align: center;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n}\r\n\r\n.stat-value {\r\n  font-size: 18px;\r\n  font-weight: 800;\r\n  color: var(--primary-color);\r\n}\r\n.stat-value .unit { font-size: 12px; font-weight: normal; color: #666; margin-left: 2px; }\r\n.stat-label { font-size: 11px; color: #999; margin-top: 2px; }\r\n\r\n.divider-vertical {\r\n  width: 1px;\r\n  height: 30px;\r\n  background: #e0e0e0;\r\n}\r\n\r\n/* 交通方式 */\r\n.transport-options {\r\n  display: flex;\r\n  gap: 8px;\r\n  overflow-x: auto;\r\n  padding-bottom: 4px;\r\n  scrollbar-width: none; /* Firefox */\r\n}\r\n.transport-options::-webkit-scrollbar { display: none; }\r\n\r\n.transport-btn {\r\n  flex: 1;\r\n  min-width: 70px;\r\n  padding: 8px 12px;\r\n  border: 1px solid #eee;\r\n  border-radius: 20px;\r\n  background: #fff;\r\n  color: #666;\r\n  font-size: 13px;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 4px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.transport-btn.active {\r\n  background: var(--primary-color);\r\n  color: #fff;\r\n  border-color: var(--primary-color);\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 10px rgba(76, 175, 80, 0.3);\r\n}\r\n\r\n/* 详情列表 */\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n  padding-bottom: 10px;\r\n  border-bottom: 1px solid #f0f0f0;\r\n}\r\n.card-header h3 { margin: 0; font-size: 16px; color: #333; }\r\n.badge { font-size: 10px; background: #e3f2fd; color: #2196f3; padding: 2px 6px; border-radius: 4px; }\r\n\r\n.route-details {\r\n  max-height: 400px;\r\n  overflow-y: auto;\r\n  padding-right: 4px;\r\n}\r\n/* 美化滚动条 */\r\n.route-details::-webkit-scrollbar { width: 4px; }\r\n.route-details::-webkit-scrollbar-thumb { background: #ddd; border-radius: 2px; }\r\n\r\n.detail-item {\r\n  display: flex;\r\n  margin-bottom: 20px;\r\n  position: relative;\r\n}\r\n\r\n.detail-step {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  margin-right: 12px;\r\n  position: relative;\r\n}\r\n\r\n.step-number {\r\n  width: 24px;\r\n  height: 24px;\r\n  border-radius: 50%;\r\n  background: #e8f5e9;\r\n  color: var(--primary-color);\r\n  font-size: 12px;\r\n  font-weight: bold;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  z-index: 2;\r\n}\r\n.detail-item:last-child .step-number { background: var(--primary-color); color: #fff; }\r\n\r\n.step-line {\r\n  width: 2px;\r\n  flex: 1;\r\n  background: #e0e0e0;\r\n  margin-top: 4px;\r\n  min-height: 40px;\r\n}\r\n\r\n.detail-content { flex: 1; padding-top: 2px; }\r\n.detail-title { font-size: 15px; font-weight: 600; color: #333; }\r\n.detail-desc { font-size: 12px; color: #777; margin-top: 4px; line-height: 1.4; }\r\n.detail-tag { \r\n  display: inline-block; \r\n  font-size: 10px; \r\n  background: #fff3e0; \r\n  color: #ff9800; \r\n  padding: 1px 6px; \r\n  border-radius: 4px; \r\n  margin-top: 6px; \r\n  font-weight: bold;\r\n}\r\n\r\n/* 导航按钮 */\r\n.mobile-nav-action {\r\n  margin-top: 10px;\r\n  padding: 0 4px;\r\n}\r\n.desktop-nav-action {\r\n  display: none; /* 默认隐藏，桌面端显示 */\r\n  padding: 20px;\r\n  background: #fff;\r\n  border-top: 1px solid #eee;\r\n}\r\n\r\n.nav-button {\r\n  width: 100%;\r\n  height: 50px;\r\n  border: none;\r\n  border-radius: 12px;\r\n  background: linear-gradient(135deg, #4CAF50, #2196F3);\r\n  color: #fff;\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  box-shadow: 0 6px 16px rgba(76, 175, 80, 0.35);\r\n  transition: transform 0.2s, box-shadow 0.2s;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 8px;\r\n}\r\n.nav-button:active { transform: scale(0.98); }\r\n.nav-button.large { height: 60px; font-size: 18px; max-width: 400px; margin: 0 auto; }\r\n\r\n/* ========== 地图可视化区域 (右侧/底部) ========== */\r\n.map-visual-container {\r\n  background: #fff;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.map-background {\r\n  position: relative;\r\n  width: 100%;\r\n  /* 移动端保持比例 */\r\n  aspect-ratio: 4/3; \r\n  background: #eef;\r\n  overflow: hidden;\r\n}\r\n\r\n.map-image {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  opacity: 0.8;\r\n}\r\n\r\n.route-path-svg {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  z-index: 2;\r\n}\r\n\r\n.animated-path {\r\n  stroke-dashoffset: 100;\r\n  animation: dash 20s linear infinite;\r\n}\r\n\r\n@keyframes dash {\r\n  to { stroke-dashoffset: 0; }\r\n}\r\n\r\n.marker-label {\r\n  font-size: 12px;\r\n  fill: #333;\r\n  font-weight: bold;\r\n  text-shadow: 0 0 4px #fff;\r\n}\r\n\r\n.map-controls {\r\n  position: absolute;\r\n  right: 15px;\r\n  bottom: 15px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n  z-index: 10;\r\n}\r\n\r\n.control-btn {\r\n  width: 40px;\r\n  height: 40px;\r\n  border: none;\r\n  border-radius: 8px;\r\n  background: #fff;\r\n  box-shadow: 0 4px 10px rgba(0,0,0,0.2);\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  display: grid;\r\n  place-items: center;\r\n}\r\n.control-btn:hover { background: #f5f5f5; }\r\n\r\n/* ========== 响应式断点 (Web/平板优化) ========== */\r\n@media (min-width: 768px) {\r\n  .hero {\r\n    height: 350px;\r\n    clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);\r\n  }\r\n  \r\n  .main-container {\r\n    flex-direction: row; /* 横向排列 */\r\n    padding: 20px;\r\n    gap: 20px;\r\n    align-items: stretch;\r\n  }\r\n\r\n  .info-panel {\r\n    flex: 0 0 380px; /* 固定左侧宽度 */\r\n    padding: 0;\r\n    background: transparent;\r\n    box-shadow: none;\r\n    overflow-y: auto;\r\n    max-height: calc(100vh - 280px);\r\n  }\r\n  \r\n  /* 隐藏移动端的独立按钮，因为桌面端按钮