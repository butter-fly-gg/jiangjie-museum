 justify-content: center;\r\n  align-items: center;\r\n  color: white;\r\n  text-align: center;\r\n  padding: 20px;\r\n}\r\n\r\n.hero-content h1 {\r\n  font-size: 36px;\r\n  margin-bottom: 10px;\r\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n.hero-content p {\r\n  font-size: 18px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.enter-mode-btn {\r\n  padding: 12px 24px;\r\n  background: #c0392b;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 8px;\r\n  font-size: 16px;\r\n  cursor: pointer;\r\n}\r\n\r\n/* 功能区域 */\r\n.features-section {\r\n  padding: 40px 20px;\r\n  background: #f8f9fa;\r\n}\r\n\r\n.features-section h2 {\r\n  text-align: center;\r\n  color: #c0392b;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.feature-grid {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 20px;\r\n  justify-content: center;\r\n}\r\n\r\n.feature-item {\r\n  width: 120px;\r\n  text-align: center;\r\n  cursor: pointer;\r\n}\r\n\r\n.feature-item img {\r\n  width: 80px;\r\n  height: 80px;\r\n  border-radius: 50%;\r\n  object-fit: cover;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.feature-item span {\r\n  display: block;\r\n  color: #333;\r\n  font-size: 14px;\r\n}\r\n</style>"],"mappings":";AAiBA,SAASA,SAAS,QAAQ,YAAY;;;;;;;IAEtC,MAAMC,MAAM,GAAGD,SAAS,CAAC,CAAC;;IAE1B;IACA,SAASE,cAAcA,CAAA,EAAG;MACxBD,MAAM,CAACE,IAAI,CAAC,cAAc,CAAC;IAC7B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}