{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/web.url-search-params.delete.js\";\nimport \"core-js/modules/web.url-search-params.has.js\";\nimport \"core-js/modules/web.url-search-params.size.js\";\nimport { ref, computed } from 'vue';\nimport { useRouter } from 'vue-router';\nconst cardWidth = 320; // 卡片宽度\n\n// 计算偏移量（让卡片居中）\n\nexport default {\n  __name: 'ModeSelectView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n\n    // 模式数据\n    const modeList = ref([{\n      name: \"故事聆听模式\",\n      img: \"Game1.l.png\",\n      path: \"/story\"\n    }, {\n      name: \"现场交互模式\",\n      img: \"Game1.m.png\",\n      path: \"/interactive\"\n    }, {\n      name: \"线上绘卷模式\",\n      img: \"Game1.r.png\",\n      path: \"/scroll\"\n    }]);\n    const currentIndex = ref(1);\n    const offset = computed(() => {\n      return -(currentIndex.value * (cardWidth + 20)) + (960 - cardWidth) / 2;\n    });\n    const currentMode = computed(() => modeList.value[currentIndex.value]);\n\n    // 图片路径处理\n    function getImgUrl(imgName) {\n      return new URL(`../imgs/${imgName}`, import.meta.url).href;\n    }\n\n    // 切换逻辑\n    function prevMode() {\n      currentIndex.value = currentIndex.value === 0 ? 2 : currentIndex.value - 1;\n    }\n    function nextMode() {\n      currentIndex.value = currentIndex.value === 2 ? 0 : currentIndex.value + 1;\n    }\n    function selectMode(index) {\n      currentIndex.value = index;\n    }\n    function goBack() {\n      router.back();\n    }\n    function enterCurrentMode() {\n      router.push(currentMode.value.path);\n    }\n    const __returned__ = {\n      router,\n      modeList,\n      currentIndex,\n      cardWidth,\n      offset,\n      currentMode,\n      getImgUrl,\n      prevMode,\n      nextMode,\n      selectMode,\n      goBack,\n      enterCurrentMode,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","cardWidth","router","modeList","name","img","path","currentIndex","offset","value","currentMode","getImgUrl","imgName","URL","import","meta","url","href","prevMode","nextMode","selectMode","index","goBack","back","enterCurrentMode","push"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <!-- 返回按钮 -->\r\n    <div class=\"back-bar\" @click=\"goBack\">← 返回</div>\r\n\r\n    <!-- 标题 -->\r\n    <h2 class=\"title\">—— 请选择您想体验的模式 ——</h2>\r\n\r\n    <!-- 横向三图轮播容器 -->\r\n    <div class=\"carousel-container\">\r\n      <button class=\"arrow-btn left-arrow\" @click=\"prevMode\">\r\n        <span class=\"arrow-icon\">❮</span>\r\n      </button>\r\n\r\n      <div class=\"carousel-track\" :style=\"{ transform: `translateX(${offset}px)` }\">\r\n        <div \r\n          class=\"mode-card\" \r\n          :class=\"{ active: currentIndex === index }\"\r\n          v-for=\"(item, index) in modeList\" \r\n          :key=\"index\"\r\n          @click=\"selectMode(index)\"\r\n        >\r\n          <img :src=\"getImgUrl(item.img)\" :alt=\"item.name\" class=\"mode-img\">\r\n          <div class=\"mode-name\">{{ item.name }}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <button class=\"arrow-btn right-arrow\" @click=\"nextMode\">\r\n        <span class=\"arrow-icon\">❯</span>\r\n      </button>\r\n    </div>\r\n\r\n    <button class=\"enter-btn\" @click=\"enterCurrentMode\">\r\n      进入 {{ currentMode.name }}\r\n    </button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nconst router = useRouter()\r\n\r\n// 模式数据\r\nconst modeList = ref([\r\n  { name: \"故事聆听模式\", img: \"Game1.l.png\", path: \"/story\" },\r\n  { name: \"现场交互模式\", img: \"Game1.m.png\", path: \"/interactive\" },\r\n  { name: \"线上绘卷模式\", img: \"Game1.r.png\", path: \"/scroll\" }\r\n])\r\n\r\nconst currentIndex = ref(1)\r\nconst cardWidth = 320 // 卡片宽度\r\n\r\n// 计算偏移量（让卡片居中）\r\nconst offset = computed(() => {\r\n  return -(currentIndex.value * (cardWidth + 20)) + (960 - cardWidth) / 2\r\n})\r\n\r\nconst currentMode = computed(() => modeList.value[currentIndex.value])\r\n\r\n// 图片路径处理\r\nfunction getImgUrl(imgName) {\r\n  return new URL(`../imgs/${imgName}`, import.meta.url).href\r\n}\r\n\r\n// 切换逻辑\r\nfunction prevMode() {\r\n  currentIndex.value = currentIndex.value === 0 ? 2 : currentIndex.value - 1\r\n}\r\nfunction nextMode() {\r\n  currentIndex.value = currentIndex.value === 2 ? 0 : currentIndex.value + 1\r\n}\r\nfunction selectMode(index) { currentIndex.value = index }\r\nfunction goBack() { router.back() }\r\nfunction enterCurrentMode() { router.push(currentMode.value.path) }\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  min-height: 100vh;\r\n  background: url(\"#{new URL('../imgs/Gamecover_1.png', import.meta.url).href}\") no-repeat center center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  font-size: 18px;\r\n  color: #fff;\r\n  cursor: pointer;\r\n  margin-bottom: 30px;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n.title {\r\n  text-align: center;\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 50px;\r\n  text-shadow: 0 2px 8px rgba(0,0,0,0.7);\r\n  letter-spacing: 4px;\r\n}\r\n\r\n.carousel-container {\r\n  position: relative;\r\n  width: 960px;\r\n  height: 480px;\r\n  overflow: hidden;\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.carousel-track {\r\n  display: flex;\r\n  gap: 20px; /* 直接写死数值，解决报错 */\r\n  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);\r\n  position: absolute;\r\n  left: 0;\r\n}\r\n\r\n.mode-card {\r\n  width: 320px;\r\n  height: 420px;\r\n  flex-shrink: 0;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  opacity: 0.6;\r\n  transform: scale(0.9);\r\n  transition: all 0.4s ease;\r\n  cursor: pointer;\r\n}\r\n\r\n.mode-card.active {\r\n  opacity: 1;\r\n  transform: scale(1.05);\r\n  z-index: 10;\r\n}\r\n\r\n.mode-img {\r\n  width: 100%;\r\n  height: 360px;\r\n  object-fit: cover;\r\n  border-radius: 16px;\r\n  box-shadow: 0 8px 24px rgba(0,0,0,0.5);\r\n}\r\n\r\n.mode-name {\r\n  margin-top: 16px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  text-shadow: 0 2px 6px rgba(0,0,0,0.8);\r\n  letter-spacing: 2px;\r\n}\r\n\r\n.arrow-btn {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 56px;\r\n  height: 56px;\r\n  border-radius: 50%;\r\n  border: 2px solid rgba(255,255,255,0.8);\r\n  background: rgba(0,0,0,0.3);\r\n  color: #fff;\r\n  font-size: 24px;\r\n  cursor: pointer;\r\n  z-index: 20;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.arrow-btn:hover {\r\n  background: rgba(192, 57, 43, 0.8);\r\n  border-color: #fff;\r\n  transform: translateY(-50%) scale(1.1);\r\n}\r\n\r\n.left-arrow { left: 20px; }\r\n.right-arrow { right: 20px; }\r\n\r\n.enter-btn {\r\n  padding: 16px 60px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n  font-weight: bold;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 16px rgba(0,0,0,0.4);\r\n}\r\n\r\n.enter-btn:hover {\r\n  background: #e74c3c;\r\n  transform: translateY(-2px);\r\n}\r\n</style>"],"mappings":";;;;AAuCA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,QAAQ,YAAY;AAYtC,MAAMC,SAAS,GAAG,GAAG,EAAC;;AAEtB;;;;;;;;IAZA,MAAMC,MAAM,GAAGF,SAAS,CAAC,CAAC;;IAE1B;IACA,MAAMG,QAAQ,GAAGL,GAAG,CAAC,CACnB;MAAEM,IA