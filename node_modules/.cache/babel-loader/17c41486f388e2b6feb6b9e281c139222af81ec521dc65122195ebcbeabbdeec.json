{\n    class: \"fake-btn\"\n  }, \"➖\")])], -1 /* CACHED */)), _createCommentVNode(\" 2. 功能覆盖层 (上层 UI) \"), _createElementVNode(\"div\", _hoisted_2, [_createCommentVNode(\" 顶部搜索/标题栏 (可选，根据第二张图似乎没有明显的顶部栏，这里做透明处理或留白) \"), _cache[6] || (_cache[6] = _createElementVNode(\"div\", {\n    class: \"top-bar-placeholder\"\n  }, null, -1 /* CACHED */)), _createCommentVNode(\" 底部信息面板 (核心复刻区域) \"), _createElementVNode(\"div\", _hoisted_3, [_createElementVNode(\"div\", _hoisted_4, [_createCommentVNode(\" 第一部分：统计数据 \"), _createElementVNode(\"div\", _hoisted_5, [_cache[4] || (_cache[4] = _createStaticVNode(\"<div class=\\\"stat-item main-stat\\\" data-v-3d1655c5><div class=\\\"stat-label\\\" data-v-3d1655c5>总计距离 <span class=\\\"sub-text\\\" data-v-3d1655c5>DISTANCE</span></div><div class=\\\"stat-value\\\" data-v-3d1655c5>14<span class=\\\"unit\\\" data-v-3d1655c5>km</span></div></div><div class=\\\"stat-divider\\\" data-v-3d1655c5></div><div class=\\\"stat-list\\\" data-v-3d1655c5><div class=\\\"list-row\\\" data-v-3d1655c5><span class=\\\"key\\\" data-v-3d1655c5>途径地点</span><span class=\\\"val\\\" data-v-3d1655c5>燊海井 / 105厂</span></div><div class=\\\"list-row\\\" data-v-3d1655c5><span class=\\\"key\\\" data-v-3d1655c5>预计行程时间</span><span class=\\\"val\\\" data-v-3d1655c5>2 小时 25 分</span></div><div class=\\\"list-row\\\" data-v-3d1655c5><span class=\\\"key\\\" data-v-3d1655c5>餐饮计划</span><span class=\\\"val highlight\\\" data-v-3d1655c5>105号肥肠馆 📞</span></div></div>\", 3)), _createElementVNode(\"div\", _hoisted_6, [_cache[3] || (_cache[3] = _createElementVNode(\"div\", {\n    class: \"badge\"\n  }, \"推荐最优\", -1 /* CACHED */)), _createElementVNode(\"button\", {\n    class: \"refresh-btn\",\n    onClick: _cache[0] || (_cache[0] = (...args) => $options.handleRefresh && $options.handleRefresh(...args))\n  }, [...(_cache[2] || (_cache[2] = [_createElementVNode(\"span\", {\n    class: \"icon\"\n  }, \"🔄\", -1 /* CACHED */), _createElementVNode(\"span\", {\n    class: \"text\"\n  }, \"立即更换\", -1 /* CACHED */)]))])])]), _createCommentVNode(\" 第二部分：交通方式选择 \"), _createElementVNode(\"div\", _hoisted_7, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.transports, mode => {\n    return _openBlock(), _createElementBlock(\"button\", {\n      key: mode.type,\n      class: _normalizeClass(['t-btn', {\n        active: $data.currentTransport === mode.type\n      }]),\n      onClick: $event => $data.currentTransport = mode.type\n    }, [_createElementVNode(\"div\", _hoisted_9, _toDisplayString(mode.icon), 1 /* TEXT */), _createElementVNode(\"div\", _hoisted_10, _toDisplayString(mode.name), 1 /* TEXT */)], 10 /* CLASS, PROPS */, _hoisted_8);\n  }), 128 /* KEYED_FRAGMENT */))]), _createCommentVNode(\" 第三部分：底部大按钮 \"), _createElementVNode(\"button\", {\n    class: \"action-button\",\n    onClick: _cache[1] || (_cache[1] = (...args) => $options.handleStart && $options.handleStart(...args))\n  }, [...(_cache[5] || (_cache[5] = [_createElementVNode(\"span\", {\n    class: \"flower-icon\"\n  }, \"❀\", -1 /* CACHED */), _createTextVNode(\" 选定并开始导航 \", -1 /* CACHED */)]))])])])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createCommentVNode","_createElementVNode","src","alt","viewBox","preserveAspectRatio","id","x1","y1","x2","y2","offset","style","x","y","width","height","in","stdDeviation","dx","dy","result","type","slope","d","stroke","fill","filter","transform","r","xmlns","_hoisted_2","_hoisted_3","_hoisted_4","_hoisted_5","_hoisted_6","onClick","_cache","args","$options","handleRefresh","_hoisted_7","_Fragment","_renderList","$data","transports","mode","key","_normalizeClass","active","currentTransport","$event","_hoisted_9","_toDisplayString","icon","_hoisted_10","name","handleStart"],"sources":["E:\\jiangjie-museum\\GitHub\\jiangjie-museum\\src\\views\\BeautifulMap.vue"],"sourcesContent":["<template>\r\n  <div class=\"map-page-wrapper\">\r\n    \r\n    <!-- 1. 背景地图层 (最下层) -->\r\n    <div class=\"map-background-layer\">\r\n      <!-- 替换为你的第一张背景图 -->\r\n      <img \r\n        src=\"https://images.unsplash.com/photo-1524661135-423995f22d0b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1748&q=80\" \r\n        alt=\"Map Background\" \r\n        class=\"map-bg-image\"\r\n      />\r\n      \r\n      <!-- SVG 路线绘制层 (覆盖在背景图上) -->\r\n      <svg class=\"route-svg-overlay\" viewBox=\"0 0 1000 1000\" preserveAspectRatio=\"xMidYMid slice\">\r\n        <defs>\r\n          <!-- 绿色渐变线条 -->\r\n          <linearGradient id=\"routeGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\r\n            <stop offset=\"0%\" style=\"stop-color:#4CAF50;stop-opacity:1\" />\r\n            <stop offset=\"100%\" style=\"stop-color:#8BC34A;stop-opacity:1\" />\r\n          </linearGradient>\r\n          <!-- 阴影滤镜 -->\r\n          <filter id=\"dropShadow\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\r\n            <feGaussianBlur in=\"SourceAlpha\" stdDeviation=\"3\"/>\r\n            <feOffset dx=\"2\" dy=\"2\" result=\"offsetblur\"/>\r\n            <feComponentTransfer>\r\n              <feFuncA type=\"linear\" slope=\"0.5\"/>\r\n            </feComponentTransfer>\r\n            <feMerge>\r\n              <feMergeNode/>\r\n              <feMergeNode in=\"SourceGraphic\"/>\r\n            </feMerge>\r\n          </filter>\r\n        </defs>\r\n\r\n        <!-- 动态虚线路径 -->\r\n        <path \r\n          class=\"animated-route\"\r\n          d=\"M 150 850 Q 300 700 400 650 T 600 500 T 750 300 T 850 150\" \r\n          stroke=\"url(#routeGradient)\" \r\n          stroke-width=\"8\" \r\n          fill=\"none\" \r\n          stroke-linecap=\"round\" \r\n          stroke-dasharray=\"20, 15\"\r\n          filter=\"url(#dropShadow)\"\r\n        />\r\n        \r\n        <!-- 起点标记 (对应图片左下角) -->\r\n        <g class=\"marker-group\" transform=\"translate(150, 850)\">\r\n          <circle r=\"12\" fill=\"#FF5722\" stroke=\"#fff\" stroke-width=\"3\" filter=\"url(#dropShadow)\"/>\r\n          <text y=\"-20\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"bold\" fill=\"#333\" stroke=\"#fff\" stroke-width=\"0.5\">起点</text>\r\n          <text y=\"35\" text-anchor=\"middle\" font-size=\"12\" fill=\"#555\">江姐故里</text>\r\n        </g>\r\n\r\n        <!-- 终点标记 (对应图片右上角) -->\r\n        <g class=\"marker-group\" transform=\"translate(850, 150)\">\r\n          <circle r=\"12\" fill=\"#2196F3\" stroke=\"#fff\" stroke-width=\"3\" filter=\"url(#dropShadow)\"/>\r\n          <text y=\"-20\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"bold\" fill=\"#333\" stroke=\"#fff\" stroke-width=\"0.5\">终点</text>\r\n          <text y=\"35\" text-anchor=\"middle\" font-size=\"12\" fill=\"#555\">东锅厂</text>\r\n        </g>\r\n\r\n        <!-- 途经点气泡 (带图片) - 点1 -->\r\n        <foreignObject x=\"380\" y=\"610\" width=\"90\" height=\"110\" class=\"spot-bubble\">\r\n          <div xmlns=\"http://www.w3.org/1999/xhtml\" class=\"bubble-content\">\r\n            <div class=\"bubble-img\" style=\"background-image: url('https://images.unsplash.com/photo-1542640244-7e67286feb8f?w=200');\"></div>\r\n            <div class=\"bubble-label\">燊海井</div>\r\n          </div>\r\n        </foreignObject>\r\n\r\n        <!-- 途经点气泡 - 点2 -->\r\n        <foreignObject x=\"580\" y=\"460\" width=\"90\" height=\"110\" class=\"spot-bubble\">\r\n          <div xmlns=\"http://www.w3.org/1999/xhtml\" class=\"bubble-content\">\r\n            <div class=\"bubble-img\" style=\"background-image: url('https://images.unsplash.com/photo-1565060169269-4c1b1c840273?w=200');\"></div>\r\n            <div class=\"bubble-label\">105 厂</div>\r\n          </div>\r\n        </foreignObject>\r\n      </svg>\r\n\r\n      <!-- 模拟地图控件 (装饰用) -->\r\n      <div class=\"fake-map-controls\">\r\n        <button class=\"fake-btn\">➕</button>\r\n        <button class=\"fake-btn\">➖</button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 2. 功能覆盖层 (上层 UI) -->\r\n    <div class=\"ui-overlay-layer\">\r\n      \r\n      <!-- 顶部搜索/标题栏 (可选，根据第二张图似乎没有明显的顶部栏，这里做透明处理或留白) -->\r\n      <div class=\"top-bar-placeholder\"></div>\r\n\r\n      <!-- 底部信息面板 (核心复刻区域) -->\r\n      <div class=\"bottom-panel\">\r\n        <div class=\"panel-inner\">\r\n          \r\n          <!-- 第一部分：统计数据 -->\r\n          <div class=\"stats-row\">\r\n            <div class=\"stat-item main-stat\">\r\n              <div class=\"stat-label\">总计距离 <span class=\"sub-text\">DISTANCE</span></div>\r\n              <div class=\"stat-value\">14<span class=\"unit\">km</span></div>\r\n            </div>\r\n            \r\n            <div class=\"stat-divider\"></div>\r\n            \r\n            <div class=\"stat-list\">\r\n              <div class=\"list-row\">\r\n                <span class=\"key\">途径地点</span>\r\n                <span class=\"val\">燊海井 / 105厂</span>\r\n              </div>\r\n              <div class=\"list-row\">\r\n                <span class=\"key\">预计行程时间</span>\r\n                <span class=\"val\">2 小时 25 分</span>\r\n              </div>\r\n              <div class=\"list-row\">\r\n                <span class=\"key\">餐饮计划</span>\r\n                <span class=\"val highlight\">105号肥肠馆 📞</span>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"recommend-box\">\r\n              <div class=\"badge\">推荐最优</div>\r\n              <button class=\"refresh-btn\" @click=\"handleRefresh\">\r\n                <span class=\"icon\">🔄</span>\r\n                <span class=\"text\">立即更换</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n\r\n          <!-- 第二部分：交通方式选择 -->\r\n          <div class=\"transport-bar\">\r\n            <button \r\n              v-for=\"mode in transports\" \r\n              :key=\"mode.type\"\r\n              :class=\"['t-btn', { active: currentTransport === mode.type }]\"\r\n              @click=\"currentTransport = mode.type\"\r\n            >\r\n              <div class=\"t-icon\">{{ mode.icon }}</div>\r\n              <div class=\"t-name\">{{ mode.name }}</div>\r\n            </button>\r\n          </div>\r\n\r\n          <!-- 第三部分：底部大按钮 -->\r\n          <button class=\"action-button\" @click=\"handleStart\">\r\n            <span class=\"flower-icon\">❀</span>\r\n            选定并开始导航\r\n          </button>\r\n\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'StaticMapNav',\r\n  data() {\r\n    return {\r\n      currentTransport: 'bus',\r\n      transports: [\r\n        { type: 'car', icon: '🚗', name: '驾车' },\r\n        { type: 'bus', icon: '🚌', name: '公交' },\r\n        { type: 'bike', icon: '🚲', name: '骑行' },\r\n        { type: 'walk', icon: '🚶', name: '步行' }\r\n      ]\r\n    };\r\n  },\r\n  methods: {\r\n    handleRefresh() {\r\n      // 模拟刷新动画\r\n      const btn = document.querySelector('.refresh-btn');\r\n      if(btn) {\r\n        btn.style.transform = 'rotate(360deg)';\r\n        setTimeout(() => btn.style.transform = 'none', 500);\r\n      }\r\n      alert('正在为您重新规划更优路线...');\r\n    },\r\n    handleStart() {\r\n      const mode = this.transports.find(t => t.type === this.currentTransport)?.name;\r\n      alert(`✅ 已选定【${mode}】方案\\n开始导航：江姐故里 → 东锅厂`);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* ========== 变量定义 ========== */\r\n:root {\r\n  --primary-green: #4CAF50;\r\n  --accent-orange: #FF9800;\r\n  --text-dark: #333333;\r\n  --text-gray: #888888;\r\n  --bg-panel: #FFFFFF;\r\n  --shadow-soft: 0 -10px 40px rgba(0,0,0,0.1);\r\n}\r\n\r\n/* ========== 整体布局 ========== */\r\n.map-page-wrapper {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 100vh;\r\n  overflow: hidden;\r\n  font-family: -apple-system, BlinkMacSystemFont, \"Microsoft YaHei\", sans-serif;\r\n  background: #f0f0f0;\r\n}\r\n\r\n/* ========== 1. 背景地图层 ========== */\r\n.map-background-layer {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  z-index: 1;\r\n  background: #f5f5dc; /* 备用米黄色 */\r\n}\r\n\r\n.map-bg-image