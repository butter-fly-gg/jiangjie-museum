\\AAA红梅\\江姐博物馆\\jiangjie-museum\\src\\views\\ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <!-- 返回按钮 -->\r\n    <div class=\"back-bar\" @click=\"goBack\">\r\n      ← 返回\r\n    </div>\r\n\r\n    <!-- 标题 -->\r\n    <h2 class=\"title\">选择参观模式</h2>\r\n\r\n    <!-- 模式选择 -->\r\n    <div class=\"mode-list\">\r\n      <div \r\n        class=\"mode-item\" \r\n        :class=\"{ active: current === index }\"\r\n        v-for=\"(item, index) in modeList\" \r\n        :key=\"index\"\r\n        @click=\"select(index)\"\r\n      >\r\n        <h3>{{ item.name }}</h3>\r\n        <p>{{ item.desc }}</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 进入按钮 -->\r\n    <button class=\"enter-btn\" @click=\"enterMode\">\r\n      进入当前模式\r\n    </button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nconst router = useRouter()\r\n\r\n// 模式数据\r\nconst modeList = ref([\r\n  {\r\n    name: \"故事模式\",\r\n    desc: \"沉浸式讲述江姐革命事迹\",\r\n    path: \"/story\"\r\n  },\r\n  {\r\n    name: \"互动模式\",\r\n    desc: \"趣味问答，学习红色知识\",\r\n    path: \"/interactive\"\r\n  },\r\n  {\r\n    name: \"卷轴模式\",\r\n    desc: \"长卷浏览，一览生平历程\",\r\n    path: \"/scroll\"\r\n  }\r\n])\r\n\r\n// 当前选中\r\nconst current = ref(0)\r\n\r\n// 选择\r\nfunction select(index) {\r\n  current.value = index\r\n}\r\n\r\n// 返回\r\nfunction goBack() {\r\n  router.back()\r\n}\r\n\r\n// 进入模式\r\nfunction enterMode() {\r\n  const target = modeList.value[current.value]\r\n  alert(\"即将进入：\" + target.name)\r\n  router.push(target.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 关键修复：使用你现有的图片资源路径 */\r\n.mode-page {\r\n  padding: 20px;\r\n  min-height: 100vh;\r\n  /* 这里使用你assets/imgs下的背景图，例如(红梅).png */\r\n  background: url(\"/src/imgs/1（红梅）.png\") no-repeat center center;\r\n  background-size: cover;\r\n  background-color: #fdf3f2; /* 备用背景色 */\r\n}\r\n\r\n.back-bar {\r\n  font-size: 16px;\r\n  color: #c0392b;\r\n  cursor: pointer;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.title {\r\n  text-align: center;\r\n  color: #c0392b;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.mode-list {\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.mode-item {\r\n  background: white;\r\n  padding: 20px;\r\n  border-radius: 12px;\r\n  margin-bottom: 12px;\r\n  border: 2px solid transparent;\r\n  cursor: pointer;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.1);\r\n}\r\n\r\n.mode-item.active {\r\n  border-color: #c0392b;\r\n  background: #fdf3f2;\r\n}\r\n\r\n.mode-item h3 {\r\n  margin: 0 0 8px 0;\r\n  color: #333;\r\n}\r\n\r\n.mode-item p {\r\n  margin: 0;\r\n  color: #666;\r\n  font-size: 14px;\r\n}\r\n\r\n.enter-btn {\r\n  width: 100%;\r\n  padding: 14px;\r\n  background: #c0392b;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 16px;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAW;;EAUfA,KAAK,EAAC;AAAW;;;uBAVxBC,mBAAA,CA2BM,OA3BNC,UA2BM,GA1BJC,mBAAA,UAAa,EACbC,mBAAA,CAEM;IAFDJ,KAAK,EAAC,UAAU;IAAEK,OAAK,EAAEC,MAAA,CAAAC;KAAQ,QAEtC,GAEAJ,mBAAA,QAAW,E,0BACXC,mBAAA,CAA6B;IAAzBJ,KAAK,EAAC;EAAO,GAAC,QAAM,qBAExBG,mBAAA,UAAa,EACbC,mBAAA,CAWM,OAXNI,UAWM,I,kBAVJP,mBAAA,CASMQ,SAAA,QAAAC,WAAA,CANoBJ,MAAA,CAAAK,QAAQ,GAAxBC,IAAI,EAAEC,KAAK;yBAHrBZ,mBAAA,CASM;MARJD,KAAK,EAAAc,eAAA,EAAC,WAAW;QAAAC,MAAA,EACCT,MAAA,CAAAU,OAAO,KAAKH;MAAK;MAElCI,GAAG,EAAEJ,KAAK;MACVR,OAAK,EAAAa,MAAA,IAAEZ,MAAA,CAAAa,MAAM,CAACN,KAAK;QAEpBT,mBAAA,CAAwB,YAAAgB,gBAAA,CAAjBR,IAAI,CAACS,IAAI,kBAChBjB,mBAAA,CAAsB,WAAAgB,gBAAA,CAAhBR,IAAI,CAACU,IAAI,iB;oCAInBnB,mBAAA,UAAa,EACbC,mBAAA,CAES;IAFDJ,KAAK,EAAC,WAAW;IAAEK,OAAK,EAAEC,MAAA,CAAAiB;KAAW,UAE7C,E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}