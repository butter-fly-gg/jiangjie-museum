n  }, null, -1 /* CACHED */))], 512 /* NEED_PATCH */)]), _createCommentVNode(\" 4. 月份选择弹窗 \"), _createVNode(_Transition, {\n    name: \"fade\"\n  }, {\n    default: _withCtx(() => [$setup.showPicker ? (_openBlock(), _createElementBlock(\"div\", {\n      key: 0,\n      class: \"picker-modal-mask\",\n      onClick: _cache[3] || (_cache[3] = _withModifiers($event => $setup.showPicker = false, [\"self\"]))\n    }, [_createElementVNode(\"div\", _hoisted_8, [_createElementVNode(\"div\", _hoisted_9, [_cache[8] || (_cache[8] = _createElementVNode(\"h3\", null, \"选择日期\", -1 /* CACHED */)), _createElementVNode(\"button\", {\n      class: \"close-btn\",\n      onClick: _cache[0] || (_cache[0] = $event => $setup.showPicker = false)\n    }, \"×\")]), _createElementVNode(\"div\", _hoisted_10, [_createElementVNode(\"button\", {\n      onClick: _cache[1] || (_cache[1] = $event => $setup.pickerYear--)\n    }, \"‹\"), _createElementVNode(\"span\", _hoisted_11, _toDisplayString($setup.pickerYear) + \"年\", 1 /* TEXT */), _createElementVNode(\"button\", {\n      onClick: _cache[2] || (_cache[2] = $event => $setup.pickerYear++)\n    }, \"›\")]), _createElementVNode(\"div\", _hoisted_12, [_createCommentVNode(\" 修复点 2: m 变量现在被正确使用了 \"), (_openBlock(), _createElementBlock(_Fragment, null, _renderList(12, m => {\n      return _createElementVNode(\"div\", {\n        key: m,\n        class: _normalizeClass([\"picker-month-item\", {\n          active: $setup.selectedDate === `${$setup.pickerYear}-${String(m).padStart(2, '0')}`,\n          disabled: $setup.isPastMonth($setup.pickerYear, m)\n        }]),\n        onClick: $event => $setup.confirmSelect($setup.pickerYear, m)\n      }, _toDisplayString(m) + \"月 \", 11 /* TEXT, CLASS, PROPS */, _hoisted_13);\n    }), 64 /* STABLE_FRAGMENT */))])])])) : _createCommentVNode(\"v-if\", true)]),\n    _: 1 /* STABLE */\n  }), _createCommentVNode(\" 5. 分类标签 \"), _createElementVNode(\"div\", _hoisted_14, [(_openBlock(), _createElementBlock(_Fragment, null, 