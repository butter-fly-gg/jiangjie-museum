{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport { ref, computed, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  __name: 'TravelVolunteer',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const goBack = () => {\n      router.push('/travel');\n    };\n\n    // === 日期数据与逻辑 ===\n    const dateList = ref([{\n      month: 1,\n      year: 2024,\n      value: '2024-01'\n    }, {\n      month: 9,\n      year: 2024,\n      value: '2024-09'\n    }, {\n      month: 10,\n      year: 2024,\n      value: '2024-10'\n    }, {\n      month: 11,\n      year: 2024,\n      value: '2024-11'\n    }, {\n      month: 12,\n      year: 2024,\n      value: '2024-12'\n    }, {\n      month: 1,\n      year: 2025,\n      value: '2025-01'\n    }]);\n\n    // 自动按年月排序\n    const sortedDateList = computed(() => {\n      return [...dateList.value].sort((a, b) => {\n        const dateA = new Date(a.year, a.month - 1);\n        const dateB = new Date(b.year, b.month - 1);\n        return dateA - dateB;\n      });\n    });\n    const selectedDate = ref('2024-09');\n    const selectDate = item => {\n      selectedDate.value = item.value;\n      console.log('切换到月份:', item.value);\n    };\n\n    // === 月份选择弹窗逻辑 ===\n    const showMonthPicker = ref(false);\n    const currentPickerYear = ref(new Date().getFullYear());\n    const isMonthDisabled = (year, month) => {\n      // 示例：禁用过去月份（可根据业务调整）\n      const now = new Date();\n      if (year < now.getFullYear()) return true;\n      if (year === now.getFullYear() && month <= now.getMonth() + 1) return true;\n      return false;\n    };\n    const selectMonthFromPicker = (year, month) => {\n      if (isMonthDisabled(year, month)) return;\n      const value = `${year}-${String(month).padStart(2, '0')}`;\n      selectedDate.value = value;\n      showMonthPicker.value = false;\n\n      // 可选：如果该月份不在当前列表中，可以动态添加\n      const exists = dateList.value.some(d => d.value === value);\n      if (!exists) {\n        dateList.value.push({\n          month,\n          year,\n          value\n        });\n      }\n    };\n\n    // === 其他原有逻辑 ===\n    const tabList = ['全部', '进行中', '已结束', '即将开放'];\n    const currentTab = ref('全部');\n    const getStatusClass = status => {\n      const classMap = {\n        '进行中': 'ongoing',\n        '已结束': 'ended',\n        '即将开放': 'coming'\n      };\n      return classMap[status] || '';\n    };\n    const getCountdownText = activity => {\n      if (activity.status === '已结束') return '活动已结束';\n      if (activity.status === '即将开放') {\n        const startDate = new Date(activity.startDate);\n        return `${startDate.getMonth() + 1}月${startDate.getDate()}日 开始`;\n      }\n      return '活动进行中';\n    };\n    const getButtonText = status => {\n      const textMap = {\n        '进行中': '立即参与',\n        '已结束': '查看详情',\n        '即将开放': '敬请期待'\n      };\n      return textMap[status] || '详情';\n    };\n    const activities = ref([{\n      _id: 1,\n      title: '红色故事宣讲员招募',\n      status: '进行中',\n      image: 'https://images.unsplash.com/photo-1544531586-fde5298cdd40?q=80&w=1000&auto=format&fit=crop'\n    }, {\n      _id: 2,\n      title: '江姐生平事迹展志愿讲解',\n      status: '即将开放',\n      image: 'https://images.unsplash.com/photo-1513519245088-0e12902e5a38?q=80&w=1000&auto=format&fit=crop'\n    }]);\n    const joinActivity = async id => {\n      alert('参与活动 ID:' + id);\n    };\n    onMounted(() => {\n      // fetchActivities()\n    });\n    const __returned__ = {\n      router,\n      goBack,\n      dateList,\n      sortedDateList,\n      selectedDate,\n      selectDate,\n      showMonthPicker,\n      currentPickerYear,\n      isMonthDisabled,\n      selectMonthFromPicker,\n      tabList,\n      currentTab,\n      getStatusClass,\n      getCountdownText,\n      getButtonText,\n      activities,\n      joinActivity,\n      ref,\n      computed,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","useRouter","router","goBack","push","dateList","month","year","value","sortedDateList","sort","a","b","dateA","Date","dateB","selectedDate","selectDate","item","console","log","showMonthPicker","currentPickerYear","getFullYear","isMonthDisabled","now","getMonth","selectMonthFromPicker","String","padStart","exists","some","d","tabList","currentTab","getStatusClass","status","classMap","getCountdownText","activity","startDate","getDate","getButtonText","textMap","activities","_id","title","image","joinActivity","id","alert"],"sources":["F:/project/jiangjie-museum/src/views/TravelVolunteer.vue"],"sourcesContent":["<template>\r\n  <div class=\"travel-volunteer-page\">\r\n    <!-- 头部 -->\r\n    <header class=\"header\">\r\n      <div class=\"back-btn\" @click=\"goBack\">\r\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#333\" stroke-width=\"2\">\r\n          <path d=\"M19 12H5M12 19l-7-7l7-7\"/>\r\n        </svg>\r\n      </div>\r\n\r\n      <div class=\"location-info\">\r\n        <div class=\"location-label\">活动总览</div>\r\n        <div class=\"location-text\">江姐故里 <span class=\"arrow\">▼</span></div>\r\n      </div>\r\n\r\n      <div class=\"settings\">\r\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#333\" stroke-width=\"2\">\r\n          <circle cx=\"12\" cy=\"12\" r=\"3\"></circle>\r\n          <path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z\"></path>\r\n        </svg>\r\n      </div>\r\n    </header>\r\n\r\n    <!-- 横幅 -->\r\n    <div class=\"banner-card\">\r\n      <img \r\n        src=\"https://images.unsplash.com/photo-1548625361-ec8f3d7f6483?q=80&w=2070&auto=format&fit=crop\" \r\n        alt=\"那时春里\"\r\n        class=\"banner-img\"\r\n      />\r\n      <div class=\"banner-overlay\">\r\n        <h2 class=\"banner-title\">那时·春里</h2>\r\n        <p class=\"banner-subtitle\">沉浸式红色文化体验之旅</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 【核心】时间选择器 + 月历按钮 -->\r\n    <div class=\"date-section\">\r\n      <!-- 左侧月历按钮 -->\r\n      <div class=\"date-icon-box\" @click=\"showMonthPicker = true\">\r\n        <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c43e3a\" stroke-width=\"2\">\r\n          <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"></rect>\r\n          <line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"></line>\r\n          <line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"></line>\r\n          <line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"></line>\r\n        </svg>\r\n        <span class=\"date-label\">月历</span>\r\n      </div>\r\n\r\n      <!-- 右侧滚动月份列表 -->\r\n      <div class=\"date-scroll-wrapper\">\r\n        <div \r\n          v-for=\"(item, index) in sortedDateList\" \r\n          :key=\"index\"\r\n          class=\"date-card\"\r\n          :class=\"{ active: selectedDate === item.value }\"\r\n          @click=\"selectDate(item)\"\r\n        >\r\n          <div class=\"date-month\">{{ item.month }}月</div>\r\n          <div class=\"date-year-box\">\r\n            <span class=\"date-year\">{{ item.year }}</span>\r\n          </div>\r\n        </div>\r\n        <div style=\"width: 20px; flex-shrink: 0;\"></div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 【新增】月份选择弹窗 -->\r\n    <div v-if=\"showMonthPicker\" class=\"month-picker-modal\" @click.self=\"showMonthPicker = false\">\r\n      <div class=\"modal-content\">\r\n        <div class=\"modal-header\">\r\n          <h3>选择月份</h3>\r\n          <button class=\"close-btn\" @click=\"showMonthPicker = false\">×</button>\r\n        </div>\r\n        <div class=\"year-selector\">\r\n          <button @click=\"currentPickerYear--\">‹</button>\r\n          <span>{{ currentPickerYear }}年</span>\r\n          <button @click=\"currentPickerYear++\">›</button>\r\n        </div>\r\n        <div class=\"month-grid\">\r\n          <div \r\n            v-for=\"m in 12\" \r\n            :key=\"m\"\r\n            class=\"month-item\"\r\n            :class=\"{ \r\n              active: selectedDate === `${currentPickerYear}-${String(m).padStart(2, '0')}`,\r\n              disabled: isMonthDisabled(currentPickerYear, m)\r\n            }\"\r\n            @click=\"selectMonthFromPicker(currentPickerYear, m)\"\r\n          >\r\n            {{ m }}月\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 分类标签 -->\r\n    <div class=\"tabs\">\r\n      <div \r\n        v-for=\"tab in tabList\" \r\n        :key=\"tab\"\r\n        class=\"tab-item\"\r\n        :class=\"{ active: currentTab === tab }\"\r\n        @click=\"currentTab = tab\"\r\n      >\r\n        {{ tab }}\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 活动列表 -->\r\n    <div class=\"activity-list\">\r\n      <div class=\"activity-card\" v-for=\"activity in activities\" :key=\"activity._id\">\r\n        <span class=\"status-tag\" :class=\"getStatusClass(activity.status)\">{{ activity.status }}</span>\r\n        <img \r\n          :src=\"activity.image || 'https://via.placeholder.com/300x120'\" \r\n          :alt=\"activity.title\"\r\n          class=\"activity-img\"\r\n        />\r\n        <div class=\"activity-info\">\r\n          <div class=\"activity-title\">{{ activity.title }}</div>\r\n          <div class=\"countdown\">{{ getCountdownText(activity) }}</div>\r\n          <button \r\n            class=\"join-btn\" \r\n            :class=\"{ disabled: activity.status !== '进行中' }\"\r\n            :disabled=\"activity.status !== '进行中'\"\r\n            @click=\"joinActivity(activity._id)\"\r\n          >\r\n            {{ getButtonText(activity.status) }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n      \r\n      <div v-if=\"activities.length === 0\" class=\"empty-state\">\r\n        暂无相关活动\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nconst router = useRouter()\r\nconst goBack = () => {\r\n  router.push('/travel') \r\n}\r\n\r\n// === 日期数据与逻辑 ===\r\nconst dateList = ref([\r\n  { month: 1, year: 2024, value: '2024-01' },\r\n  { month: 9, year: 2024, value: '2024-09' },\r\n  { month: 10, year: 2024, value: '2024-10' },\r\n  { month: 11, year: 2024, value: '2024-11' },\r\n  { month: 12, year: 2024, value: '2024-12' },\r\n  { month: 1, year: 2025, value: '2025-01' },\r\n])\r\n\r\n// 自动按年月排序\r\nconst sortedDateList = computed(() => {\r\n  return [...dateList.value].sort((a, b) => {\r\n    const dateA = new Date(a.year, a.month - 1);\r\n    const dateB = new Date(b.year, b.month - 1);\r\n    return dateA - dateB;\r\n  });\r\n})\r\n\r\nconst selectedDate = ref('2024-09')\r\n\r\nconst selectDate = (item) => {\r\n  selectedDate.value = item.value\r\n  console.log('切换到月份:', item.value)\r\n}\r\n\r\n// === 月份选择弹窗逻辑 ===\r\nconst showMonthPicker = ref(false)\r\nconst currentPickerYear = ref(new Date().getFullYear())\r\n\r\nconst isMonthDisabled = (year, month) => {\r\n  // 示例：禁用过去月份（可根据业务调整）\r\n  const now = new Date();\r\n  if (year < now.getFullYear()) return true;\r\n  if (year === now.getFullYear() && month <= now.getMonth() + 1) return true;\r\n  return false;\r\n}\r\n\r\nconst selectMonthFromPicker = (year, month) => {\r\n  if (isMonthDisabled(year, month)) return;\r\n  const value = `${year}-${String(month).padStart(2, '0')}`;\r\n  selectedDate.value = value;\r\n  showMonthPicker.value = false;\r\n  \r\n  // 可选：如果该月份不在当前列表中，可以动态添加\r\n  const exists = dateList.value.some(d => d.value === value);\r\n  if (!exists) {\r\n    dateList.value.push({ month, year, value });\r\n  }\r\n}\r\n\r\n// === 其他原有逻辑 ===\r\nconst tabList = ['全部', '进行中', '已结束', '即将开放']\r\nconst currentTab = ref('全部')\r\n\r\nconst getStatusClass = (status) => {\r\n  const classMap = {\r\n    '进行中': 'ongoing',\r\n    '已结束': 'ended',\r\n    '即将开放': 'coming'\r\n  }\r\n  return classMap[status] || ''\r\n}\r\n\r\nconst getCountdownText = (activity) => {\r\n  if (activity.status === '已结束') return '活动已结束'\r\n  if (activity.status === '即将开放') {\r\n    const startDate = new Date(activity.startDate)\r\n    return `${startDate.getMonth()+1}月${startDate.getDate()}日 开始`\r\n  }\r\n  return '活动进行中'\r\n}\r\n\r\nconst getButtonText = (status) => {\r\n  const textMap = {\r\n    '进行中': '立即参与',\r\n    '已结束': '查看详情',\r\n    '即将开放': '敬请期待'\r\n  }\r\n  return textMap[status] || '详情'\r\n}\r\n\r\nconst activities = ref([\r\n  { _id: 1, title: '红色故事宣讲员招募', status: '进行中', image: 'https://images.unsplash.com/photo-1544531586-fde5298cdd40?q=80&w=1000&auto=format&fit=crop' },\r\n  { _id: 2, title: '江姐生平事迹展志愿讲解', status: '即将开放', image: 'https://images.unsplash.com/photo-1513519245088-0e12902e5a38?q=80&w=1000&auto=format&fit=crop' },\r\n])\r\n\r\nconst joinActivity = async (id) => {\r\n  alert('参与活动 ID:' + id)\r\n}\r\n\r\nonMounted(() => {\r\n  // fetchActivities()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n/* === 全局样式保持不变 === */\r\n.travel-volunteer-page {\r\n  min-height: 100vh;\r\n  background-color: #f9f5f0;\r\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\r\n  padding: 16px;\r\n  padding-bottom: 80px;\r\n}\r\n\r\n/* === 头部、横幅等样式略（同前）=== */\r\n\r\n/* === 时间选择器 === */\r\n.date-section {\r\n  display: flex;\r\n  align-items: center;\r\n  background: #fff;\r\n  border-radius: 16px;\r\n  padding: 12px;\r\n  margin-bottom: 16px;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.04);\r\n}\r\n\r\n.date-icon-box {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 50px;\r\n  border-right: 1px solid #eee;\r\n  margin-right: 12px;\r\n  padding-right: 12px;\r\n  flex-shrink: 0;\r\n  cursor: pointer;\r\n  transition: opacity 0.2s;\r\n}\r\n.date-icon-box:hover {\r\n  opacity: 0.7;\r\n}\r\n.date-icon-box svg {\r\n  margin-bottom: 4px;\r\n}\r\n.date-label {\r\n  font-size: 12px;\r\n  color: #999;\r\n}\r\n\r\n.date-scroll-wrapper {\r\n  display: flex;\r\n  gap: 12px;\r\n  overflow-x: auto;\r\n  -webkit-overflow-scrolling: touch;\r\n  padding: 4px 4px 8px 4px;\r\n  scrollbar-width: none;\r\n}\r\n.date-scroll-wrapper::-webkit-scrollbar {\r\n  display: none;\r\n}\r\n\r\n.date-card {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  flex-shrink: 0;\r\n  opacity: 0.6;\r\n  transform: scale(0.95);\r\n}\r\n.date-card.active {\r\n  opacity: 1;\r\n  transform: scale(1);\r\n}\r\n\r\n.date-month {\r\n  font-size: 13px;\r\n  color: #666;\r\n  margin-bottom: 6px;\r\n  font-weight: 500;\r\n}\r\n.date-card.active .date-month {\r\n  color: #c43e3a;\r\n  font-weight: bold;\r\n}\r\n\r\n.date-year-box {\r\n  background: #f5f5f5;\r\n  padding: 8px 16px;\r\n  border-radius: 8px;\r\n  transition: all 0.2s;\r\n}\r\n.date-card.active .date-year-box {\r\n  background: #c43e3a;\r\n  box-shadow: 0 4px 10px rgba(196, 62, 58, 0.3);\r\n}\r\n.date-year {\r\n  font-size: 16px;\r\n  font-weight: bold;\r\n  color: #333;\r\n  line-height: 1;\r\n}\r\n.date-card.active .date-year {\r\n  color: #fff;\r\n}\r\n\r\n/* === 月份选择弹窗 === */\r\n.month-picker-modal {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  background: rgba(0,0,0,0.5);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  z-index: 1000;\r\n  backdrop-filter: blur(4px);\r\n}\r\n\r\n.modal-content {\r\n  background: #fff;\r\n  border-radius: 16px;\r\n  padding: 20px;\r\n  width: 90%;\r\n  max-width: 320px;\r\n  box-shadow: 0 10px 30px rgba(0,0,0,0.2);\r\n}\r\n\r\n.modal-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n}\r\n.modal-header h3 {\r\n  margin: 0;\r\n  font-size: 18px;\r\n  color: #333;\r\n}\r\n.close-btn {\r\n  background: none;\r\n  border: none;\r\n  font-size: 24px;\r\n  color: #999;\r\n  cursor: pointer;\r\n  padding: 0;\r\n  line-height: 1;\r\n}\r\n\r\n.year-selector {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  gap: 16px;\r\n  margin-bottom: 16px;\r\n  font-weight: bold;\r\n  color: #333;\r\n}\r\n.year-selector button {\r\n  background: #f5f5f5;\r\n  border: none;\r\n  width: 32px;\r\n  height: 32px;\r\n  border-radius: 50%;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  color: #666;\r\n}\r\n\r\n.month-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(3, 1fr);\r\n  gap: 8px;\r\n}\r\n.month-item {\r\n  padding: 12px 0;\r\n  text-align: center;\r\n  background: #f5f5f5;\r\n  border-radius: 8px;\r\n  font-size: 14px;\r\n  color: #666;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n}\r\n.month-item.active {\r\n  background: #c43e3a;\r\n  color: white;\r\n  font-weight: bold;\r\n}\r\n.month-item.disabled {\r\n  opacity: 0.4;\r\n  cursor: not-allowed;\r\n  background: #eee;\r\n}\r\n\r\n/* === 其他样式略（同前）=== */\r\n</style>"],"mappings":";;;AA4IA,SA