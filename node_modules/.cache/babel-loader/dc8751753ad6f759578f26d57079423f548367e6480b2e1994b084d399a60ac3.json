{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed } from 'vue';\nimport { useRouter } from 'vue-router';\n\n// 🔑 关键：提前 import 图片，Vue 会自动处理路径\nimport storyImg from '../imgs/Game1.l.png';\nimport interactiveImg from '../imgs/Game1.m.png';\nimport scrollImg from '../imgs/Game1.r.png';\nexport default {\n  __name: 'ModeSelectView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const modeList = ref([{\n      name: '故事聆听模式',\n      img: storyImg,\n      // 直接用 import 进来的变量\n      path: '/story'\n    }, {\n      name: '现场交互模式',\n      img: interactiveImg,\n      path: '/interactive'\n    }, {\n      name: '线上绘卷模式',\n      img: scrollImg,\n      path: '/scroll'\n    }]);\n    const current = ref(1);\n    const pos = computed(() => {\n      return -current.value * 33.33;\n    });\n    const currentItem = computed(() => modeList.value[current.value]);\n    function prev() {\n      current.value = current.value === 0 ? 2 : current.value - 1;\n    }\n    function next() {\n      current.value = current.value === 2 ? 0 : current.value + 1;\n    }\n    function select(i) {\n      current.value = i;\n    }\n    function goBack() {\n      router.back();\n    }\n    function enter() {\n      router.push(currentItem.value.path);\n    }\n    const __returned__ = {\n      router,\n      modeList,\n      current,\n      pos,\n      currentItem,\n      prev,\n      next,\n      select,\n      goBack,\n      enter,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      },\n      get storyImg() {\n        return storyImg;\n      },\n      get interactiveImg() {\n        return interactiveImg;\n      },\n      get scrollImg() {\n        return scrollImg;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","storyImg","interactiveImg","scrollImg","router","modeList","name","img","path","current","pos","value","currentItem","prev","next","select","i","goBack","back","enter","push"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <div class=\"back-bar\" @click=\"goBack\">← 返回</div>\r\n\r\n    <h2 class=\"title\">—— 请选择您想体验的模式 ——</h2>\r\n\r\n    <div class=\"carousel-container\">\r\n      <div class=\"arrow left\" @click=\"prev\">❮</div>\r\n\r\n      <div class=\"carousel-track\" :style=\"{ transform: `translateX(${pos}%)` }\">\r\n        <div\r\n          class=\"mode-card\"\r\n          :class=\"{ active: current === index }\"\r\n          v-for=\"(item, index) in modeList\"\r\n          :key=\"index\"\r\n          @click=\"select(index)\"\r\n        >\r\n          <img class=\"mode-img\" :src=\"item.img\" />\r\n          <div class=\"label\">{{ item.name }}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"arrow right\" @click=\"next\">❯</div>\r\n    </div>\r\n\r\n    <button class=\"enter-btn\" @click=\"enter\">进入 {{ currentItem.name }}</button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\n// 🔑 关键：提前 import 图片，Vue 会自动处理路径\r\nimport storyImg from '../imgs/Game1.l.png'\r\nimport interactiveImg from '../imgs/Game1.m.png'\r\nimport scrollImg from '../imgs/Game1.r.png'\r\n\r\nconst router = useRouter()\r\n\r\nconst modeList = ref([\r\n  {\r\n    name: '故事聆听模式',\r\n    img: storyImg, // 直接用 import 进来的变量\r\n    path: '/story'\r\n  },\r\n  {\r\n    name: '现场交互模式',\r\n    img: interactiveImg,\r\n    path: '/interactive'\r\n  },\r\n  {\r\n    name: '线上绘卷模式',\r\n    img: scrollImg,\r\n    path: '/scroll'\r\n  },\r\n])\r\n\r\nconst current = ref(1)\r\n\r\nconst pos = computed(() => {\r\n  return -current.value * 33.33\r\n})\r\n\r\nconst currentItem = computed(() => modeList.value[current.value])\r\n\r\nfunction prev() {\r\n  current.value = current.value === 0 ? 2 : current.value - 1\r\n}\r\nfunction next() {\r\n  current.value = current.value === 2 ? 0 : current.value + 1\r\n}\r\nfunction select(i) {\r\n  current.value = i\r\n}\r\nfunction goBack() {\r\n  router.back()\r\n}\r\nfunction enter() {\r\n  router.push(currentItem.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background: url(../imgs/1（背景图）.png) no-repeat center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n\r\n.title {\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.carousel-container {\r\n  position: relative;\r\n  width: 100%;\r\n  max-width: 900px;\r\n  height: 460px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden;\r\n}\r\n\r\n.arrow {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 50px;\r\n  height: 50px;\r\n  background: rgba(255,255,255,0.2);\r\n  border: 2px solid #fff;\r\n  border-radius: 50%;\r\n  color: #fff;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  z-index: 10;\r\n}\r\n.arrow.left { left: 10px; }\r\n.arrow.right { right: 10px; }\r\n\r\n.carousel-track {\r\n  display: flex;\r\n  width: 300%;\r\n  transition: transform 0.5s ease;\r\n}\r\n\r\n.mode-card {\r\n  width: 33.333%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  opacity: 0.6;\r\n  transform: scale(0.9);\r\n  transition: all 0.4s ease;\r\n}\r\n.mode-card.active {\r\n  opacity: 1;\r\n  transform: scale(1);\r\n}\r\n\r\n.mode-img {\r\n  width: 280px;\r\n  height: 380px;\r\n  object-fit: cover;\r\n  border-radius: 16px;\r\n}\r\n\r\n.label {\r\n  margin-top: 12px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n}\r\n\r\n.enter-btn {\r\n  margin-top: 20px;\r\n  padding: 14px 50px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n}\r\n</style>"],"mappings":";AA8BA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,QAAQ,YAAY;;AAEtC;AACA,OAAOC,QAAQ,MAAM,qBAAqB;AAC1C,OAAOC,cAAc,MAAM,qBAAqB;AAChD,OAAOC,SAAS,MAAM,qBAAqB;;;;;;;IAE3C,MAAMC,MAAM,GAAGJ,SAAS,CAAC,CAAC;IAE1B,MAAMK,QAAQ,GAAGP,GAAG,CAAC,CACnB;MACEQ,IAAI,EAAE,QAAQ;MACdC,GAAG,EAAEN,QAAQ;MAAE;MACfO,IAAI,EAAE;IACR,CAAC,EACD;MACEF,IAAI,EAAE,QAAQ;MACdC,GAAG,EAAEL,cAAc;MACnBM,IAAI,EAAE;IACR,CAAC,EACD;MACEF,IAAI,EAAE,QAAQ;MACdC,GAAG,EAAEJ,SAAS;MACdK,IAAI,EAAE;IACR,CAAC,CACF,CAAC;IAEF,MAAMC,OAAO,GAAGX,GAAG,CAAC,CAAC,CAAC;IAEtB,MAAMY,GAAG,GAAGX,QAAQ,CAAC,MAAM;MACzB,OAAO,CAACU,OAAO,CAACE,KAAK,GAAG,KAAK;IAC/B,CAAC,CAAC;IAEF,MAAMC,WAAW,GAAGb,QAAQ,CAAC,MAAMM,QAAQ,CAACM,KAAK,CAACF,OAAO,CAACE,KAAK,CAAC,CAAC;IAEjE,SAASE,IAAIA,CAAA,EAAG;MACdJ,OAAO,CAACE,KAAK,GAAGF,OAAO,CAACE,KAAK,KAAK,CAAC,GAAG,CAAC,GAAGF,OAAO,CAACE,KAAK,GAAG,CAAC;IAC7D;IACA,SAASG,IAAIA,CAAA,EAAG;MACdL,OAAO,CAACE,KAAK,GAAGF,OAAO,CAACE,KAAK,KAAK,CAAC,GAAG,CAAC,GAAGF,OAAO,CAACE,KAAK,GAAG,CAAC;IAC7D;IACA,SAASI,MAAMA,CAACC,CAAC,EAAE;MACjBP,OAAO,CAACE,KAAK,GAAGK,CAAC;IACnB;IACA,SAASC,MAAMA,CAAA,EAAG;MAChBb,MAAM,CAACc,IAAI,CAAC,CAAC;IACf;IACA,SAASC,KAAKA,CAAA,EAAG;MACff,MAAM,CAACgB,IAAI,CAACR,WAAW,CAACD,KAAK,CAACH,IAAI,CAAC;IACrC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}