{"ast":null,"code":"import { createElementVNode as _createElementVNode, createCommentVNode as _createCommentVNode, renderList as _renderList, Fragment as _Fragment, openBlock as _openBlock, createElementBlock as _createElementBlock, toDisplayString as _toDisplayString, normalizeClass as _normalizeClass, normalizeStyle as _normalizeStyle } from \"vue\";\nconst _hoisted_1 = {\n  class: \"mode-page\"\n};\nconst _hoisted_2 = {\n  class: \"carousel-container\"\n};\nconst _hoisted_3 = [\"onClick\"];\nconst _hoisted_4 = [\"src\"];\nconst _hoisted_5 = {\n  class: \"label\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createElementVNode(\"div\", {\n    class: \"back-bar\",\n    onClick: $setup.goBack\n  }, \"← 返回\"), _cache[0] || (_cache[0] = _createElementVNode(\"h2\", {\n    class: \"title\"\n  }, \"—— 请选择您想体验的模式 ——\", -1 /* CACHED */)), _createCommentVNode(\" 🔑  carousel-container 是视口，必须 overflow: hidden \"), _createElementVNode(\"div\", _hoisted_2, [_createElementVNode(\"div\", {\n    class: \"arrow left\",\n    onClick: $setup.prev\n  }, \"❮\"), _createCommentVNode(\" 🔑   track 承载所有卡片，宽度是 300%，位移通过 translateX 控制 \"), _createElementVNode(\"div\", {\n    class: \"carousel-track\",\n    style: _normalizeStyle({\n      transform: `translateX(${$setup.pos}%)`\n    })\n  }, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.modeList, (item, index) => {\n    return _openBlock(), _createElementBlock(\"div\", {\n      class: _normalizeClass([\"mode-card\", {\n        active: $setup.current === index\n      }]),\n      key: index,\n      onClick: $event => $setup.select(index)\n    }, [_createElementVNode(\"img\", {\n      class: \"mode-img\",\n      src: item.img\n    }, null, 8 /* PROPS */, _hoisted_4), _createElementVNode(\"div\", _hoisted_5, _toDisplayString(item.name), 1 /* TEXT */)], 10 /* CLASS, PROPS */, _hoisted_3);\n  }), 128 /* KEYED_FRAGMENT */))], 4 /* STYLE */), _createElementVNode(\"div\", {\n    class: \"arrow right\",\n    onClick: $setup.next\n  }, \"❯\")]), _createElementVNode(\"button\", {\n    class: \"enter-btn\",\n    onClick: $setup.enter\n  }, \"进入 \" + _toDisplayString($setup.currentItem.name), 1 /* TEXT */)]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","onClick","$setup","goBack","_createCommentVNode","_hoisted_2","prev","style","_normalizeStyle","transform","pos","_Fragment","_renderList","modeList","item","index","_normalizeClass","active","current","key","$event","select","src","img","_hoisted_5","_toDisplayString","name","next","enter","currentItem"],"sources":["D:\\AAA红梅\\江姐博物馆\\jiangjie-museum\\src\\views\\ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <div class=\"back-bar\" @click=\"goBack\">← 返回</div>\r\n\r\n    <h2 class=\"title\">—— 请选择您想体验的模式 ——</h2>\r\n\r\n    <!-- 🔑  carousel-container 是视口，必须 overflow: hidden -->\r\n    <div class=\"carousel-container\">\r\n      <div class=\"arrow left\" @click=\"prev\">❮</div>\r\n\r\n      <!-- 🔑   track 承载所有卡片，宽度是 300%，位移通过 translateX 控制 -->\r\n      <div class=\"carousel-track\" :style=\"{ transform: `translateX(${pos}%)` }\">\r\n        <div\r\n          class=\"mode-card\"\r\n          :class=\"{ active: current === index }\"\r\n          v-for=\"(item, index) in modeList\"\r\n          :key=\"index\"\r\n          @click=\"select(index)\"\r\n        >\r\n          <img class=\"mode-img\" :src=\"item.img\" />\r\n          <div class=\"label\">{{ item.name }}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"arrow right\" @click=\"next\">❯</div>\r\n    </div>\r\n\r\n    <button class=\"enter-btn\" @click=\"enter\">进入 {{ currentItem.name }}</button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\n// 1. 导入图片（import 是最稳的方式）\r\nimport storyImg from '../imgs/Game1.l.png'\r\nimport interactiveImg from '../imgs/Game1.m.png'\r\nimport scrollImg from '../imgs/Game1.r.png'\r\n\r\nconst router = useRouter()\r\n\r\n// 2. 模式列表\r\nconst modeList = ref([\r\n  { name: '故事聆听模式', img: storyImg, path: '/story' },\r\n  { name: '现场交互模式', img: interactiveImg, path: '/interactive' },\r\n  { name: '线上绘卷模式', img: scrollImg, path: '/scroll' },\r\n])\r\n\r\n// 3. 核心逻辑：无缝循环\r\n// current 代表中间显示的卡片索引（0,1,2 循环）\r\nconst current = ref(1) \r\n\r\n// 4. 计算位移：33.33 * 索引 = 卡片居中\r\nconst pos = computed(() => {\r\n  return -current.value * 33.33\r\n})\r\n\r\nconst currentItem = computed(() => modeList.value[current.value])\r\n\r\n// 🔄 无缝循环算法\r\nfunction prev() {\r\n  // 上一张：如果当前是0(故事)，则切换到2(卷轴)，实现循环\r\n  current.value = current.value === 0 ? 2 : current.value - 1;\r\n}\r\n\r\nfunction next() {\r\n  // 下一张：如果当前是2(卷轴)，则切换到0(故事)，实现循环\r\n  current.value = current.value === 2 ? 0 : current.value + 1;\r\n}\r\n\r\nfunction select(i) {\r\n  current.value = i\r\n}\r\nfunction goBack() {\r\n  router.back()\r\n}\r\nfunction enter() {\r\n  router.push(currentItem.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  /* 背景图也用 import 进来的变量，确保路径正确 */\r\n  background: url(../imgs/Gamecover_1.png) no-repeat center center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n\r\n.title {\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 40px;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 🔑 关键样式 1：视口容器，溢出隐藏 */\r\n.carousel-container {\r\n  position: relative;\r\n  width: 100%;\r\n  max-width: 900px; /* 可以根据设计稿调整 */\r\n  height: 460px;   /* 卡片高度 */\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden; /* 必须加，只显示中间一张 */\r\n}\r\n\r\n/* 🔑 关键样式 2：箭头位置与美化 */\r\n.arrow {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 50px;\r\n  height: 50px;\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border: 2px solid #fff;\r\n  border-radius: 50%;\r\n  color: #fff;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  z-index: 10;\r\n  transition: all 0.3s;\r\n}\r\n.arrow:hover {\r\n  background: rgba(255, 255, 255, 0.4);\r\n}\r\n.arrow.left { left: 10px; }\r\n.arrow.right { right: 10px; }\r\n\r\n/* 🔑 关键样式 3：轨道宽度 300%，3张卡片并排 */\r\n.carousel-track {\r\n  display: flex;\r\n  width: 300%; /* 100% * 3 */\r\n  height: 100%;\r\n  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* 丝滑动画 */\r\n}\r\n\r\n/* 🔑 关键样式 4：每张卡片占 33.333%，保持连在一起 */\r\n.mode-card {\r\n  width: 33.333%; /* 平均分配 */\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  opacity: 0.7;\r\n  transform: scale(0.85); /* 初始缩小 */\r\n  transition: all 0.4s ease;\r\n  cursor: pointer;\r\n}\r\n\r\n/* 🔑 关键样式 5：中间选中状态，放大高亮 */\r\n.mode-card.active {\r\n  opacity: 1;\r\n  transform: scale(1); /* 中间卡片正常大小 */\r\n}\r\n\r\n.mode-img {\r\n  width: 100%;\r\n  height: 380px;\r\n  object-fit: cover;\r\n  border-radius: 16px;\r\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\r\n}\r\n\r\n.label {\r\n  margin-top: 12px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n.enter-btn {\r\n  margin-top: 20px;\r\n  padding: 14px 50px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 15px rgba(0,0,0,0.3);\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAW;;EAMfA,KAAK,EAAC;AAAoB;;;;EAapBA,KAAK,EAAC;AAAO;;uBAnB1BC,mBAAA,CA2BM,OA3BNC,UA2BM,GA1BJC,mBAAA,CAAgD;IAA3CH,KAAK,EAAC,UAAU;IAAEI,OAAK,EAAEC,MAAA,CAAAC;KAAQ,MAAI,G,0BAE1CH,mBAAA,CAAuC;IAAnCH,KAAK,EAAC;EAAO,GAAC,kBAAgB,qBAElCO,mBAAA,oDAAuD,EACvDJ,mBAAA,CAkBM,OAlBNK,UAkBM,GAjBJL,mBAAA,CAA6C;IAAxCH,KAAK,EAAC,YAAY;IAAEI,OAAK,EAAEC,MAAA,CAAAI;KAAM,GAAC,GAEvCF,mBAAA,mDAAsD,EACtDJ,mBAAA,CAWM;IAXDH,KAAK,EAAC,gBAAgB;IAAEU,KAAK,EAAAC,eAAA;MAAAC,SAAA,gBAA6BP,MAAA,CAAAQ,GAAG;IAAA;yBAChEZ,mBAAA,CASMa,SAAA,QAAAC,WAAA,CANoBV,MAAA,CAAAW,QAAQ,GAAxBC,IAAI,EAAEC,KAAK;yBAHrBjB,mBAAA,CASM;MARJD,KAAK,EAAAmB,eAAA,EAAC,WAAW;QAAAC,MAAA,EACCf,MAAA,CAAAgB,OAAO,KAAKH;MAAK;MAElCI,GAAG,EAAEJ,KAAK;MACVd,OAAK,EAAAmB,MAAA,IAAElB,MAAA,CAAAmB,MAAM,CAACN,KAAK;QAEpBf,mBAAA,CAAwC;MAAnCH,KAAK,EAAC,UAAU;MAAEyB,GAAG,EAAER,IAAI,CAACS;yCACjCvB,mBAAA,CAAwC,OAAxCwB,UAAwC,EAAAC,gBAAA,CAAlBX,IAAI,CAACY,IAAI,iB;mDAInC1B,mBAAA,CAA8C;IAAzCH,KAAK,EAAC,aAAa;IAAEI,OAAK,EAAEC,MAAA,CAAAyB;KAAM,GAAC,E,GAG1C3B,mBAAA,CAA2E;IAAnEH,KAAK,EAAC,WAAW;IAAEI,OAAK,EAAEC,MAAA,CAAA0B;KAAO,KAAG,GAAAH,gBAAA,CAAGvB,MAAA,CAAA2B,WAAW,CAACH,IAAI,iB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}