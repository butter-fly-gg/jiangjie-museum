  }\r\n  .menu-item {\r\n    padding: 28px 32px; /* 进一步增大菜单项内边距 */\r\n    font-size: 18px;\r\n  }\r\n  .menu-icon {\r\n    width: 28px;\r\n    height: 28px;\r\n  }\r\n}\r\n</style>"],"mappings":";OAIWA,UAAoB;OAKlBC,UAAoB;OAIpBC,UAA4B;;EAZlCC,KAAK,EAAC;AAAc;;EAElBA,KAAK,EAAC;AAAgB;;EAcpBA,KAAK,EAAC;AAAkB;;;EActBA,KAAK,EAAC;AAAa;;EACnBA,KAAK,EAAC;AAAK;;EAqBfA,KAAK,EAAC;AAAM;;EAOZA,KAAK,EAAC;AAAW;;;EAGZA,KAAK,EAAC;AAAY;;uBA9D9BC,mBAAA,CAkEM,OAlENC,UAkEM,GAjEJC,mBAAA,iBAAoB,EACpBC,mBAAA,CA+CM,OA/CNC,UA+CM,G,0BA9CJD,mBAAA,CAAsD;IAAjDE,GAAoB,EAApBT,UAAoB;IAACU,GAAG,EAAC,KAAK;IAACP,KAAK,EAAC;wDAC1CI,mBAAA,CAAkC;IAA7BJ,KAAK,EAAC;EAAgB,4BAE3BG,mBAAA,UAAa,E,0BACbC,mBAAA,CAEM;IAFDJ,KAAK,EAAC;EAAW,IACpBI,mBAAA,CAAoC;IAA/BE,GAAoB,EAApBR,UAAoB;IAACS,GAAG,EAAC;0BAEhCJ,mBAAA,UAAa,E,0BACbC,mBAAA,CAEM;IAFDJ,KAAK,EAAC;EAAU,IACnBI,mBAAA,CAA4C;IAAvCE,GAA4B,EAA5BP,UAA4B;IAACQ,GAAG,EAAC;0BAGxCJ,mBAAA,WAAc,EACdC,mBAAA,CAgBM,OAhBNI,UAgBM,GAfJJ,mBAAA,CAKM;IALDJ,KAAK,EAAC,gBAAgB;IAAES,OAAK,EAAEC,MAAA,CAAAC;MAClCP,mBAAA,CAA8C;IAAxCE,GAAG,EAAEI,MAAA,CAAAE,SAAS;IAAEL,GAAG,EAAC,IAAI;IAACP,KAAK,EAAC;iEACrCI,mBAAA,CAEM;IAFDJ,KAAK,EAAC;EAAgB,IACzBI,mBAAA,CAAiB,cAAX,MAAI,E,uBAGdA,mBAAA,CAMC;IALCS,GAAG,EAAC,WAAW;IACfC,IAAI,EAAC,MAAM;IACXC,MAAM,EAAC,SAAS;IAChBC,KAAqB,EAArB;MAAA;IAAA,CAAqB;IACpBC,QAAM,EAAEP,MAAA,CAAAQ;kDAEXd,mBAAA,CAAmF,OAAnFe,UAAmF,EAAAC,gBAAA,CAAvDV,MAAA,CAAAW,QAAQ,CAACC,QAAQ,IAAIZ,MAAA,CAAAW,QAAQ,CAACE,QAAQ,0BAClEnB,mBAAA,CAAwD,OAAxDoB,UAAwD,EAAvC,MAAI,GAAAJ,gBAAA,CAAGV,MAAA,CAAAW,QAAQ,CAACI,EAAE,6B,GAGrCtB,mBAAA,UAAa,E,8iBAiBfA,mBAAA,WAAc,EACdC,mBAAA,CAIM,OAJNsB,UAIM,GAHJtB,mBAAA,CAAoE;IAA/DJ,KAAK,EAAC,iBAAiB;IAAES,OAAK,EAAAkB,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAElB,MAAA,CAAAmB,SAAS;KAAc,IAAE,GAC9DzB,mBAAA,CAA4D;IAAvDJ,KAAK,EAAC,UAAU;IAAES,OAAK,EAAAkB,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAElB,MAAA,CAAAmB,SAAS;KAAa,IAAE,GACtDzB,mBAAA,CAAyD;IAApDJ,KAAK,EAAC,UAAU;IAAES,OAAK,EAAAkB,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAElB,MAAA,CAAAmB,SAAS;KAAU,IAAE,E,GAGrD1B,mBAAA,WAAc,EACdC,mBAAA,CAMM,OANN0B,UAMM,I,kBALJ7B