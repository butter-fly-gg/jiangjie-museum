{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRoute, useRouter } from 'vue-router';\nimport { reservationAPI } from '../api/index';\nexport default {\n  __name: 'MineBook_1',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const route = useRoute();\n    const router = useRouter();\n    const reservation = ref(null);\n    const refreshing = ref(false);\n    const canceling = ref(false);\n    const reservationId = route.query.reservationId; // 从预约页传入的预约ID\n\n    const fetchReservationDetail = async () => {\n      if (!reservationId) {\n        alert('缺少预约ID，无法查看详情');\n        router.back();\n        return;\n      }\n      try {\n        console.log('正在获取预约详情，ID:', reservationId);\n        const res = await reservationAPI.getReservationDetail(reservationId);\n        console.log('预约详情响应:', res);\n        if (res && res.code === 200) {\n          reservation.value = res.data;\n        } else {\n          alert(res?.message || '获取预约详情失败');\n        }\n      } catch (e) {\n        console.error('获取预约详情失败:', e);\n        alert('获取预约详情失败: ' + (e.message || '未知错误'));\n      }\n    };\n    const refreshQrcode = async () => {\n      refreshing.value = true;\n      await fetchReservationDetail();\n      refreshing.value = false;\n    };\n    const cancelBooking = async () => {\n      if (canceling.value) return;\n      if (!confirm('确定要取消本次预约吗？')) return;\n      canceling.value = true;\n      try {\n        const res = await reservationAPI.cancelReservation(reservationId);\n        if (res && res.code === 200) {\n          alert('预约已取消');\n          router.push('/mine/book');\n        } else {\n          alert(res?.message || '取消失败');\n        }\n      } catch (e) {\n        alert('取消失败');\n      } finally {\n        canceling.value = false;\n      }\n    };\n\n    // 格式化日期显示（假设visitDate是\"2024-10-04\"形式）\n    const formatDate = dateStr => {\n      if (!dateStr) return '-- --';\n      return dateStr; // 可根据需要进一步格式化\n    };\n    onMounted(fetchReservationDetail);\n    const __returned__ = {\n      route,\n      router,\n      reservation,\n      refreshing,\n      canceling,\n      reservationId,\n      fetchReservationDetail,\n      refreshQrcode,\n      cancelBooking,\n      formatDate,\n      ref,\n      onMounted,\n      get useRoute() {\n        return useRoute;\n      },\n      get useRouter() {\n        return useRouter;\n      },\n      get reservationAPI() {\n        return reservationAPI;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRoute","useRouter","reservationAPI","route","router","reservation","refreshing","canceling","reservationId","query","fetchReservationDetail","alert","back","console","log","res","getReservationDetail","code","value","data","message","e","error","refreshQrcode","cancelBooking","confirm","cancelReservation","push","formatDate","dateStr"],"sources":["D:/AAA红梅/江姐博物馆/jiangjie-museum/src/views/MineBook_1.vue"],"sourcesContent":["<template>\r\n  <div class=\"booking-page\">\r\n    <!-- 顶部导航 -->\r\n    <div class=\"header\">\r\n      <span class=\"title\">我的当前预约</span>\r\n      <button class=\"close-btn\" @click=\"$router.push('/mine/book')\">×</button>\r\n    </div>\r\n\r\n    <!-- 完整的参观票容器 -->\r\n    <div class=\"ticket-container\">\r\n      <div class=\"card\">\r\n        <div class=\"card-header\">\r\n          <h2 class=\"card-title\">江姐生平<br>事迹陈列展主馆</h2>\r\n        </div>\r\n        <div class=\"card-content\">\r\n          <div class=\"basic-info\">\r\n            <div class=\"info-item\">\r\n              <span class=\"value\">{{ reservation?.phone || '****' }}</span>\r\n              <hr>\r\n              <span class=\"label\">预约手机号</span>\r\n            </div>\r\n            <div class=\"info-item code-item\">\r\n              <span class=\"label\">核销码</span>\r\n              <span class=\"code\">{{ reservation?.verifyCode || '****' }}</span>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <span class=\"value\">{{ reservation?.visitTime || '--:--' }}</span>\r\n              <hr>\r\n              <span class=\"label\">预计抵达时间</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"feature-bar\">\r\n            <span class=\"feature-tag\">✓ 随心退</span>\r\n            <span class=\"feature-tag\">✓ 可帮订</span>\r\n            <span class=\"feature-tag\">✓ 请于游玩当天16:30前入馆</span>\r\n          </div>\r\n          <div class=\"visit-info\">\r\n            <div class=\"info-item\">\r\n              <span class=\"label\">参观时间</span>\r\n              <span class=\"value\">{{ formatDate(reservation?.visitDate) }}</span>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <span class=\"label\">同行人数</span>\r\n              <span class=\"value\">{{ reservation?.peopleCount || 1 }}</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"dashed-divider\"></div>\r\n      <div class=\"qrcode-section\">\r\n      <!-- 使用默认二维码图片 -->\r\n      <img src=\"../imgs/二维码.png\" alt=\"预约二维码\" class=\"qrcode\">\r\n      <div class=\"qrcode-label\">{{ reservation?.verifyCode || '预约码' }}</div>\r\n      <button class=\"refresh-btn\" :disabled=\"refreshing\" @click=\"refreshQrcode\">{{ refreshing ? '刷新中...' : '刷新二维码' }}</button>\r\n    </div>\r\n    </div>\r\n\r\n    <!-- 底部按钮与印章容器 -->\r\n    <div class=\"bottom-container\">\r\n      <div class=\"footer-buttons\">\r\n        <button class=\"btn cancel-btn\" :disabled=\"canceling\" @click=\"cancelBooking\"><img src=\"../imgs/取消预约.png\" alt=\"取消预约\"></button>\r\n        <button class=\"btn save-btn\"><img src=\"../imgs/保存至本地.png\" alt=\"保存至本地\"></button>\r\n      </div>\r\n      <div class=\"seal\">\r\n        <img src=\"../imgs/欢迎.png\" alt=\"欢迎印章\">\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue';\r\nimport { useRoute, useRouter } from 'vue-router';\r\nimport { reservationAPI } from '../api/index';\r\n\r\nconst route = useRoute();\r\nconst router = useRouter();\r\nconst reservation = ref(null);\r\nconst refreshing = ref(false);\r\nconst canceling = ref(false);\r\n\r\nconst reservationId = route.query.reservationId;   // 从预约页传入的预约ID\r\n\r\nconst fetchReservationDetail = async () => {\r\n  if (!reservationId) {\r\n    alert('缺少预约ID，无法查看详情');\r\n    router.back();\r\n    return;\r\n  }\r\n  try {\r\n    console.log('正在获取预约详情，ID:', reservationId);\r\n    const res = await reservationAPI.getReservationDetail(reservationId);\r\n    console.log('预约详情响应:', res);\r\n    if (res && res.code === 200) {\r\n      reservation.value = res.data;\r\n    } else {\r\n      alert(res?.message || '获取预约详情失败');\r\n    }\r\n  } catch (e) {\r\n    console.error('获取预约详情失败:', e);\r\n    alert('获取预约详情失败: ' + (e.message || '未知错误'));\r\n  }\r\n};\r\n\r\nconst refreshQrcode = async () => {\r\n  refreshing.value = true;\r\n  await fetchReservationDetail();\r\n  refreshing.value = false;\r\n};\r\n\r\nconst cancelBooking = async () => {\r\n  if (canceling.value) return;\r\n  if (!confirm('确定要取消本次预约吗？')) return;\r\n  canceling.value = true;\r\n  try {\r\n    const res = await reservationAPI.cancelReservation(reservationId);\r\n    if (res && res.code === 200) {\r\n      alert('预约已取消');\r\n      router.push('/mine/book');\r\n    } else {\r\n      alert(res?.message || '取消失败');\r\n    }\r\n  } catch (e) {\r\n    alert('取消失败');\r\n  } finally {\r\n    canceling.value = false;\r\n  }\r\n};\r\n\r\n// 格式化日期显示（假设visitDate是\"2024-10-04\"形式）\r\nconst formatDate = (dateStr) => {\r\n  if (!dateStr) return '-- --';\r\n  return dateStr;  // 可根据需要进一步格式化\r\n};\r\n\r\nonMounted(fetchReservationDetail);\r\n</script>\r\n\r\n<style scoped>\r\n/* 基础布局 - 全屏铺满，稳定基准 */\r\n.booking-page {\r\n  min-height: 100vh;\r\n  width: 100vw;\r\n  margin: 0;\r\n  padding: 0;\r\n  background: #d6e4f0;\r\n  font-family: \"PingFang SC\", \"Microsoft YaHei\", sans-serif;\r\n  position: relative;\r\n  padding-bottom: 160px;\r\n  box-sizing: border-box;\r\n  overflow-x: hidden;\r\n}\r\n\r\n.header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 20px 30px;\r\n  color: #333;\r\n}\r\n\r\n.title {\r\n  font-size: clamp(16px, 2vw, 24px);\r\n  font-weight: 600;\r\n}\r\n\r\n.close-btn {\r\n  font-size: clamp(20px, 3vw, 30px);\r\n  background: none;\r\n  border: none;\r\n  cursor: pointer;\r\n  color: #333;\r\n  padding: 0;\r\n  width: 40px;\r\n  height: 40px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n/* 票卡容器 - 负边距固定px，与印章精准接触 */\r\n.ticket-container {\r\n  background: rgba(255, 255, 255, 0.6) url('../imgs/1（背景图）.png') no-repeat center/cover;\r\n  border-radius: clamp(8px, 2vw, 20px);\r\n  overflow: hidden;\r\n  margin: 0 auto -50px;\r\n  padding: 0;\r\n  max-width: 600px;\r\n  width: calc(100% - 60px);\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\r\n  position: relative;\r\n  z-index: 2;\r\n}\r\n\r\n.card {\r\n  background: transparent;\r\n}\r\n\r\n.card-header {\r\n  background: rgba(255, 255, 255, 0.8) url('../imgs/1（背景图）.png') no-repeat center/cover;\r\n  color: #333;\r\n  padding: clamp(20px, 4vw, 40px) clamp(15px, 3vw, 30px);\r\n  text-align: left;\r\n}\r\n\r\n.card-title {\r\n  font-size: clamp(18px, 2.5vw, 28px);\r\n  font-weight: bold;\r\n  line-height: 1.4;\r\n}\r\n\r\n.basic-info {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: clamp(15px, 2vw, 20px) clamp(15px, 3vw, 30px);\r\n  flex-wrap: wrap;\r\n  gap: 15px;\r\n}\r\n\r\n.info-item {\r\n  text-align: center;\r\n  flex: 1;\r\n  min-width: 80px;\r\n}\r\n\r\n.code-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n}\r\n\r\n.label {\r\n  display: block;\r\n  font-size: clamp(12px, 1.5vw, 16px);\r\n  color: #666;\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.value {\r\n  font-size: clamp(14px, 2vw, 20px);\r\n  font-weight: 500;\r\n}\r\n\r\n.code {\r\n  background: #333;\r\n  color: #fff;\r\n  padding: clamp(5px, 1vw, 8px) clamp(10px, 1.5vw, 15px);\r\n  border-radius: clamp(3px, 0.8vw, 6px);\r\n  font-family: monospace;\r\n  font-weight: bold;\r\n  font-size: clamp(14px, 2vw, 20px);\r\n}\r\n\r\n.feature-bar {\r\n  background: #a62b28;\r\n  color: #fff;\r\n  padding: clamp(10px, 1.5vw, 15px) clamp(15px, 2vw, 20px);\r\n  display: flex;\r\n  justify-content: space-between;\r\n  font-size: clamp(12px, 1.5vw, 14px);\r\n  flex-wrap: wrap;\r\n  gap: 10px;\r\n}\r\n\r\n.visit-info {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: clamp(15px, 2vw, 20px) clamp(15px, 3vw, 30px);\r\n  margin: 0;\r\n  flex-wrap: wrap;\r\n  gap: 20px;\r\n}\r\n\r\n.dashed-divider {\r\n  position: relative;\r\n  height: clamp(8px, 1.5vw, 15px);\r\n  margin: clamp(3px, 1vw, 8px);\r\n  border-top: clamp(1px, 0.3vw, 3px) dashed #999;\r\n}\r\n\r\n.dashed-divider::before {\r\n  content: '';\r\n  position: absolute;\r\n  left: -10px;\r\n  top: -10px;\r\n  width: 20px;\r\n  height: 20px;\r\n  background: #d6e4f0;\r\n  border-radius: 50%;\r\n}\r\n\r\n.dashed-divider::after {\r\n  content: '';\r\n  position: absolute;\r\n  right: -10px;\r\n  top: -10px;\r\n  width: 20px;\r\n  height: 20px;\r\n  background: #d6e4f0;\r\n  border-radius: 50%;\r\n}\r\n\r\n/* 二维码区域 - 最高层级，防止遮挡 */\r\n.qrcode-section {\r\n  background: transparent;\r\n  padding: 25px clamp(15px, 3vw, 30px);\r\n  text-align: center;\r\n  margin: 0;\r\n  position: relative;\r\n  z-index: 3;\r\n}\r\n\r\n.qrcode {\r\n  width: clamp(180px, 25vw, 280px);\r\n  height: clamp(180px, 25vw, 280px);\r\n  margin: 0 auto 15px;\r\n  display: block;\r\n}\r\n\r\n.qrcode-label {\r\n  font-size: clamp(14px, 1.5vw, 16px);\r\n  color: #666;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.refresh-btn {\r\n  background: transparent;\r\n  border: clamp(1px, 0.2vw, 2px) solid #070605e3;\r\n  padding: 8px 20px;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  font-size: clamp(14px, 1.5vw, 16px);\r\n  color: #333;\r\n}\r\n\r\n/* 底部容器 - 固定宽度基准，定位不偏移 */\r\n.bottom-container {\r\n  position: fixed;\r\n  bottom: 20px;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  width: 100%;\r\n  max-width: 500px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  z-index: 10;\r\n}\r\n\r\n.footer-buttons {\r\n  display: flex;\r\n  gap: 20px;\r\n  justify-content: center;\r\n  align-items: center;\r\n  width: 100%;\r\n}\r\n\r\n.btn {\r\n  width: auto;\r\n  height: auto;\r\n  padding: 0;\r\n  border: none;\r\n  background: transparent !important;\r\n  cursor: pointer;\r\n}\r\n\r\n.cancel-btn img, .save-btn img {\r\n  width: clamp(100px, 40vw, 200px);\r\n  height: auto;\r\n  object-fit: contain;\r\n  display: block;\r\n}\r\n\r\n/* 印章 - 完整显示，与票卡精准接触 */\r\n.seal {\r\n  position: absolute;\r\n  bottom: 70px;\r\n  width: clamp(100px, 30vw, 150px);\r\n  height: clamp(100px, 30vw, 150px);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: transparent;\r\n  box-shadow: none;\r\n  z-index: 1;\r\n}\r\n\r\n.seal img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: contain;\r\n}\r\n\r\n/* 移动端适配 - 仅微调尺寸，位置关系不变 */\r\n@media (max-width: 768px) {\r\n  .booking-page {\r\n    padding: 15px;\r\n    padding-bottom: 140px;\r\n  }\r\n  .ticket-container {\r\n    width: calc(100% - 30px);\r\n    margin: 0 auto -45px;\r\n  }\r\n  .qrcode {\r\n    width: 180px;\r\n    height: 180px;\r\n  }\r\n  .seal {\r\n    bottom: 60px;\r\n    width: 100px;\r\n    height: 100px;\r\n  }\r\n  .footer-buttons {\r\n    gap: 15px;\r\n  }\r\n  .cancel-btn img, .save-btn img {\r\n    width: clamp(80px, 40vw, 120px);\r\n  }\r\n}\r\n</style>"],"mappings":";AAuEA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,QAAQ,EAAEC,SAAS,QAAQ,YAAY;AAChD,SAASC,cAAc,QAAQ,cAAc;;;;