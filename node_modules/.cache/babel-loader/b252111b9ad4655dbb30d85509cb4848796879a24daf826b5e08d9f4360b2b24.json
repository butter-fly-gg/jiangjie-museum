isplayString(item.name) + \" 🌸\", 1 /* TEXT */)) : (_openBlock(), _createElementBlock(\"span\", _hoisted_7, _toDisplayString(item.name), 1 /* TEXT */))])], 10 /* CLASS, PROPS */, _hoisted_3);\n  }), 128 /* KEYED_FRAGMENT */))], 4 /* STYLE */), _createElementVNode(\"div\", {\n    class: \"arrow right\",\n    onClick: $setup.next\n  }, \"❯\")]), _createElementVNode(\"button\", {\n    class: \"enter-btn\",\n    onClick: $setup.enter\n  }, \"进入 \" + _toDisplayString($setup.currentItem.name), 1 /* TEXT */)]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","onClick","$setup","goBack","_createCommentVNode","_hoisted_2","prev","style","_normalizeStyle","transform","offset","_Fragment","_renderList","modeList","item","index","_normalizeClass","active","current","key","$event","select","src","img","_hoisted_5","_hoisted_6","_toDisplayString","name","_hoisted_7","next","enter","currentItem"],"sources":["D:\\AAA红梅\\江姐博物馆\\jiangjie-museum\\src\\views\\ModeSelectView.vue"],"sourcesContent":["<template>\r\n  <div class=\"mode-page\">\r\n    <div class=\"back-bar\" @click=\"goBack\">← 返回</div>\r\n\r\n    <h2 class=\"title\">—— 请选择您想体验的模式 ——</h2>\r\n\r\n    <!-- 外层容器：保证三张图并排可见 -->\r\n    <div class=\"carousel-container\">\r\n      <div class=\"arrow left\" @click=\"prev\">❮</div>\r\n\r\n      <!-- 核心：三张图连在一起，中间放大 -->\r\n      <div class=\"carousel-track\" :style=\"{ transform: `translateX(${offset}px)` }\">\r\n        <div\r\n          class=\"mode-card\"\r\n          :class=\"{ active: current === index }\"\r\n          v-for=\"(item, index) in modeList\"\r\n          :key=\"index\"\r\n          @click=\"select(index)\"\r\n        >\r\n          <img class=\"mode-img\" :src=\"item.img\" />\r\n          <div class=\"label\">\r\n            <span v-if=\"current === index\">🌸 {{ item.name }} 🌸</span>\r\n            <span v-else>{{ item.name }}</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"arrow right\" @click=\"next\">❯</div>\r\n    </div>\r\n\r\n    <button class=\"enter-btn\" @click=\"enter\">进入 {{ currentItem.name }}</button>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\n// 1. 导入图片（根据你截图的文件结构，确保路径正确）\r\nimport storyImg from '../imgs/Game1.l.png'\r\nimport interactiveImg from '../imgs/Game1.m.png'\r\nimport scrollImg from '../imgs/Game1.r.png'\r\n\r\nconst router = useRouter()\r\n\r\n// 2. 模式列表\r\nconst modeList = ref([\r\n  { name: '故事聆听模式', img: storyImg, path: '/story' },\r\n  { name: '现场交互模式', img: interactiveImg, path: '/interactive' },\r\n  { name: '线上绘卷模式', img: scrollImg, path: '/scroll' },\r\n])\r\n\r\n// 3. 永远中间是选中项\r\nconst current = ref(1)\r\n\r\n// 4. 计算位移：让当前项永远在视觉中间\r\n// 公式：-(索引 - 1) * 容器宽度的一半 (这里用固定比例实现居中)\r\nconst offset = computed(() => {\r\n  // 100% 是容器宽度，-(current.value - 1) * 33.33 实现三张连在一起滑动\r\n  return -(current.value - 1) * 33.33\r\n})\r\n\r\n// 5. 当前选中项\r\nconst currentItem = computed(() => modeList.value[current.value])\r\n\r\n// 6. 切换逻辑\r\nfunction prev() {\r\n  current.value = current.value === 0 ? 2 : current.value - 1\r\n}\r\n\r\nfunction next() {\r\n  current.value = current.value === 2 ? 0 : current.value + 1\r\n}\r\n\r\nfunction select(i) {\r\n  current.value = i\r\n}\r\n\r\nfunction goBack() {\r\n  router.back()\r\n}\r\n\r\nfunction enter() {\r\n  router.push(currentItem.value.path)\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.mode-page {\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background: url(../imgs/Gamecover_1.png) no-repeat center center;\r\n  background-size: cover;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 30px 20px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.back-bar {\r\n  align-self: flex-start;\r\n  color: #fff;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n}\r\n\r\n.title {\r\n  color: #fff;\r\n  font-size: 26px;\r\n  margin-bottom: 30px;\r\n  text-shadow: 0 2px 4px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* 核心容器：限制宽度，保证三张图挤在中间 */\r\n.carousel-container {\r\n  position: relative;\r\n  width: 100%;\r\n  max-width: 900px; /* 限制最大宽度 */\r\n  height: 450px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden; /* 隐藏溢出 */\r\n}\r\n\r\n/* 箭头样式 */\r\n.arrow {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  width: 50px;\r\n  height: 50px;\r\n  background: rgba(255,255,255,0.2);\r\n  border: 2px solid #fff;\r\n  border-radius: 50%;\r\n  color: #fff;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  z-index: 10;\r\n  transition: background 0.3s;\r\n}\r\n.arrow:hover {\r\n  background: rgba(255,255,255,0.4);\r\n}\r\n.arrow.left { left: -60px; } /* 稍微往外一点 */\r\n.arrow.right { right: -60px; }\r\n\r\n/* 核心：三张图连在一起 (300% = 3 * 100%) */\r\n.carousel-track {\r\n  display: flex;\r\n  width: 300%;\r\n  height: 100%;\r\n  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* 丝滑动画 */\r\n}\r\n\r\n/* 卡片：每一张占 33.33%，连在一起 */\r\n.mode-card {\r\n  width: 33.333%;\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.4s ease;\r\n  transform: scale(0.85); /* 左右默认小一点 */\r\n  opacity: 0.8;\r\n}\r\n\r\n/* 激活状态：中间放大 (1.15倍) */\r\n.mode-card.active {\r\n  transform: scale(1.15); /* 中间最大 */\r\n  opacity: 1;\r\n  z-index: 5; /* 提升层级，不被遮挡 */\r\n}\r\n\r\n.mode-img {\r\n  width: 100%;\r\n  height: 380px;\r\n  object-fit: cover; /* 保持比例 */\r\n}\r\n\r\n.label {\r\n  margin-top: 10px;\r\n  color: #fff;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  text-shadow: 0 2px 5px rgba(0,0,0,0.7);\r\n}\r\n\r\n.enter-btn {\r\n  margin-top: 30px;\r\n  padding: 14px 50px;\r\n  background: #c0392b;\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 15px rgba(0,0,0,0.3);\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAW;;EAMfA,KAAK,EAAC;AAAoB;;;;EAapBA,KAAK,EAAC;AAAO;;;;;;;;uBAnB1BC,mBAAA,CA8BM,OA9BNC,UA8BM,GA7BJC,mBAAA,CAAgD;IAA3CH,KAAK,EAAC,UAAU;IAAEI,OAAK,EAAEC,MAAA,CAAAC;KAAQ,MAAI,G,0BAE1CH,mBAAA,CAAuC;IAAnCH,KAAK,EAAC;EAAO,GAAC,kBAAgB,qBAElCO,mBAAA,oBAAuB,EACvBJ,mBAAA,CAqBM,OArBNK,UAqBM,GApBJL,mBAAA,CAA6C;IAAxCH,KAAK,EAAC,YAAY;IAAEI,OAAK,EAAEC,MAAA,CAAAI;KAAM,GAAC,GAEvCF,mBAAA,qBAAwB,EACxBJ,mBAAA,CAcM;IAdDH,KAAK,EAAC,gBAAgB;IAAEU,KAAK,EAAAC,eAAA;MAAAC,SAAA,gBAA6BP,MAAA,CAAAQ,MAAM;IAAA;yBACnEZ,mBAAA,CAYMa,SAAA,QAAAC,WAAA,CAToBV,MAAA,CAAAW,QAAQ,GAAxBC,IAAI,EAAEC,KAAK;yBAHrBjB,mBAAA,CAYM;MAXJD,KAAK,EAAAmB,eAAA,EAAC,WAAW;QAAAC,MAAA,EACCf,MAAA,CAAAgB,OAAO,KAAKH;MAAK;MAElCI,GAAG,EAAEJ,KAAK;MACVd,OAAK,EAAAmB,MAAA,IAAElB,MAAA,CAAAmB,MAAM,CAACN,KAAK;QAEpBf,mBAAA,CAAwC;MAAnCH,KAAK,EAAC,UAAU;MAAEyB,GAAG,EAAER,IAAI,CAACS;yCACjCvB,mBAAA,CAGM,OAHNwB,UAGM,GAFQtB,MAAA,CAAAgB,OAAO,KAAKH,KAAK,I,cAA7BjB,mBAAA,CAA2D,QAAA2B,UAAA,EAA5B,KAAG,GAAAC,gBAAA,CAAGZ,IAAI,CAACa,IAAI,IAAG,KAAG,oB,cACpD7B,mBAAA,CAAmC,QAAA8B,UAAA,EAAAF,gBAAA,CAAnBZ,IAAI,CAACa,IAAI,kB;mDAK/B3B,mBAAA,CAA8C;IAAzCH,KAAK,EAAC,aAAa;IAAEI,OAAK,EAAEC,MAAA,CAAA2B;KAAM,GAAC,E,GAG1C7B,mBAAA,CAA2E;IAAnEH,KAAK,EAAC,WAAW;IAAEI,OAAK,EAAEC,MAAA,CAAA4B;KAAO,KAAG,GAAAJ,gBAAA,CAAGxB,MAAA,CAAA6B,WAAW,CAACJ,IAAI,iB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}