\">\r\n          <defs>\r\n            <filter id=\"routeShadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\r\n              <feDropShadow dx=\"0\" dy=\"2\" stdDeviation=\"3\" flood-opacity=\"0.3\"/>\r\n            </filter>\r\n          </defs>\r\n          \r\n          <!-- 绿色路线 (实线) -->\r\n          <path \r\n            class=\"route-line\"\r\n            d=\"M 60 480 L 80 450 L 120 420 L 180 400 L 220 380 L 260 360 L 280 340 L 300 320 L 320 300 L 340 280\"\r\n            stroke=\"#4CAF50\"\r\n            stroke-width=\"6\"\r\n            fill=\"none\"\r\n            stroke-linecap=\"round\"\r\n            stroke-linejoin=\"round\"\r\n            filter=\"url(#routeShadow)\"\r\n          />\r\n          \r\n          <!-- 起点标记 -->\r\n          <g class=\"marker start-marker\" transform=\"translate(60, 480)\">\r\n            <circle r=\"10\" fill=\"#2E7D32\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n            <text y=\"25\" text-anchor=\"middle\" font-size=\"12\" font-weight=\"bold\" fill=\"#333\">起点</text>\r\n            <text y=\"40\" text-anchor=\"middle\" font-size=\"10\" fill=\"#666\">江姐故里</text>\r\n          </g>\r\n          \r\n          <!-- 终点标记 -->\r\n          <g class=\"marker end-marker\" transform=\"translate(340, 280)\">\r\n            <circle r=\"10\" fill=\"#D32F2F\" stroke=\"#fff\" stroke-width=\"2\"/>\r\n            <text y=\"25\" text-anchor=\"middle\" font-size=\"12\" font-weight=\"bold\" fill=\"#333\">终点</text>\r\n            <text y=\"40\" text-anchor=\"middle\" font-size=\"10\" fill=\"#666\">东锅厂</text>\r\n          </g>\r\n          \r\n          <!-- 途经点气泡 1 -->\r\n          <foreignObject x=\"100\" y=\"350\" width=\"100\" height=\"120\" class=\"spot-bubble\">\r\n            <div xmlns=\"http://www.w3.org/1999/xhtml\" class=\"bubble-wrapper\">\r\n              <img src=\"@/assets/images/beautiful/spot-1.jpg\" alt=\"途经点1\" class=\"bubble-img\" />\r\n              <div class=\"bubble-arrow\"></div>\r\n            </div>\r\n   